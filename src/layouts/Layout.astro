---
import '../styles/global.css';
import DeadDrop from '../components/DeadDrop.astro';
import AdminBar from '../components/AdminBar.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  categoryHref?: string;
  ogImage?: string;
}

const { title, description, category, categoryHref, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;

const siteUrl = 'https://soundsystemhardening.fr';
const defaultDescription = 'Plateforme collective : wiki, documentation et outils pour le mouvement free party. Loi RIPOST, sécurité numérique, stratégies juridiques.';
const resolvedDescription = description || defaultDescription;
// Image OpenGraph 1200x630 dédiée : preview large dans Signal/Telegram/X.
// Surchargeable par page via la prop `ogImage` (chemin racine ou URL absolue).
const resolvedImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`)
  : `${siteUrl}/og-cover.png`;
const resolvedTitle = title === 'Home' ? 'SoundSystemHardening' : `${title} | SoundSystemHardening`;

const sidebarIcons: Record<string, string> = {
  home:      `<path d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" stroke-linecap="round" stroke-linejoin="round"/>`,
  scale:     `<path d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  shield:    `<path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  crosshair: `<path d="M12 3v3m0 12v3M3 12h3m12 0h3m-4.222-6.778-2.121 2.121M9.343 14.657l-2.121 2.121m0-9.9 2.121 2.121m5.314 5.314 2.121 2.121M12 8.25a3.75 3.75 0 1 0 0 7.5 3.75 3.75 0 0 0 0-7.5Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  clock:     `<path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  megaphone: `<path d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 1 8.835-2.535m0 0A23.74 23.74 0 0 1 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" stroke-linecap="round" stroke-linejoin="round"/>`,
  terminal:  `<path d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  eye:       `<path d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  radio:     `<path d="M3.75 7.5l16.5-4.125M12 6.75c-2.708 0-5.363.224-7.948.655C2.566 7.685 1.5 9.048 1.5 10.61v4.765c0 1.562 1.067 2.926 2.552 3.207C6.637 19.026 9.292 19.25 12 19.25s5.363-.224 7.948-.655c1.485-.281 2.552-1.645 2.552-3.207v-4.765c0-1.562-1.067-2.925-2.552-3.206A48.97 48.97 0 0 0 12 6.75Zm-1.5 6a1.5 1.5 0 1 0 3 0 1.5 1.5 0 0 0-3 0Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  lock:      `<path d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  funnel:    `<path d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" stroke-linecap="round" stroke-linejoin="round"/>`,
};

// Menu mobile : reprend l'integralite de la navigation topbar (masquee sur mobile).
const compactNav = [
  { href: '/commencer', label: 'Commencer ici', icon: 'start' },
  { href: '/wiki',      label: 'Wiki',          icon: 'wiki' },
  { href: '/urgence',   label: 'Urgence',       icon: 'urgence', crit: true },
  { href: '/wiki/ripost', label: 'RIPOST',      icon: 'ripost' },
  { href: '/decision',  label: 'Arbre de décision', icon: 'decision' },
  { href: '/map',       label: 'Carte',         icon: 'map' },
  { href: '/contribuer',label: 'Contribuer',    icon: 'contribute' },
];
// Outils interactifs (correspond au menu OUTILS de la topbar desktop).
const compactTools = [
  { href: '/tools',             label: 'Tous les outils', icon: 'tools' },
  { href: '/soundcheck',        label: 'SoundCheck',      icon: 'soundcheck' },
  { href: '/copwatch',          label: 'CopWatch',        icon: 'copwatch' },
  { href: '/opsec-tools',       label: 'OpSec Tools',     icon: 'opsec' },
  { href: '/timeseal',          label: 'TimeSeal',        icon: 'timeseal' },
  { href: '/compliance-shield', label: 'Compliance-Shield', icon: 'shield_check' },
  { href: '/infocrypt',         label: 'InfoCrypt',       icon: 'infocrypt' },
  { href: '/stripmeta',         label: 'StripMeta',       icon: 'stripmeta' },
];
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- meta[name=generator] supprimé : expose la version exacte du framework (profil CVE) -->
    <title>{resolvedTitle}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SoundSystemHardening",
      "url": "https://soundsystemhardening.fr",
      "logo": "https://soundsystemhardening.fr/SoundSystemHardening-logo.png",
      "description": "Plateforme collective : wiki, documentation et outils pour le mouvement free party"
    }
    </script>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={`${siteUrl}${currentPath}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${currentPath}`} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={resolvedImage} />
    <meta property="og:image:secure_url" content={resolvedImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="SoundSystemHardening - wiki droits, opsec et résistance free party" />
    <meta property="og:site_name" content="SoundSystemHardening" />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={resolvedImage} />
    <meta name="twitter:image:alt" content="SoundSystemHardening - wiki droits, opsec et résistance free party" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#00ff9f" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="SSHardening" />
    <style>
      /* Logo top bar */
      .topbar-logo-link {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3px 10px;
        margin-top: -14px;
      }
      .topbar-logo-link:hover {
        animation: none;
      }
      .topbar-logo-img {
        filter: drop-shadow(0 0 6px rgba(0,255,159,0.5));
        animation: logo-glow-pulse 3s ease-in-out infinite;
        transition: filter 0.2s;
      }
      .topbar-logo-link:hover .topbar-logo-img {
        filter: drop-shadow(0 0 10px rgba(0,255,159,0.9)) drop-shadow(0 0 20px rgba(0,255,159,0.4));
        animation: none;
      }
      @keyframes logo-glow-pulse {
        0%, 100% { filter: drop-shadow(0 0 4px rgba(0,255,159,0.3)); }
        50%       { filter: drop-shadow(0 0 10px rgba(0,255,159,0.7)) drop-shadow(0 0 18px rgba(0,255,159,0.3)); }
      }
      /* Logo centré mobile : meme halo vert pulsé que le desktop */
      .topbar-logo-mobile-img {
        filter: drop-shadow(0 0 6px rgba(0,255,159,0.5));
        animation: logo-glow-pulse 3s ease-in-out infinite;
      }
      @media (prefers-reduced-motion: reduce) {
        .topbar-logo-mobile-img { animation: none; }
      }
      /* Logo desktop centré : masqué sur mobile */
      .topbar-logo-desktop { display: none; }
      @media (min-width: 768px) {
        .topbar-logo-desktop { display: flex; }
      }
      /* Glitch sobre du titre HARDENING dans le menu mobile (aberration verte/rouge) */
      .sb-glitch { position: relative; }
      .sb-glitch::before,
      .sb-glitch::after {
        content: attr(data-glitch);
        position: absolute;
        top: 0; left: 0;
        opacity: 0;
        pointer-events: none;
      }
      .sb-glitch::before { color: #00ff9f; animation: sb-glitch-g 6s steps(1) infinite; }
      .sb-glitch::after  { color: rgba(255,68,68,0.85); animation: sb-glitch-r 6s steps(1) infinite; }
      @keyframes sb-glitch-g {
        0%, 100% { opacity: 0; transform: translate(0); }
        92% { opacity: 0.8; transform: translate(-1px, 0); }
        94% { opacity: 0; }
        96% { opacity: 0.7; transform: translate(1px, 0); }
        98% { opacity: 0; }
      }
      @keyframes sb-glitch-r {
        0%, 100% { opacity: 0; transform: translate(0); }
        93% { opacity: 0.7; transform: translate(1px, 0); }
        95% { opacity: 0; }
        97% { opacity: 0.6; transform: translate(-1px, 0); }
        99% { opacity: 0; }
      }
      @media (prefers-reduced-motion: reduce) {
        .sb-glitch::before, .sb-glitch::after { animation: none; opacity: 0; }
      }

      /* Animation pin carte dans la topbar */
      .carte-pin-idle {
        display: inline-flex;
        animation: pin-pulse 2.5s ease-in-out infinite;
        transform-origin: center bottom;
      }
      @keyframes pin-pulse {
        0%, 100% { transform: translateY(0) scale(1); opacity: 1; }
        50%       { transform: translateY(-2px) scale(1.15); opacity: .7; }
      }
      .carte-pin-active {
        display: inline-flex;
        filter: drop-shadow(0 0 4px #00ff9f);
        animation: pin-glow 1.2s ease-in-out infinite alternate;
      }
      @keyframes pin-glow {
        from { filter: drop-shadow(0 0 2px #00ff9f); }
        to   { filter: drop-shadow(0 0 8px #00ff9f) drop-shadow(0 0 14px #00ff9f66); }
      }

      /* ── Dropdown OUTILS topbar ── */
      .tb-dropdown-wrap { position: relative; }
      .tb-tools-btn { background: transparent; cursor: pointer; white-space: nowrap; height: 100%; }
      .tb-tools-menu {
        position: absolute;
        top: calc(100% + 2px);
        left: 0;
        min-width: 240px;
        background: #08080c;
        border: 1px solid rgba(42,42,58,0.95);
        border-top: 2px solid rgba(0,255,159,0.5);
        z-index: 200;
        box-shadow: 0 8px 32px rgba(0,0,0,0.7);
      }
      /* état ouvert géré via remove('hidden') en JS */
      .tb-tools-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        text-decoration: none;
        border-bottom: 1px solid rgba(42,42,58,0.5);
        transition: background 0.12s;
        position: relative;
      }
      .tb-tools-item:last-child { border-bottom: none; }
      .tb-tools-item:hover { background: rgba(0,255,159,0.05); }
      .tb-tools-item.active { background: rgba(0,255,159,0.07); }
      .tb-tools-item-icon {
        font-size: 16px;
        color: rgba(0,255,159,0.6);
        flex-shrink: 0;
        width: 20px;
        text-align: center;
      }
      .tb-tools-item-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #e8e8f0;
      }
      .tb-tools-item.active .tb-tools-item-label { color: #00ff9f; }
      .tb-tools-item-desc {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        color: rgba(122,122,138,0.65);
        margin-top: 2px;
        letter-spacing: 0.04em;
      }
      .tb-tools-item-dot {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #00ff9f;
        box-shadow: 0 0 5px #00ff9f;
      }

      /* ── Onglets outils topbar (ligne 2) : presentation soignee ── */
      .tb-tab {
        position: relative;
        white-space: nowrap;
      }
      .tb-tab-icon {
        opacity: 0.7;
        transition: opacity 0.15s, transform 0.15s, filter 0.15s;
      }
      .tb-tab:hover .tb-tab-icon {
        opacity: 1;
        transform: translateY(-1px);
      }
      /* Onglet actif : icone mise en avant avec un leger halo neon */
      .tb-tab[aria-current="page"] .tb-tab-icon,
      .tb-tab.text-neon-green .tb-tab-icon {
        opacity: 1;
        filter: drop-shadow(0 0 5px rgba(0,255,159,0.55));
      }
      /* Separateur vertical discret entre onglets pour structurer la barre */
      .tb-tab + .tb-tab::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        height: 14px;
        width: 1px;
        background: rgba(42,42,58,0.6);
      }

      /* ════════ FOOTER PRINCIPAL ════════ */
      .ssh-footer {
        position: relative;
        margin-top: 4rem;
        border-top: 1px solid rgba(42,42,58,0.7);
        background:
          radial-gradient(120% 140% at 50% 0%, rgba(0,255,159,0.05) 0%, transparent 55%),
          linear-gradient(180deg, rgba(10,10,15,0.4) 0%, rgba(8,8,12,0.85) 100%);
        overflow: hidden;
      }
      /* Liseré néon haut */
      .ssh-footer::before {
        content: '';
        position: absolute;
        top: -1px; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, rgba(0,255,159,0.7) 25%, rgba(0,217,255,0.7) 50%, rgba(0,255,159,0.7) 75%, transparent 100%);
      }
      /* Grille discrète en filigrane */
      .ssh-footer::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(0,255,159,0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,255,159,0.025) 1px, transparent 1px);
        background-size: 32px 32px;
        mask-image: linear-gradient(180deg, rgba(0,0,0,0.6), transparent 70%);
        -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.6), transparent 70%);
        pointer-events: none;
      }
      .ssh-footer-inner { position: relative; z-index: 1; }

      /* Bandeau identité */
      .ssh-footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
        padding-bottom: 24px;
        margin-bottom: 28px;
        border-bottom: 1px solid rgba(42,42,58,0.5);
      }
      .ssh-footer-logo img {
        height: 52px;
        width: auto;
        display: block;
        filter: drop-shadow(0 0 8px rgba(0,255,159,0.3));
        transition: filter 0.2s;
      }
      .ssh-footer-logo:hover img {
        filter: drop-shadow(0 0 12px rgba(0,255,159,0.7));
      }
      .ssh-footer-brand-text { flex: 1; min-width: 0; }
      .ssh-footer-name {
        font-family: 'Space Grotesk', 'Inter', sans-serif;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 0.04em;
        color: #e8e8f0;
        line-height: 1.1;
      }
      .ssh-footer-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.08em;
        color: rgba(122,122,138,0.85);
        margin-top: 5px;
      }
      .ssh-footer-status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        flex-shrink: 0;
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(0,255,159,0.7);
        border: 1px solid rgba(0,255,159,0.25);
        border-radius: 2px;
        padding: 5px 10px;
        background: rgba(0,255,159,0.04);
      }
      .ssh-footer-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #00ff9f;
        box-shadow: 0 0 6px #00ff9f;
        animation: ssh-footer-pulse 2s ease-in-out infinite;
      }
      @keyframes ssh-footer-pulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 6px #00ff9f; }
        50%      { opacity: 0.4; box-shadow: 0 0 2px #00ff9f; }
      }

      /* Colonnes */
      .ssh-footer-col-title {
        display: flex;
        align-items: center;
        gap: 7px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #00ff9f;
        margin-bottom: 14px;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(0,255,159,0.12);
      }
      .ssh-footer-col-title.muted { color: rgba(122,122,138,0.9); border-bottom-color: rgba(42,42,58,0.6); }
      .ssh-footer-col-title svg { width: 13px; height: 13px; flex-shrink: 0; }

      .ssh-footer-link {
        display: flex;
        align-items: center;
        gap: 7px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11.5px;
        color: rgba(232,232,240,0.78);
        text-decoration: none;
        padding: 3px 0;
        transition: color 0.15s, transform 0.15s;
      }
      .ssh-footer-link::before {
        content: '›';
        color: rgba(0,255,159,0.35);
        font-size: 12px;
        transition: color 0.15s, transform 0.15s;
      }
      .ssh-footer-link:hover {
        color: #00ff9f;
        transform: translateX(3px);
      }
      .ssh-footer-link:hover::before { color: #00ff9f; transform: translateX(1px); }
      .ssh-footer-link .ext {
        font-size: 9px;
        color: rgba(122,122,138,0.5);
        margin-left: auto;
      }

      .ssh-footer-legal-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: rgba(122,122,138,0.9);
        padding: 3px 0;
      }
      .ssh-footer-legal-item .chk { color: rgba(0,255,159,0.6); }

      /* Barre basse */
      .ssh-footer-bottom {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: 32px;
        padding-top: 18px;
        border-top: 1px solid rgba(42,42,58,0.5);
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.08em;
        color: rgba(122,122,138,0.75);
      }
