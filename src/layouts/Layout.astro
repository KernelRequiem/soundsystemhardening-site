          <!-- Purger mes traces (mobile) : action locale, effacement du stockage du site -->
          <button type="button" data-purge class="sb-purge">
            <span class="sb-nav-ic"><Icon name="purge" size={16} /></span>
            <span class="sb-purge-label" data-purge-label>Purger mes traces</span>
