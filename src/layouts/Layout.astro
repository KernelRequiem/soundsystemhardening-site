          <a href="/" class="flex items-center gap-2.5 no-underline">
            <img src="/SoundSystemHardeninglogo.png" alt="" class="h-8 w-auto" style="filter: drop-shadow(0 0 6px rgba(0,255,159,0.35));" />
            <span class="font-display font-bold text-[11px] tracking-[0.18em] uppercase leading-tight">
              <span class="block"><span class="text-neon-green">SOUND</span><span class="text-dedsec-text">SYSTEM</span></span>
              <span class="block sb-glitch text-dedsec-text" data-glitch="HARDENING">HARDENING</span>
            </span>
          </a>
          <button id="menu-close" class="flex items-center justify-center w-8 h-8 rounded-md text-dedsec-muted hover:text-neon-green hover:bg-neon-green/5 transition-colors" aria-label="Fermer le menu">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
          </button>
        </div>

        <!-- Recherche -->
        <div class="shrink-0 px-3 pt-3">
          <a href="/search" class="flex items-center gap-2 bg-dedsec-black/60 border border-dedsec-border hover:border-neon-green/40 px-3 py-2.5 text-dedsec-muted hover:text-neon-green transition-all no-underline">
            <span class="text-neon-green/50 font-mono text-sm">⌕</span>
            <span class="font-mono text-xs flex-1 text-dedsec-muted/70">Rechercher...</span>
          </a>
        </div>

        <!-- Nav : reprend toute la navigation de la topbar -->
        <nav class="flex-1 overflow-y-auto py-3" aria-label="Menu principal">
          <div class="sb-group-title">Navigation</div>
          {compactNav.map((item) => (
            <a href={item.href} class={item.href === currentPath ? 'sb-nav-link active' : (item.crit ? 'sb-nav-link sb-nav-link--crit' : 'sb-nav-link')}>
              <span class="sb-nav-ic"><Icon name={item.icon} size={17} /></span>
              <span class="sb-nav-label">{item.label}</span>
