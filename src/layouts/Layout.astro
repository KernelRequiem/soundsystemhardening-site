    <script>
      const bar = document.getElementById('progress-bar');
      if (bar) {
        const update = () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.height = (docHeight > 0 ? (scrollTop / docHeight) * 100 : 0) + '%';
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
      }
      const toggle = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('overlay');
      const closeBtn = document.getElementById('menu-close');
      if (toggle && sidebar && overlay) {
        const openMenu = () => {
          sidebar.classList.remove('-translate-x-full');
          overlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          toggle.setAttribute('aria-expanded', 'true');
        };
        const closeMenu = () => {
          sidebar.classList.add('-translate-x-full');
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
          toggle.setAttribute('aria-expanded', 'false');
        };
        toggle.addEventListener('click', () =>
          sidebar.classList.contains('-translate-x-full') ? openMenu() : closeMenu()
        );
        overlay.addEventListener('click', closeMenu);
        closeBtn?.addEventListener('click', closeMenu);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
        // Fermer apres clic sur un lien du menu
        sidebar.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
      }

      // ── Purger mes traces : efface le stockage local du site (same-origin) ──
      // 100% local, reversible, rien n'est envoye. Double-clic = confirmation,
      // pour eviter une purge accidentelle d'un brouillon en cours (Compliance-Shield).
      document.querySelectorAll('[data-purge]').forEach((btn) => {
        const label = btn.querySelector('[data-purge-label]') as HTMLElement | null;
        const original = label?.textContent || '';
        let armed = false;
        let timer: ReturnType<typeof setTimeout> | null = null;
        btn.addEventListener('click', () => {
          if (!armed) {
            armed = true;
            if (label) label.textContent = 'Confirmer ?';
            btn.classList.add('is-armed');
            timer = setTimeout(() => {
              armed = false;
              if (label) label.textContent = original;
              btn.classList.remove('is-armed');
            }, 4000);
            return;
          }
          if (timer) clearTimeout(timer);
          let n = 0;
          try { n += localStorage.length; localStorage.clear(); } catch {}
          try { n += sessionStorage.length; sessionStorage.clear(); } catch {}
          armed = false;
          btn.classList.remove('is-armed');
          btn.classList.add('is-done');
          if (label) label.textContent = '✓ Effacé';
          setTimeout(() => {
            btn.classList.remove('is-done');
            if (label) label.textContent = original;
          }, 2500);
        });
      });
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {

        // ── Dropdown OUTILS topbar (hover) ──
        const tbBtn  = document.getElementById('tb-tools-btn');
        const tbMenu = document.getElementById('tb-tools-menu');
        const tbChev = document.getElementById('tb-tools-chev');
        if (tbBtn && tbMenu) {
          let tbCloseTimer: ReturnType<typeof setTimeout> | null = null;

          function tbPosition() {
            const rect = tbBtn.getBoundingClientRect();
            const el = tbMenu as HTMLElement;
            const menuW = Math.max(el.offsetWidth, 240);
            let left = rect.left;
            const maxLeft = window.innerWidth - menuW - 8;
            if (left > maxLeft) left = Math.max(8, maxLeft);
            el.style.top  = rect.bottom + 'px';
            el.style.left = left + 'px';
          }
          function tbOpen() {
            if (tbCloseTimer) { clearTimeout(tbCloseTimer); tbCloseTimer = null; }
            tbPosition();
            tbMenu.classList.remove('hidden');
            tbBtn.setAttribute('aria-expanded', 'true');
            if (tbChev) (tbChev as HTMLElement).style.transform = 'rotate(180deg)';
          }
          function tbClose() {
            tbMenu.classList.add('hidden');
            tbBtn.setAttribute('aria-expanded', 'false');
            if (tbChev) (tbChev as HTMLElement).style.transform = '';
          }
          function tbScheduleClose() {
            tbCloseTimer = setTimeout(tbClose, 150);
          }

          // Hover sur le lien
          tbBtn.addEventListener('mouseenter', tbOpen);
          tbBtn.addEventListener('mouseleave', tbScheduleClose);

          // Hover sur le menu lui-même - annuler la fermeture
          tbMenu.addEventListener('mouseenter', () => {
            if (tbCloseTimer) { clearTimeout(tbCloseTimer); tbCloseTimer = null; }
          });
          tbMenu.addEventListener('mouseleave', tbScheduleClose);

          // Fermer au clic en dehors (sécurité)
          document.addEventListener('click', (e) => {
            if (!tbBtn.contains(e.target as Node) && !tbMenu.contains(e.target as Node)) tbClose();
          });
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') tbClose();
          });

          // Navigation clavier
          tbBtn.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowDown') { e.preventDefault(); tbOpen(); (tbMenu.querySelector('.tb-tools-item') as HTMLElement)?.focus(); }
          });
          tbMenu.addEventListener('keydown', (e) => {
            const items = Array.from(tbMenu.querySelectorAll('.tb-tools-item')) as HTMLElement[];
            const idx   = items.indexOf(document.activeElement as HTMLElement);
            if (e.key === 'ArrowDown') { e.preventDefault(); items[(idx + 1) % items.length]?.focus(); }
            if (e.key === 'ArrowUp')   { e.preventDefault(); items[(idx - 1 + items.length) % items.length]?.focus(); }
            if (e.key === 'Escape')    { tbClose(); (tbBtn as HTMLElement).focus(); }
          });
        }
      });
    </script>

    <!-- Boîte aux lettres morte : bouton flottant + modale (contribution anonyme) -->
    <DeadDrop />

    <!-- Barre d'édition admin : ne rend RIEN pour un visiteur public (cf. AdminBar.astro) -->
    <AdminBar />

    <!-- Service Worker, précache URGENCE + DÉCISION pour usage offline terrain -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch((err) => {
            console.warn('[SW] Enregistrement échoué :', err);
          });
        });
      }
    </script>

    <!-- Reveal au scroll : revele les .reveal une seule fois, puis cesse d'observer.
         Inerte si reduce-motion ou si IntersectionObserver absent (tout reste visible). -->
    <script>
      (function revealOnScroll() {
        const els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver((entries, obs) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
      })();
    </script>
