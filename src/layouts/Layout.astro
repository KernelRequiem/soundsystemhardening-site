      /* Footer : empilage propre sur mobile (evite les retours a la ligne moches) */
      @media (max-width: 600px) {
        .ssh-footer-brand {
          flex-direction: column;
          align-items: flex-start;
          gap: 12px;
        }
        .ssh-footer-tag { font-size: 10px; line-height: 1.5; }
        .ssh-footer-bottom { flex-direction: column; align-items: flex-start; gap: 14px; }
      }
    </style>
  </head>
  <body>

    <!-- Sans JavaScript, on neutralise le reveal pour que le contenu reste visible -->
    <noscript><style>.reveal{opacity:1 !important;transform:none !important;}</style></noscript>

    <div id="progress-bar" class="fixed top-0 right-0 w-[2px] z-[9999] pointer-events-none" style="height: 0%; background: linear-gradient(180deg, #00ff9f, #00d9ff); box-shadow: 0 0 8px #00ff9f;"></div>
    <button id="menu-toggle" class="md:hidden fixed top-1.5 left-1.5 z-50 flex items-center justify-center w-9 h-9 rounded-md bg-dedsec-darker/90 border border-dedsec-border text-dedsec-text hover:text-neon-green hover:border-neon-green/50 active:scale-95 backdrop-blur-sm transition-all" aria-label="Ouvrir le menu" aria-controls="sidebar" aria-expanded="false">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7"/>
        <line x1="4" y1="12" x2="20" y2="12"/>
        <line x1="4" y1="17" x2="20" y2="17"/>
      </svg>
    </button>
    <div class="flex min-h-screen">
      <!-- MENU MOBILE : sidebar uniquement sur mobile (desktop = topbar pleine largeur).
           Epure : marque, recherche, nav essentielle, urgence. -->
      <aside id="sidebar" class="md:hidden fixed top-0 left-0 h-screen w-[82%] max-w-[320px] bg-dedsec-darker border-r border-dedsec-border overflow-y-auto transition-transform duration-300 ease-out z-50 -translate-x-full flex flex-col">

        <!-- En-tete : marque + fermeture -->
