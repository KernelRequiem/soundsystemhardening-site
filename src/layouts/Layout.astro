            <!-- Zone OUTILS : ancrée à droite -->
            <div class="shrink-0 flex items-end pr-2 md:pr-3">
              <!-- Lien OUTILS → /tools  (dropdown au hover, géré par JS ci-dessous) -->
              {(() => {
                const toolPaths = ['/soundcheck', '/copwatch', '/opsec-tools', '/timeseal', '/compliance-shield', '/infocrypt', '/stripmeta'];
                const isActive = currentPath === '/tools' || toolPaths.includes(currentPath);
                return (
                  <a
                    id="tb-tools-btn"
                    href="/tools"
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-controls="tb-tools-menu"
                    class={`tb-tab shrink-0 flex items-center gap-2 px-4 py-2.5 font-mono text-[11px] tracking-widest transition-all no-underline border-b-2 ${
                      isActive
                        ? 'text-neon-green border-neon-green bg-neon-green/10'
