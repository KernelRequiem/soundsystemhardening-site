                <span class="inline-block" style="width:6px; height:6px; border-radius:50%; background:#00ff9f; box-shadow:0 0 6px #00ff9f; flex-shrink:0;"></span>
                <span class="font-mono text-[10px] tracking-[0.18em] text-dedsec-muted/60 uppercase">SECURE</span>
