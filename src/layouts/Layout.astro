            <!-- Zone outils principale : calee a gauche. /map a son acces dedie "CARTE" ligne 1. -->
            <div class="flex items-end overflow-x-auto scrollbar-none min-w-0 pl-2 md:pl-3 md:pr-4">
              {[
                { href: '/urgence',     label: 'URGENCE',  icon: 'urgence',  critical: true  },
                { href: '/wiki',        label: 'WIKI',     icon: 'wiki',     critical: false },
                { href: '/wiki/ripost', label: 'RIPOST',   icon: 'ripost',   critical: false },
                { href: '/decision',    label: 'DÉCISION', icon: 'decision', critical: false },
              ].map(tool => (
                <a
                  href={tool.href}
                  aria-current={currentPath === tool.href ? 'page' : undefined}
                  class={`tb-tab shrink-0 flex items-center gap-2 px-4 py-2.5 font-mono text-[11px] tracking-widest transition-all no-underline border-b-2 ${
                    currentPath === tool.href
                      ? tool.critical
                        ? 'text-neon-red border-neon-red bg-neon-red/10'
                        : 'text-neon-green border-neon-green bg-neon-green/10'
                      : tool.critical
                        ? 'text-neon-red/70 border-transparent hover:text-neon-red hover:border-neon-red/60 hover:bg-neon-red/5'
                        : 'text-dedsec-muted hover:text-neon-green hover:border-neon-green/50 hover:bg-neon-green/5 border-transparent'
