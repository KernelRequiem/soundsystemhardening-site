                <span class="hidden lg:inline font-mono text-[10px] tracking-widest">CARTE</span>
              </a>
              <a href="/search" class="hidden md:flex items-center gap-2 self-stretch px-4 font-mono text-[10px] tracking-widest text-dedsec-muted/60 hover:text-neon-green hover:bg-neon-green/5 transition-all no-underline border-l border-dedsec-border" aria-label="Rechercher">
                <span class="text-base leading-none">⌕</span>
                <span class="hidden lg:inline">RECHERCHER</span>
              </a>
              <!-- Purger mes traces (desktop) : efface le stockage local du site -->
              <button type="button" data-purge
                class="hidden md:flex items-center gap-2 self-stretch px-3 font-mono text-[10px] tracking-widest text-dedsec-muted/60 hover:text-neon-green hover:bg-neon-green/5 transition-all border-l border-dedsec-border"
