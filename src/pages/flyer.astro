---
// src/pages/flyer.astro
// Section "Flyers imprimables" : 2 themes (sombre neon / clair encre) x 3 formats (A6/A5/A4).
// PDF print-ready full-bleed dans /public/flyers/. Le QR pointe vers le site (decouverte),
// le contact passe par le formulaire web (/contact).
import Layout from '../layouts/Layout.astro';

const themes = [
  {
    id: 'sombre',
    nom: 'Thème sombre',
    desc: "Fond noir, accents vert néon, logo qui glow. Identique à l'identité du site. Impact maximal, idéal en impression couleur ou affichage écran.",
    preview: '/flyers/preview-sombre.png',
    note: "Couvre la page de noir : prévoir une imprimante qui n'ignore pas les fonds.",
  },
  {
    id: 'clair',
    nom: 'Thème clair',
    desc: 'Fond blanc, logo noir, accents vert ponctuels. Économe en encre, parfait pour la distribution en volume et la photocopie.',
    preview: '/flyers/preview-clair.png',
    note: "Lisible partout, coût d'impression réduit.",
  },
];

const formats = [
  { code: 'A6', dim: '10,5 × 14,8 cm', usage: 'Carte à distribuer en main' },
  { code: 'A5', dim: '14,8 × 21 cm', usage: 'Demi-page, meilleur compromis' },
  { code: 'A4', dim: '21 × 29,7 cm', usage: 'Affiche à coller en lieu de passage' },
];
---

<Layout
  title="Flyers imprimables"
  category="DIFFUSION"
  description="Flyers imprimables prêts à l'emploi : 2 thèmes (sombre néon, clair encre) en A6, A5 et A4. QR vers le wiki, accroche, URL. À distribuer en rassemblement, meetup, événement terrain."
>

  <h1>Flyers imprimables</h1>
  <p class="text-dedsec-muted text-sm font-mono tracking-widest uppercase mb-6">
    ▸ 2 thèmes · A6 / A5 / A4 · PDF prêt à imprimer
  </p>

  <div class="info-box mb-8">
    Chaque flyer reprend l'identité du site : logo, wordmark, palette néon. Le QR mène au wiki,
    le contact se fait par le formulaire. Deux thèmes au choix, trois formats chacun.
    <strong>Gratuit, libre, sans pub, sans tracker.</strong>
  </div>

  <div class="flyer-grid">
    {themes.map((t) => (
      <section class="flyer-block">
        <div class="flyer-preview-wrap">
          <img src={t.preview} alt={`Aperçu du flyer SoundSystem Hardening, ${t.nom}`} loading="lazy" class="flyer-preview no-border" />
        </div>

        <div class="flyer-meta">
          <h2 class="flyer-h2">{t.nom}</h2>
          <p class="flyer-desc">{t.desc}</p>

          <div class="flyer-formats">
            {formats.map((f) => (
              <a href={`/flyers/flyer-ssh-${t.id}-${f.code}.pdf`} download class="btn-neon flyer-fmt">
                <span class="fmt-code">⬇ {f.code}</span>
                <span class="fmt-dim">{f.dim}</span>
                <span class="fmt-usage">{f.usage}</span>
              </a>
            ))}
          </div>

          <p class="flyer-note">{t.note}</p>
        </div>
      </section>
    ))}
  </div>

  <div class="flex flex-wrap gap-3 mt-10">
    <a href="/flyer-qr.png" download class="btn-neon" style="border-color:rgba(122,122,138,0.4);color:#7a7a8a;">⬇ QR seul (PNG)</a>
    <a href="/presse" class="btn-neon" style="border-color:rgba(122,122,138,0.4);color:#7a7a8a;">→ Dossier de presse</a>
  </div>

</Layout>

<style>
  .flyer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 880px) {
    .flyer-grid { grid-template-columns: 1fr 1fr; }
  }

  .flyer-block {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .flyer-preview-wrap {
    border: 1px solid var(--color-border);
    background: #0a0a0f;
    padding: 0;
    overflow: hidden;
  }
  .flyer-preview {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
  }

  .flyer-h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .flyer-desc {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0 0 1.1rem;
  }

  .flyer-formats {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .flyer-fmt {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 0.9rem;
    align-items: baseline;
    text-align: left;
    padding: 0.7rem 0.95rem;
  }
  .fmt-code {
    grid-row: 1 / 3;
    align-self: center;
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.05em;
  }
  .fmt-dim {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--color-text);
  }
  .fmt-usage {
    grid-column: 2;
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .flyer-note {
    margin: 0.9rem 0 0;
    font-size: 0.72rem;
    line-height: 1.45;
    color: var(--color-muted);
    border-left: 2px solid var(--color-border);
    padding-left: 0.7rem;
  }
</style>
