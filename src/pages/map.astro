---
import Layout from '../layouts/Layout.astro';
import incidents from '../data/incidents.json';

const TYPES = {
  charge:       { label: 'Charge / intervention', color: '#ff4444' },
  blessure:     { label: 'Blessure / mutilation',  color: '#ff8a00' },
  saisie:       { label: 'Saisie de matériel',     color: '#a855f7' },
  gav:          { label: 'GAV / interpellation',   color: '#ffd400' },
  interdiction: { label: 'Interdiction préfect.',  color: '#00d9ff' },
  autre:        { label: 'Autre',                  color: '#00ff9f' },
};

const DEPT_NAMES: Record<string, string> = {
  '05':'Hautes-Alpes','11':'Aude','18':'Cher','22':'Côtes-d\'Armor',
  '24':'Dordogne','27':'Eure','29':'Finistère','30':'Gard',
  '34':'Hérault','35':'Ille-et-Vilaine','36':'Indre','42':'Loire',
  '44':'Loire-Atlantique','46':'Lot','48':'Lozère','51':'Marne',
  '53':'Mayenne','56':'Morbihan','57':'Moselle','69':'Rhône',
  '70':'Haute-Saône','71':'Saône-et-Loire','72':'Sarthe','75':'Paris',
  '76':'Seine-Maritime','85':'Vendée','86':'Vienne',
};

// Date de dernière mise à jour des données (à actualiser à chaque ajout d'incident)
const lastUpdate = '2026-06-13';
const lastUpdateFR = lastUpdate
  ? new Date(lastUpdate).toLocaleDateString('fr-FR', { day:'numeric', month:'long', year:'numeric' })
  : '-';
const totalIncidents = incidents.length;
const nonce = Astro.locals.cspNonce;
---

<Layout title="MAP" category="OUTILS">
  <link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />

  <!-- ═══════════════════════════════════════════════════════════════
       CONTENEUR PRINCIPAL
  ═══════════════════════════════════════════════════════════════ -->
  <div class="map-wrap" id="mapWrap">

    <!-- Toggle sidebar -->
    <button id="sidebarToggle" class="sidebar-toggle">◀</button>

    <!-- ─── SIDEBAR ──────────────────────────────────────────── -->
    <aside class="map-aside" id="mapSidebar">

      <!-- INCIDENTS sidebar -->
      <div class="aside-panel" id="panelIncidents">
        <div class="aside-inner">
          <div>
            <h1 class="map-h1">CARTE DE LA RÉPRESSION</h1>
            <div class="map-sub">▸ INDEX TERRITORIAL // 1996-2026</div>
          </div>
          <div class="stats-block">
            <div class="stat-item">
              <span class="stat-label">AFFICHÉS</span>
              <b class="stat-val"><span id="incCount">00</span><span class="stat-total">/{totalIncidents}</span></b>
            </div>
            <div class="stat-item">
              <span class="stat-label">DERNIÈRE MAJ</span>
              <b class="stat-date">{lastUpdateFR}</b>
            </div>
          </div>
          <div>
            <div class="block-title">▸ Type</div>
            <div id="incFilters" class="filters"></div>
          </div>
          <div>
            <div class="block-title">▸ Période</div>
            <select id="incYear"><option value="all">Toutes les années</option></select>
          </div>
          <div>
            <div class="block-title">▸ Département</div>
            <select id="incDept"><option value="all">Tous les départements</option></select>
          </div>
          <button class="reset-btn" id="incReset">↺ Réinitialiser</button>
          <button class="contrib-btn" id="openModal">+ SIGNALER UN CAS</button>
          <p class="aside-note">Aucune donnée nominative. Chaque cas sourcé et vérifié.</p>
        </div>
      </div>

      <!-- TERRAIN sidebar -->
      <div class="aside-panel" id="panelTerrain" style="display:none">
        <div class="aside-inner">
          <div>
            <h1 class="map-h1">ÉVALUATEUR DE TERRAIN</h1>
            <div class="map-sub">▸ ANALYSE OSM · ATOUTS & RISQUES</div>
          </div>

          <div class="ter-warn">
            <strong>⚠ OPSEC</strong>
            <p>Coordonnée arrondie ~1 km envoyée à <b>OpenStreetMap</b>. Utilise <b>Tor</b> si zone sensible. Validation finale = reconnaissance physique hors réseau.</p>
          </div>

          <!-- Saisie coordonnées -->
          <div>
            <div class="block-title">▸ Saisir coordonnées GPS</div>
            <div class="coord-row">
              <input id="terLat" type="text" class="coord-input" placeholder="Lat · ex: 48.856" />
              <input id="terLng" type="text" class="coord-input" placeholder="Lng · ex: 2.352" />
            </div>
            <button id="terGo" class="go-btn">⊕ POSITIONNER</button>
            <p id="terCoordError" class="ter-err" style="display:none;margin-top:4px"></p>
          </div>

          <div class="coord-or">── ou clic direct sur la carte ──</div>

          <!-- Rayon -->
          <div>
            <div class="block-title">▸ Rayon d'analyse</div>
            <select id="terRayon">
              <option value="500">500 m</option>
              <option value="1000" selected>1 km</option>
              <option value="1500">1,5 km</option>
              <option value="2000">2 km</option>
              <option value="3000">3 km</option>
            </select>
          </div>

          <!-- Zone active -->
          <div>
            <div class="block-title">▸ Point sélectionné</div>
            <div id="terCoord" class="ter-coord">Cliquez sur la carte ou saisissez des coordonnées</div>
          </div>

          <button id="terAnalyze" class="analyze-btn" disabled>ANALYSER CETTE ZONE</button>

          <div id="terStatus" class="ter-status" style="display:none">
            <div class="ter-spinner"></div>
            <span id="terStatusMsg">Interrogation Overpass...</span>
          </div>
          <p id="terError" class="ter-err" style="display:none"></p>

          <!-- Rapport -->
          <div id="terReport" class="ter-report" style="display:none">

            <div class="score-wrap">
              <div>
                <div class="score-label">RISQUE GLOBAL</div>
                <span id="terScore" class="score-val">-</span>
              </div>
              <div id="terScoreBar" class="score-bar-wrap">
                <div id="terScoreFill" class="score-bar-fill"></div>
              </div>
            </div>

            <!-- Atouts -->
            <div class="ter-section">
              <div class="ter-sec-title ter-sec-ok">▸ ATOUTS</div>
              <ul id="terAvantages" class="facteurs facteurs-ok"></ul>
              <div id="terNoAtout" class="ter-empty" style="display:none">Aucun atout identifié</div>
            </div>

            <!-- Risques -->
            <div class="ter-section">
              <div class="ter-sec-title ter-sec-risk">▸ RISQUES</div>
              <ul id="terInconvenients" class="facteurs facteurs-risk"></ul>
              <div id="terNoRisque" class="ter-empty" style="display:none">Aucun risque identifié</div>
            </div>

            <!-- Données brutes -->
            <div class="ter-section">
              <div class="ter-sec-title">▸ DONNÉES BRUTES</div>
              <div id="terMeta" class="ter-meta"></div>
            </div>

            <p id="terPrecision" class="ter-note"></p>
          </div>
        </div>
      </div>

    </aside>

    <!-- ─── CARTE ─────────────────────────────────────────────── -->
    <main class="map-main">
      <div class="map-topbar">
        <span id="topbarMode" class="topbar-mode">● INCIDENTS</span>
        <span id="topbarInfo" class="topbar-info"></span>
        <button id="guideToggle" class="map-guide-btn" aria-expanded="false" aria-controls="guideModal">
          <span id="guideArrow">▸</span> GUIDE
        </button>
        <span class="topbar-right">CC BY-SA · OSM</span>
      </div>

      <div id="leafletMap"></div>

      <!-- Bouton flottant switch de mode -->
      <button id="modeSwitch" class="mode-switch">
        <span id="modeSwitchIcon">◎</span>
        <span id="modeSwitchLabel">ÉVALUER TERRAIN</span>
      </button>
    </main>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════
       MODAL SIGNALEMENT
  ═══════════════════════════════════════════════════════════════ -->
  <div id="reportModal" class="modal-overlay" aria-hidden="true">
    <div class="modal-box" role="dialog">
      <div class="modal-header">
        <span>▸ SIGNALER UN CAS</span>
        <button id="closeModal" class="modal-close">✕</button>
      </div>
      <div id="modalForm">
        <p class="modal-note">Statut <b>En attente</b>. Modérateur vérifie avant publication.</p>
        <div class="field"><label>Lieu <span class="req">*</span></label><input id="f-lieu" type="text" placeholder="ex: Redon (35)" /></div>
        <div class="field"><label>Date <span class="req">*</span></label><input id="f-date" type="date" /></div>
        <div class="field"><label>Type <span class="req">*</span></label>
          <select id="f-type">
            <option value="">-- choisir --</option>
            <option>Charge / intervention</option><option>Blessure / mutilation</option>
            <option>Saisie de matériel</option><option>GAV / interpellation</option>
            <option>Interdiction préfectorale</option><option>Autre</option>
          </select>
        </div>
        <div class="field"><label>Description <span class="req">*</span></label><textarea id="f-desc" rows="3" placeholder="Résumé factuel, sans donnée nominative"></textarea></div>
        <div class="field"><label>Bilan</label><input id="f-bilan" type="text" placeholder="ex: 2 GAV, matériel saisi" /></div>
        <div class="field"><label>Source (URL)</label><input id="f-source" type="url" placeholder="https://..." /></div>
        <button id="submitReport" class="submit-btn">ENVOYER LE SIGNALEMENT</button>
        <p id="formError" class="form-error" style="display:none"></p>
      </div>
      <div id="modalSuccess" style="display:none" class="modal-success">
        <div class="success-icon">✔</div>
        <p>Signalement reçu.</p>
        <p class="success-sub">Un modérateur valide avant publication.</p>
        <button id="closeSuccess" class="submit-btn" style="margin-top:16px">FERMER</button>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════
       MODALE GUIDE (fixed, par-dessus la carte)
  ═══════════════════════════════════════════════════════════════ -->
  <div id="guideModal" class="mg-overlay mg-hidden" role="dialog" aria-modal="true" aria-labelledby="guideModalTitle">
    <div class="mg-box">

      <div class="mg-header">
        <div>
          <span class="mg-eyebrow">GUIDE D'UTILISATION</span>
          <h2 id="guideModalTitle" class="mg-title">Carte &amp; Terrain</h2>
        </div>
        <button id="guideClose" class="mg-close" aria-label="Fermer">✕</button>
      </div>

      <div class="mg-tabs">
        <button class="mg-tab mg-tab-active" data-tab="incidents">⊞ INCIDENTS</button>
        <button class="mg-tab" data-tab="terrain">◎ TERRAIN</button>
      </div>

      <div class="mg-panel" id="mgPanelIncidents">
        <div class="mg-cols">
          <div class="mg-col">
            <div class="mg-section-title">CE QUE C'EST</div>
            <p class="mg-text">Index territorial de <strong>{totalIncidents} incidents répressifs</strong> documentés en France depuis 1996 : charges, GAV, saisies de matériel, blessures, interdictions préfectorales. Chaque cas sourcé et vérifié.</p>
            <div class="mg-section-title" style="margin-top:16px">UTILITÉ</div>
            <p class="mg-text">Identifier zones et périodes à risque historique. Documenter les patterns répressifs pour appuyer des recours juridiques.</p>
          </div>
          <div class="mg-col">
            <div class="mg-section-title">COMMENT L'UTILISER</div>
            <ul class="mg-list">
              <li><span class="mg-bullet">▸</span>Filtre par <strong>type d'incident</strong> via les cases à cocher</li>
              <li><span class="mg-bullet">▸</span>Filtre par <strong>année</strong> ou <strong>département</strong></li>
              <li><span class="mg-bullet">▸</span>Clique sur un <strong>marqueur</strong> pour les détails et la source</li>
              <li><span class="mg-bullet">▸</span><strong>+ SIGNALER UN CAS</strong> pour contribuer (modéré avant publication)</li>
            </ul>
            <div class="mg-opsec">
              <span class="mg-opsec-icon">⊗</span>
              <span>Aucune donnée nominative collectée. Carte 100% côté client.</span>
            </div>
          </div>
        </div>
      </div>

      <div class="mg-panel mg-hidden" id="mgPanelTerrain">
        <div class="mg-cols">
          <div class="mg-col">
            <div class="mg-section-title">CE QUE C'EST</div>
            <p class="mg-text">Évaluateur de zone via <strong>OpenStreetMap</strong> : analyse atouts et risques d'un point GPS dans un rayon défini (500m-3km). Accès routiers, gendarmeries, couvert végétal…</p>
            <div class="mg-section-title" style="margin-top:16px">UTILITÉ</div>
            <p class="mg-text">Pré-qualifier un site à distance avant déplacement. Identifier failles opérationnelles et atouts tactiques (isolement, accès multiples).</p>
          </div>
          <div class="mg-col">
            <div class="mg-section-title">COMMENT L'UTILISER</div>
            <ul class="mg-list">
              <li><span class="mg-bullet">▸</span>Saisis les <strong>coordonnées GPS</strong> ou clique directement sur la carte</li>
              <li><span class="mg-bullet">▸</span>Sélectionne un <strong>rayon d'analyse</strong> (1 km par défaut)</li>
              <li><span class="mg-bullet">▸</span>Lance l'analyse : rapport avec <strong>score de risque global</strong> + facteurs</li>
              <li><span class="mg-bullet">▸</span>Validation finale = <strong>reconnaissance physique</strong> hors réseau</li>
            </ul>
            <div class="mg-warn">
              <strong>⚠ OPSEC</strong> : Coordonnée arrondie ~1 km envoyée à Overpass. Aucun log. Utilise <strong>Tor Browser</strong> si la zone est sensible.
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════
       SCRIPTS
  ═══════════════════════════════════════════════════════════════ -->
  <script src="/vendor/leaflet/leaflet.js" is:inline></script>

  <script nonce={nonce} define:vars={{ INCIDENTS: incidents, TYPES, DEPT_NAMES, TOTAL: totalIncidents }}>
  (function () {

    // ── Constantes ──────────────────────────────────────────────────────────
    var OVERPASS_ENDPOINTS = [
      'https://overpass-api.de/api/interpreter',
      'https://overpass.kumi.systems/api/interpreter',
    ];
    var SCORE_COLORS = { faible: '#00ff9f', modéré: '#60a5fa', élevé: '#ff8a00', critique: '#ff4444' };

    // ── État global ─────────────────────────────────────────────────────────
    var mode = 'incidents'; // 'incidents' | 'terrain'
    var sidebarOpen = true;

    // incidents state
    var activeTypes = new Set(Object.keys(TYPES));
    var yearFilter = 'all';
    var deptFilter = 'all';
    var incLayer;

    // terrain state
    var terMarker = null, terCircle = null;
    var rLat = null, rLng = null;

    // ── Carte Leaflet ───────────────────────────────────────────────────────
    var map = L.map('leafletMap', { zoomControl: true }).setView([46.6, 2.4], 6);
    window._map = map;
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19, subdomains: 'abcd',
    }).addTo(map);
    incLayer = L.layerGroup().addTo(map);

    document.head.insertAdjacentHTML('beforeend',
      '<style>@keyframes mpulse{0%{transform:scale(1);opacity:1}50%{transform:scale(1.5);opacity:.5}100%{transform:scale(1);opacity:1}}</style>'
    );

    // ── Sidebar toggle ──────────────────────────────────────────────────────
    document.getElementById('sidebarToggle').addEventListener('click', function () {
      sidebarOpen = !sidebarOpen;
      document.getElementById('mapSidebar').classList.toggle('collapsed', !sidebarOpen);
      document.getElementById('mapWrap').classList.toggle('collapsed', !sidebarOpen);
      this.textContent = sidebarOpen ? '◀' : '▶';
      setTimeout(function () { map.invalidateSize(); }, 320);
    });

    // ── Switch de mode ──────────────────────────────────────────────────────
    document.getElementById('modeSwitch').addEventListener('click', function () {
      setMode(mode === 'incidents' ? 'terrain' : 'incidents');
    });

    function setMode(newMode) {
      mode = newMode;
      var isIncidents = mode === 'incidents';

      document.getElementById('panelIncidents').style.display = isIncidents ? '' : 'none';
      document.getElementById('panelTerrain').style.display   = isIncidents ? 'none' : '';

      document.getElementById('modeSwitchIcon').textContent  = isIncidents ? '◎' : '⊞';
      document.getElementById('modeSwitchLabel').textContent = isIncidents ? 'ÉVALUER TERRAIN' : 'INCIDENTS';
      document.getElementById('topbarMode').textContent = isIncidents ? '● INCIDENTS' : '● TERRAIN';

      if (isIncidents) {
        // Repasser en mode incidents : nettoyer terrain, afficher incidents
        if (terMarker) { map.removeLayer(terMarker); terMarker = null; }
        if (terCircle) { map.removeLayer(terCircle); terCircle = null; }
        rLat = rLng = null;
        document.getElementById('terCoord').textContent = 'Cliquez sur la carte pour poser un point';
        document.getElementById('terAnalyze').disabled = true;
        document.getElementById('terReport').style.display = 'none';
        document.getElementById('terError').style.display = 'none';
        incLayer.addTo(map);
        renderIncidents();
      } else {
        // Passer en mode terrain : masquer incidents
        incLayer.clearLayers();
        map.removeLayer(incLayer);
        updateTopbarInfo('');
      }

      map.invalidateSize();
    }

    // ════════════════════════════════════════════════════════════════════════
    // MODE INCIDENTS
    // ════════════════════════════════════════════════════════════════════════

    function dotIcon(color) {
      return L.divIcon({
        className: '',
        iconSize: [14, 14], iconAnchor: [7, 7],
        html: '<div style="width:12px;height:12px;border-radius:50%;background:' + color + ';box-shadow:0 0 8px ' + color + ';border:1px solid #05060a;animation:mpulse 2s infinite"></div>',
      });
    }

    function popupHTML(i) {
      var t = TYPES[i.type] || TYPES.autre;
      var d = new Date(i.date).toLocaleDateString('fr-FR', { day:'numeric', month:'long', year:'numeric' });
      var cout = '';
      if (i.cout_eur) {
        cout = i.cout_eur >= 1000000
          ? '~' + (i.cout_eur/1000000).toFixed(2).replace('.', ',') + ' M€'
          : '~' + Math.round(i.cout_eur/1000) + ' k€';
      } else if (i.effectifs) {
        cout = i.effectifs + ' agents';
      }
      return '<div class="pop-wrap">' +
        '<div class="pop-header"><span class="pop-type" style="background:' + t.color + '">' + t.label.toUpperCase() + '</span>' +
        (i.statut_juridique ? '<span class="pop-statut">' + i.statut_juridique.toUpperCase() + '</span>' : '') + '</div>' +
        '<div class="pop-title">' + i.titre + '</div>' +
        '<div class="pop-meta">' + i.lieu + ' · ' + d + (i.departement ? ' · Dép. ' + i.departement : '') + '</div>' +
        (i.desc ? '<div class="pop-desc">' + i.desc + '</div>' : '') +
        '<div class="pop-data">' +
        (i.bilan ? '<div class="pop-row pop-bilan"><span class="pop-lbl">BILAN</span><span>' + i.bilan + '</span></div>' : '') +
        (cout    ? '<div class="pop-row pop-cout"><span class="pop-lbl">COÛT EST.</span><span>' + cout + '</span></div>' : '') +
        '</div>' +
        '<div class="pop-actions"><div class="pop-links">' +
        (i.source ? '<a href="' + i.source + '" target="_blank" rel="noopener">↗ SOURCE</a>' : '') +
        (i.wiki   ? '<a href="' + i.wiki   + '">↗ WIKI</a>' : '') +
        '</div><button class="pop-briefing" onclick="openBriefing(\'' + i.id + '\')">⊕ BRIEFING</button></div>' +
        '</div>';
    }

    function renderIncidents() {
      incLayer.clearLayers();
      var n = 0;
      INCIDENTS.forEach(function (i) {
        if (!activeTypes.has(i.type)) return;
        if (yearFilter !== 'all' && String(i.date).slice(0,4) !== yearFilter) return;
        if (deptFilter !== 'all' && i.departement !== deptFilter) return;
        L.marker([i.lat, i.lng], { icon: dotIcon((TYPES[i.type]||TYPES.autre).color) })
          .bindPopup(popupHTML(i), { maxWidth: 300, className: 'pop-custom' })
          .addTo(incLayer);
        n++;
      });
      document.getElementById('incCount').textContent = String(n).padStart(2,'0');
      updateTopbarInfo(n < TOTAL ? n + ' / ' + TOTAL + ' incidents affichés' : TOTAL + ' incidents indexés');
    }

    function updateTopbarInfo(txt) {
      document.getElementById('topbarInfo').textContent = txt;
    }

    // Filtres type
    var fbox = document.getElementById('incFilters');
    Object.entries(TYPES).forEach(function (entry) {
      var key = entry[0], t = entry[1];
      var count = INCIDENTS.filter(function (i) { return i.type === key; }).length;
      if (count === 0) return;
      var b = document.createElement('button');
      b.className = 'chip on';
      b.innerHTML = '<span class="dot" style="background:' + t.color + '"></span>' + t.label + '<span class="ct">' + count + '</span>';
      b.addEventListener('click', function () {
        activeTypes.has(key) ? activeTypes.delete(key) : activeTypes.add(key);
        b.classList.toggle('on', activeTypes.has(key));
        renderIncidents();
      });
      fbox.appendChild(b);
    });

    // Filtre année
    var years = [...new Set(INCIDENTS.map(function (i) { return String(i.date).slice(0,4); }))].sort().reverse();
    var ySel = document.getElementById('incYear');
    years.forEach(function (y) { var o = document.createElement('option'); o.value = y; o.textContent = y; ySel.appendChild(o); });
    ySel.addEventListener('change', function () { yearFilter = ySel.value; renderIncidents(); });

    // Filtre département
    var depts = [...new Set(INCIDENTS.map(function (i) { return i.departement; }).filter(Boolean))].sort(function (a,b) { return Number(a)-Number(b); });
    var dSel = document.getElementById('incDept');
    depts.forEach(function (dep) {
      var o = document.createElement('option');
      o.value = dep;
      o.textContent = dep + ' - ' + (DEPT_NAMES[dep]||dep);
      dSel.appendChild(o);
    });
    dSel.addEventListener('change', function () { deptFilter = dSel.value; renderIncidents(); });

    // Reset
    document.getElementById('incReset').addEventListener('click', function () {
      Object.keys(TYPES).forEach(function (k) { activeTypes.add(k); });
      document.querySelectorAll('.chip').forEach(function (b) { b.classList.add('on'); });
      ySel.value = 'all'; yearFilter = 'all';
      dSel.value = 'all'; deptFilter = 'all';
      renderIncidents();
    });

    renderIncidents();

    // Briefing
    var _reg = {};
    INCIDENTS.forEach(function (i) { _reg[i.id] = i; });

    window.openBriefing = function (id) {
      var i = _reg[id]; if (!i) return;
      var win = window.open('', '_blank');
      if (!win) { alert('Autorisez les popups.'); return; }
      var d = new Date(i.date).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});
      var t = TYPES[i.type]||TYPES.autre;
      var css = '*{margin:0;padding:0;box-sizing:border-box}body{font-family:Georgia,serif;color:#111;max-width:740px;margin:0 auto;padding:40px;line-height:1.6;font-size:13px}.pb{margin-bottom:24px;padding:9px 20px;background:#111;color:#fff;border:none;cursor:pointer;font-family:monospace;font-size:11px;letter-spacing:1px}.br{font-family:monospace;font-size:9px;color:#999;letter-spacing:1px;margin-bottom:6px}.dt{font-size:22px;font-weight:bold;border-bottom:2px solid #111;padding-bottom:10px;margin-bottom:6px}.ds{font-family:monospace;font-size:9px;color:#999;margin-bottom:28px}h2{font-family:monospace;font-size:9px;letter-spacing:2px;color:#666;text-transform:uppercase;border-bottom:1px solid #ddd;padding-bottom:3px;margin:28px 0 12px}p{margin-bottom:8px}.dr{display:flex;gap:12px;margin-bottom:6px;font-size:12px}.dl{font-family:monospace;color:#888;width:140px;flex-shrink:0;font-size:11px}.hl{background:#f5f5f5;border-left:3px solid #111;padding:10px 14px;margin:12px 0;font-size:12px}.ft{margin-top:40px;padding-top:16px;border-top:1px solid #ddd;font-size:10px;color:#aaa}a{color:#1a56db}@media print{.pb{display:none}body{padding:0}@page{margin:2cm}}';
      var row = function(l,v){return v?'<div class="dr"><span class="dl">'+l+'</span><span>'+String(v).replace(/</g,'&lt;')+'</span></div>':'';};
      win.document.write('<!DOCTYPE html><html lang="fr"><head><meta charset="utf-8"><title>Briefing - '+i.titre+'</title><style>'+css+'</style></head><body>'+
        '<button class="pb" onclick="window.print()">↓ IMPRIMER / PDF</button>'+
        '<div class="br">SOUNDSYSTEMHARDENING.FR // BRIEFING</div>'+
        '<div class="dt">'+i.titre+'</div>'+
        '<div class="ds">Généré le '+new Date().toLocaleDateString('fr-FR')+' - CC BY-SA 4.0</div>'+
        '<h2>01 - Identification</h2>'+row('Lieu',i.lieu)+row('Date',d)+row('Type',t.label)+row('Département',i.departement)+row('Préfecture',i.prefecture)+
        '<h2>02 - Description</h2>'+(i.desc?'<p>'+i.desc+'</p>':'')+(i.bilan?'<div class="hl">Bilan : <strong>'+i.bilan+'</strong></div>':'')+
        '<h2>03 - Moyens</h2>'+row('Effectifs',i.effectifs?i.effectifs+' agents':null)+row('Unités',i.unites)+row('Durée',i.duree_h?i.duree_h+'h':null)+
        '<h2>04 - Cadre juridique</h2>'+row('Statut',i.statut_juridique)+row('Recours',i.recours)+
        (i.failles?'<h2>05 - Failles</h2><p>'+i.failles+'</p>':'')+
        (i.contre_mesures?'<h2>06 - Contre-mesures</h2><p>'+i.contre_mesures+'</p>':'')+
        '<div class="ft">SoundSystemHardening.fr - CC BY-SA 4.0 - Document informatif, non contractuel.</div>'+
        '</body></html>');
      win.document.close();
    };

    // ════════════════════════════════════════════════════════════════════════
    // MODE TERRAIN
    // ════════════════════════════════════════════════════════════════════════

    var round2    = function (n) { return Math.round(n * 100) / 100; };
    var roundDist = function (m) { return Math.round(m / 50) * 50; };

    function placePin(lat, lng) {
      if (mode !== 'terrain') return;
      rLat = round2(lat); rLng = round2(lng);
      if (terMarker) map.removeLayer(terMarker);
      if (terCircle) map.removeLayer(terCircle);
      terMarker = L.circleMarker([rLat, rLng], { radius:6, color:'#00ff9f', fillColor:'#00ff9f', fillOpacity:1, weight:1 }).addTo(map);
      terCircle = L.circle([rLat, rLng], { radius: parseInt(document.getElementById('terRayon').value,10), color:'#00ff9f', fillColor:'#00ff9f', fillOpacity:0.06, weight:1, dashArray:'4 4' }).addTo(map);
      document.getElementById('terCoord').innerHTML = 'Zone analysée :<br><b>'+rLat.toFixed(2)+', '+rLng.toFixed(2)+'</b><br><span style="font-size:8px;color:#7a7a8a">Clic précis non transmis</span>';
      document.getElementById('terAnalyze').disabled = false;
      document.getElementById('terReport').style.display = 'none';
      document.getElementById('terError').style.display = 'none';
    }

    map.on('click', function (e) { if (mode === 'terrain') placePin(e.latlng.lat, e.latlng.lng); });
    document.getElementById('terRayon').addEventListener('change', function () { if (rLat !== null) placePin(rLat, rLng); });

    // ── Saisie coordonnées GPS ──────────────────────────────────
    document.getElementById('terGo').addEventListener('click', function () {
      var rawLat = document.getElementById('terLat').value.replace(',', '.').trim();
      var rawLng = document.getElementById('terLng').value.replace(',', '.').trim();
      var lat = parseFloat(rawLat), lng = parseFloat(rawLng);
      var errEl = document.getElementById('terCoordError');
      if (isNaN(lat)||isNaN(lng)||lat<-90||lat>90||lng<-180||lng>180) {
        errEl.textContent = 'Coordonnées invalides. Format: 48.856 / 2.352';
        errEl.style.display = 'block'; return;
      }
      errEl.style.display = 'none';
      map.setView([lat, lng], 13);
      placePin(lat, lng);
    });
    // Positionner avec Entrée
    ['terLat','terLng'].forEach(function(id) {
      document.getElementById(id).addEventListener('keydown', function(e) {
        if (e.key === 'Enter') document.getElementById('terGo').click();
      });
    });

    function haversine(lat1, lng1, lat2, lng2) {
      var R=6371000, r=function(d){return d*Math.PI/180;};
      var a=Math.sin(r(lat2-lat1)/2)**2+Math.cos(r(lat1))*Math.cos(r(lat2))*Math.sin(r(lng2-lng1)/2)**2;
      return 2*R*Math.asin(Math.sqrt(a));
    }

    function classifyZone(tags) {
      if (!tags) return null;
      var lu=tags.landuse;
      if (lu==='residential') return 'résidentielle';
      if (lu==='military')    return 'militaire';
      if (lu==='industrial')  return 'industrielle';
      if (lu==='commercial'||lu==='retail')   return 'commerciale';
      if (lu==='farmland'||lu==='farmyard')   return 'agricole';
      if (lu==='forest'||tags.natural==='wood') return 'forêt';
      if (tags.natural==='water') return "plan d'eau";
      if (tags.leisure==='nature_reserve'||tags.boundary==='protected_area') return 'zone protégée';
      return null;
    }

    function scoreTerrain(d) {
      var avantages=[], inconvenients=[], niveau=0;

      // ── Habitation ─────────────────────────────────────────────
      if (d.nearestHab===null) {
        avantages.push('Aucune habitation détectée dans le rayon');
      } else if (d.nearestHab<300) {
        niveau=Math.max(niveau,3);
        inconvenients.push('Habitation à ~'+d.nearestHab+' m - intervention quasi certaine');
      } else if (d.nearestHab<600) {
        niveau=Math.max(niveau,2);
        inconvenients.push('Habitation à ~'+d.nearestHab+' m - risque élevé de plainte');
      } else if (d.nearestHab<1000) {
        niveau=Math.max(niveau,1);
        inconvenients.push('Habitation à ~'+d.nearestHab+' m - risque modéré');
      } else {
        avantages.push('Habitation à plus de 1 km - zone tampon suffisante');
      }

      // ── Densité bâti ───────────────────────────────────────────
      if (d.habCount>20) {
        niveau=Math.max(niveau,3);
        inconvenients.push(d.habCount+' bâtiments - secteur très urbanisé');
      } else if (d.habCount>5) {
        niveau=Math.max(niveau,1);
        inconvenients.push(d.habCount+' bâtiments dans le rayon - semi-urbanisé');
      } else if (d.habCount===0) {
        avantages.push('Aucun bâtiment recensé dans le rayon');
      }

      // ── Zones d'usage ──────────────────────────────────────────
      if (d.zones.indexOf('résidentielle')!==-1) { niveau=Math.max(niveau,3); inconvenients.push('Zone résidentielle classifiée - intervention garantie'); }
      if (d.zones.indexOf('militaire')!==-1)     { niveau=Math.max(niveau,1); inconvenients.push('Emprise militaire à proximité - cadre légal restrictif'); }
      if (d.zones.indexOf('industrielle')!==-1||d.zones.indexOf('commerciale')!==-1) {
        avantages.push('Zone industrielle/commerciale - tolérance sonore nocturne plus élevée');
      }
      if (d.zones.indexOf('agricole')!==-1) {
        avantages.push('Terrain agricole - zone typiquement isolée et peu surveillée');
      }
      if (d.zones.indexOf('forêt')!==-1||d.hasForest) {
        avantages.push('Couverture forestière - isolation acoustique naturelle');
      }
      if (d.protegee) { niveau=Math.max(niveau,2); inconvenients.push('Zone naturelle protégée - risque juridique environnemental'); }

      // ── Accès routier ──────────────────────────────────────────
      if (d.nearestRoad!==null) {
        if (d.nearestRoad<200) {
          avantages.push('Accès routier à ~'+d.nearestRoad+' m - logistique convois facilitée');
        } else if (d.nearestRoad>800) {
          avantages.push('Éloigné des routes (~'+d.nearestRoad+' m) - discrétion accrue, piste ou chemin nécessaire');
        }
        if (d.roadTypes.indexOf('primary')!==-1||d.roadTypes.indexOf('trunk')!==-1||d.roadTypes.indexOf('motorway')!==-1) {
          avantages.push('Route principale à portée - accès poids lourds possible');
        }
      } else {
        avantages.push('Aucune route détectée dans le rayon - zone très isolée');
      }

      // ── Eau ────────────────────────────────────────────────────
      if (d.hasWater) {
        avantages.push('Cours d\'eau ou plan d\'eau à proximité - ressource disponible');
      }

      // ── Services répressifs ────────────────────────────────────
      if (d.nearestPolice!==null) {
        var pkm=Math.round(d.nearestPolice/100)/10;
        if (d.nearestPolice<3000) {
          niveau=Math.max(niveau,2);
          inconvenients.push('Brigade/commissariat à ~'+pkm+' km - délai d\'intervention < 10 min');
        } else if (d.nearestPolice<8000) {
          niveau=Math.max(niveau,1);
          inconvenients.push('Forces de l\'ordre à ~'+pkm+' km - délai d\'intervention estimé 15-20 min');
        } else {
          avantages.push('Aucune brigade détectée dans un rayon de 8 km');
        }
      } else {
        avantages.push('Aucune brigade/commissariat détecté - réponse opérationnelle plus lente');
      }

      // ── Établissements sensibles ───────────────────────────────
      if (d.nearestSensible!==null&&d.nearestSensible<500) {
        niveau=Math.max(niveau,2);
        inconvenients.push('Établissement sensible (école/hôpital) à ~'+d.nearestSensible+' m');
      }

      // ── Lignes haute tension ───────────────────────────────────
      if (d.powerlines) {
        avantages.push('Infrastructure électrique (ligne HT) détectée dans la zone');
      }

      return { score:['faible','modéré','élevé','critique'][niveau], avantages:avantages, inconvenients:inconvenients };
    }

    async function queryOverpass(endpoint, query) {
      var ctrl=new AbortController(), tid=setTimeout(function(){ctrl.abort();},22000);
      try {
        var res=await fetch(endpoint,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'data='+encodeURIComponent(query),signal:ctrl.signal});
        clearTimeout(tid);
        if (!res.ok) throw new Error('HTTP '+res.status);
        return await res.json();
      } catch(e) { clearTimeout(tid); throw e; }
    }

    document.getElementById('terAnalyze').addEventListener('click', async function () {
      if (rLat===null) return;
      this.disabled=true;
      document.getElementById('terError').style.display='none';
      document.getElementById('terReport').style.display='none';
      var statusEl=document.getElementById('terStatus'), msgEl=document.getElementById('terStatusMsg');
      var rayon=parseInt(document.getElementById('terRayon').value,10);

      // Requête Overpass étendue : bâti + zones + routes + services + eau + HT
      var query='[out:json][timeout:25];\n(\n'+
        '  way["building"](around:'+rayon+','+rLat+','+rLng+');\n'+
        '  way["landuse"~"residential|military|industrial|farmland|farmyard|forest|commercial|retail"](around:'+rayon+','+rLat+','+rLng+');\n'+
        '  way["natural"~"water|wood|scrub|heath|grassland"](around:'+rayon+','+rLat+','+rLng+');\n'+
        '  way["leisure"="nature_reserve"](around:'+rayon+','+rLat+','+rLng+');\n'+
        '  way["highway"~"motorway|trunk|primary|secondary|tertiary|residential|unclassified|track"](around:'+rayon+','+rLat+','+rLng+');\n'+
        '  node["amenity"~"police|gendarmerie"](around:8000,'+rLat+','+rLng+');\n'+
        '  node["amenity"~"hospital|school|kindergarten|college"](around:'+rayon+','+rLat+','+rLng+');\n'+
        '  way["power"="line"](around:'+rayon+','+rLat+','+rLng+');\n'+
        '  way["waterway"~"river|stream|canal"](around:'+rayon+','+rLat+','+rLng+');\n'+
        ');\nout center tags;';

      var data=null;
      for (var i=0;i<OVERPASS_ENDPOINTS.length;i++) {
        try {
          statusEl.style.display='flex';
          msgEl.textContent=(i===0?'Interrogation Overpass':'Tentative miroir')+'... ('+(i+1)+'/'+OVERPASS_ENDPOINTS.length+')';
          data=await queryOverpass(OVERPASS_ENDPOINTS[i],query);
          break;
        } catch(e) {
          if (i===OVERPASS_ENDPOINTS.length-1) {
            statusEl.style.display='none';
            document.getElementById('terError').textContent='Service cartographique injoignable. Réessaie dans quelques instants.';
            document.getElementById('terError').style.display='block';
            document.getElementById('terAnalyze').disabled=false;
            return;
          }
        }
      }
      statusEl.style.display='none';

      // ── Extraction des données ──────────────────────────────────
      var elements=data.elements||[];
      var nearestHabRaw=null, habCount=0, zonesSet={};
      var militaire=false, protegee=false;
      var nearestRoadRaw=null, roadTypes=[], hasWater=false, hasForest=false;
      var nearestPoliceRaw=null, nearestSensibleRaw=null;
      var powerlines=false;

      for (var j=0;j<elements.length;j++) {
        var el=elements[j], tags=el.tags||{}, c=el.center||el;
        var dist=c.lat!=null ? haversine(rLat,rLng,c.lat,c.lon) : null;

        // Bâtiments
        if (tags.building&&dist!=null) {
          habCount++;
          if (nearestHabRaw===null||dist<nearestHabRaw) nearestHabRaw=dist;
        }

        // Zones d'usage
        var z=classifyZone(tags);
        if (z&&!zonesSet[z]) zonesSet[z]=true;
        if (tags.landuse==='military') militaire=true;
        if (tags.leisure==='nature_reserve'||tags.boundary==='protected_area') protegee=true;

        // Forêt / végétation
        if (tags.natural==='wood'||tags.landuse==='forest'||tags.natural==='scrub') hasForest=true;

        // Eau
        if (tags.natural==='water'||tags.waterway) hasWater=true;

        // Routes
        if (tags.highway&&dist!=null) {
          if (nearestRoadRaw===null||dist<nearestRoadRaw) nearestRoadRaw=dist;
          if (roadTypes.indexOf(tags.highway)===-1) roadTypes.push(tags.highway);
        }

        // Services répressifs
        if ((tags.amenity==='police'||tags.amenity==='gendarmerie')&&dist!=null) {
          if (nearestPoliceRaw===null||dist<nearestPoliceRaw) nearestPoliceRaw=dist;
        }

        // Établissements sensibles
        if ((tags.amenity==='hospital'||tags.amenity==='school'||tags.amenity==='kindergarten'||tags.amenity==='college')&&dist!=null) {
          if (nearestSensibleRaw===null||dist<nearestSensibleRaw) nearestSensibleRaw=dist;
        }

        // Lignes HT
        if (tags.power==='line') powerlines=true;
      }

      var nearestHab=nearestHabRaw===null?null:roundDist(nearestHabRaw);
      var nearestRoad=nearestRoadRaw===null?null:roundDist(nearestRoadRaw);
      var nearestPolice=nearestPoliceRaw===null?null:Math.round(nearestPoliceRaw);
      var nearestSensible=nearestSensibleRaw===null?null:roundDist(nearestSensibleRaw);
      var zones=Object.keys(zonesSet);

      var result=scoreTerrain({
        nearestHab:nearestHab, habCount:habCount, zones:zones,
        militaire:militaire, protegee:protegee,
        nearestRoad:nearestRoad, roadTypes:roadTypes,
        hasWater:hasWater, hasForest:hasForest,
        nearestPolice:nearestPolice, nearestSensible:nearestSensible,
        powerlines:powerlines
      });

      var color=SCORE_COLORS[result.score]||'#00ff9f';
      var scoreIdx=['faible','modéré','élevé','critique'].indexOf(result.score);

      // Score + barre
      document.getElementById('terScore').textContent=result.score.toUpperCase();
      document.getElementById('terScore').style.color=color;
      document.getElementById('terScore').style.textShadow='0 0 10px '+color+'66';
      var fill=document.getElementById('terScoreFill');
      if (fill) { fill.style.width=((scoreIdx+1)*25)+'%'; fill.style.background=color; }

      // Cercle + marqueur
      if (terCircle) terCircle.setStyle({color:color,fillColor:color});
      if (terMarker) terMarker.setStyle({color:color,fillColor:color});

      // Atouts
      var ulOk=document.getElementById('terAvantages'); ulOk.innerHTML='';
      result.avantages.forEach(function(f){var li=document.createElement('li');li.textContent=f;ulOk.appendChild(li);});
      document.getElementById('terNoAtout').style.display=result.avantages.length===0?'block':'none';

      // Risques
      var ulRisk=document.getElementById('terInconvenients'); ulRisk.innerHTML='';
      result.inconvenients.forEach(function(f){var li=document.createElement('li');li.textContent=f;ulRisk.appendChild(li);});
      document.getElementById('terNoRisque').style.display=result.inconvenients.length===0?'block':'none';

      // Données brutes
      var hab=nearestHab===null?'aucune':'~'+nearestHab+' m';
      var road=nearestRoad===null?'aucune':'~'+nearestRoad+' m';
      var police=nearestPolice===null?'> 8 km':'~'+Math.round(nearestPolice/100)/10+' km';
      document.getElementById('terMeta').innerHTML=
        '<div><span>Habitation la + proche</span><b>'+hab+'</b></div>'+
        '<div><span>Bâtiments détectés</span><b>'+habCount+'</b></div>'+
        '<div><span>Route la + proche</span><b>'+road+'</b></div>'+
        '<div><span>Forces de l\'ordre</span><b '+(nearestPolice!==null&&nearestPolice<3000?'style="color:#ff8a00"':'')+'>'+police+'</b></div>'+
        (hasForest?'<div><span>Couvert forestier</span><b style="color:#00ff9f">oui</b></div>':'')+
        (hasWater?'<div><span>Eau à proximité</span><b style="color:#00ff9f">oui</b></div>':'')+
        (powerlines?'<div><span>Ligne haute tension</span><b style="color:#ffd400">détectée</b></div>':'')+
        (militaire?'<div><span>Zone militaire</span><b style="color:#ff8a00">oui</b></div>':'')+
        (protegee?'<div><span>Zone protégée</span><b style="color:#ff8a00">oui</b></div>':'')+
        (zones.length?'<div><span>Zones OSM</span><b>'+zones.join(', ')+'</b></div>':'');

      var rayonLabel=rayon>=1000?(rayon/1000)+' km':rayon+' m';
      document.getElementById('terPrecision').textContent='Rayon '+rayonLabel+' · '+elements.length+' éléments OSM · Validation obligatoire en reconnaissance physique hors réseau.';
      document.getElementById('terReport').style.display='block';
      document.getElementById('terAnalyze').disabled=false;
    });

    // ════════════════════════════════════════════════════════════════════════
    // MODAL SIGNALEMENT
    // ════════════════════════════════════════════════════════════════════════
    var modal=document.getElementById('reportModal');
    function openModal(){modal.style.display='flex';modal.setAttribute('aria-hidden','false');}
    function closeModal(){modal.style.display='none';modal.setAttribute('aria-hidden','true');document.getElementById('modalForm').style.display='block';document.getElementById('modalSuccess').style.display='none';document.getElementById('formError').style.display='none';document.getElementById('submitReport').disabled=false;document.getElementById('submitReport').textContent='ENVOYER LE SIGNALEMENT';}
    document.getElementById('openModal').addEventListener('click',openModal);
    document.getElementById('closeModal').addEventListener('click',closeModal);
    document.getElementById('closeSuccess').addEventListener('click',closeModal);
    modal.addEventListener('click',function(e){if(e.target===modal)closeModal();});

    document.getElementById('submitReport').addEventListener('click',async function(){
      var lieu=document.getElementById('f-lieu').value.trim(),date=document.getElementById('f-date').value.trim(),type=document.getElementById('f-type').value.trim(),desc=document.getElementById('f-desc').value.trim();
      if(!lieu||!date||!type||!desc){document.getElementById('formError').textContent='Champs requis manquants.';document.getElementById('formError').style.display='block';return;}
      document.getElementById('formError').style.display='none';this.disabled=true;this.textContent='ENVOI...';
      try {
        var res=await fetch('/api/report',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({lieu,date,type,description:desc,bilan:document.getElementById('f-bilan').value,source:document.getElementById('f-source').value})});
        var data=await res.json();
        if(res.ok&&data.ok){document.getElementById('modalForm').style.display='none';document.getElementById('modalSuccess').style.display='block';}
        else throw new Error(data.error||'Erreur inconnue');
      } catch(err){document.getElementById('formError').textContent='Erreur : '+err.message;document.getElementById('formError').style.display='block';this.disabled=false;this.textContent='ENVOYER LE SIGNALEMENT';}
    });

  })();
  </script>
</Layout>

<style is:global>
  article.prose-dedsec:has(#mapWrap) { padding: 0 !important; max-width: none !important; margin: 0 !important; }

  /* ── Layout ──────────────────────────────────────────────────── */
  .map-wrap {
    display: grid;
    grid-template-columns: 280px 1fr;
    height: calc(100dvh - 88px);
    position: relative;
    transition: grid-template-columns .3s ease;
    overflow: hidden;
  }
  .map-wrap.collapsed { grid-template-columns: 0 1fr; }

  /* ── Sidebar toggle ──────────────────────────────────────────── */
  .sidebar-toggle {
    position: absolute; left: 280px; top: 50%; transform: translateY(-50%);
    z-index: 1000; width: 18px; height: 48px;
    background: #08080c; border: 1px solid #2a2a3a; border-left: none;
    color: #00ff9f; cursor: pointer; font-size: 10px;
    display: flex; align-items: center; justify-content: center;
    transition: left .3s ease; padding: 0;
  }
  .sidebar-toggle:hover { background: rgba(0,255,159,0.08); }
  .map-wrap.collapsed .sidebar-toggle { left: 0; border-left: 1px solid #2a2a3a; border-right: none; }

  /* ── Aside ───────────────────────────────────────────────────── */
  .map-aside {
    background: #08080c; border-right: 1px solid #2a2a3a;
    overflow: hidden; transition: opacity .25s; width: 280px;
  }
  .map-aside.collapsed { opacity: 0; pointer-events: none; }

  .aside-panel { height: 100%; overflow: hidden; }
  .aside-inner {
    padding: 16px 14px; display: flex; flex-direction: column;
    gap: 14px; height: 100%; overflow-y: auto;
    font-family: 'JetBrains Mono', monospace;
  }

