<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var btn    = document.getElementById('guideToggle');
    var modal  = document.getElementById('guideModal');
    var btnClose = document.getElementById('guideClose');
    if (!btn || !modal) return;

    function openModal() {
      modal.classList.remove('mg-hidden');
      btn.classList.add('active');
      btn.setAttribute('aria-expanded', 'true');
    }
    function closeModal() {
      modal.classList.add('mg-hidden');
      btn.classList.remove('active');
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', function() {
      modal.classList.contains('mg-hidden') ? openModal() : closeModal();
    });

    if (btnClose) btnClose.addEventListener('click', closeModal);

    // Clic sur le fond → ferme
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });

    // Switch d'onglets
    var tabs   = modal.querySelectorAll('.mg-tab');
    var panels = modal.querySelectorAll('.mg-panel');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var target = tab.dataset.tab;
        tabs.forEach(function(t) { t.classList.remove('mg-tab-active'); });
        tab.classList.add('mg-tab-active');
        panels.forEach(function(p) {
          var id = 'mgPanel' + target.charAt(0).toUpperCase() + target.slice(1);
          p.id === id ? p.classList.remove('mg-hidden') : p.classList.add('mg-hidden');
        });
      });
    });

    // Echap → ferme
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });
  });
})();
</script>
