══════════════════════════════════════════════════════════════ -->
<script nonce={nonce} is:inline>
(function () {
  // ── GUIDE MODAL ───────────────────────────────────────────────
  window.icGuideOpen = function () {
    const el = document.getElementById('ic-guide-overlay');
    el.classList.remove('hidden');
    // Trap focus / prevent body scroll
    document.body.style.overflow = 'hidden';
  };
  window.icGuideClose = function () {
    document.getElementById('ic-guide-overlay').classList.add('hidden');
    document.body.style.overflow = '';
  };
  // Fermer avec Echap
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') icGuideClose();
  });

  // ── TABS ─────────────────────────────────────────────────────
  window.icTab = function (name) {
    ['enc','dec'].forEach(n => {
      document.getElementById('tab-'+n).classList.toggle('ic-active', n===name);
      document.getElementById('panel-'+n).classList.toggle('hidden', n!==name);
    });
  };
  // Init : tab enc actif
  document.getElementById('tab-enc').classList.add('ic-active');

  // ── HELPERS ──────────────────────────────────────────────────
  window.icTogglePw = id => {
    const el = document.getElementById(id);
    el.type = el.type === 'password' ? 'text' : 'password';
  };

  function icShowAlert(id, type, msg) {
    const el = document.getElementById(id);
    el.className = (type === 'ok' ? 'ic-alert-ok' : 'ic-alert') + ' mb-4 px-4 py-3 font-mono text-xs tracking-wide';
    el.textContent = msg;
  }
  function icHideAlert(id) {
    const el = document.getElementById(id);
    el.className = el.className.replace(/ic-alert\S*/g,'') + ' hidden';
  }

  window.icCopy = function (srcId, btn) {
    navigator.clipboard.writeText(document.getElementById(srcId).textContent).then(() => {
      btn.textContent = '✓ Copie'; btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'Copier'; btn.classList.remove('copied'); }, 2000);
    });
  };

  function icCopyRaw(text, btn) {
    navigator.clipboard.writeText(text).then(() => {
      const orig = btn.textContent; btn.textContent='✓'; btn.classList.add('copied');
      setTimeout(() => { btn.textContent=orig; btn.classList.remove('copied'); }, 2000);
    });
  }

  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── PASSWORD STRENGTH ─────────────────────────────────────────
  window.icPwStrength = function (pw) {
    const bar  = document.getElementById('ic-pw-bar');
    const hint = document.getElementById('ic-pw-hint');
    if (!pw) { bar.style.width='0%'; hint.textContent='- Entrez un mot de passe'; hint.style.color=''; return; }
    let score = 0;
    if (pw.length >= 8)  score++;
    if (pw.length >= 14) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;
    const levels = [
      { pct:'15%', color:'#ff4444', label:'Tres faible' },
      { pct:'30%', color:'#ff6b35', label:'Faible'      },
      { pct:'55%', color:'#ffaa00', label:'Moyen'       },
      { pct:'80%', color:'#7bed9f', label:'Fort'        },
      { pct:'100%',color:'#00ff9f', label:'Tres fort'   },
    ];
    const l = levels[Math.min(score-1,4)] || levels[0];
    bar.style.width = l.pct; bar.style.background = l.color;
    hint.textContent = '- ' + l.label; hint.style.color = l.color;
  };

  // ── CRYPTO UTILS ──────────────────────────────────────────────
  const ITER = 250000, SALT_LEN = 16, IV_LEN = 12;

  function b64(buf) { return btoa(String.fromCharCode(...new Uint8Array(buf))); }
  function unb64(s) { return Uint8Array.from(atob(s), c=>c.charCodeAt(0)).buffer; }

  async function deriveKey(pw, salt) {
    const km = await crypto.subtle.importKey('raw', new TextEncoder().encode(pw), 'PBKDF2', false, ['deriveKey']);
    return crypto.subtle.deriveKey(
      { name:'PBKDF2', salt, iterations:ITER, hash:'SHA-256' },
      km, { name:'AES-GCM', length:256 }, false, ['encrypt','decrypt']
    );
  }

  async function icEncryptPayload(plain, pw) {
    const salt = crypto.getRandomValues(new Uint8Array(SALT_LEN));
    const iv   = crypto.getRandomValues(new Uint8Array(IV_LEN));
    const key  = await deriveKey(pw, salt);
    const ct   = await crypto.subtle.encrypt({name:'AES-GCM',iv}, key, new TextEncoder().encode(plain));
    return { v:1, algo:'AES-GCM-256', kdf:'PBKDF2-SHA256', iter:ITER,
             salt:b64(salt), iv:b64(iv), ct:b64(ct), ts:new Date().toISOString() };
  }

  async function icDecryptPayload(payload, pw) {
    const salt = unb64(payload.salt), iv = unb64(payload.iv), ct = unb64(payload.ct);
    const km = await crypto.subtle.importKey('raw', new TextEncoder().encode(pw), 'PBKDF2', false, ['deriveKey']);
    const key = await crypto.subtle.deriveKey(
      { name:'PBKDF2', salt, iterations:payload.iter||ITER, hash:'SHA-256' },
      km, { name:'AES-GCM', length:256 }, false, ['decrypt']
    );
    const pt = await crypto.subtle.decrypt({name:'AES-GCM',iv}, key, ct);
    return new TextDecoder().decode(pt);
  }

  // ── CURRENT PAYLOAD ───────────────────────────────────────────
  let currentPayload = null;

  // ── ENCRYPT FLOW ──────────────────────────────────────────────
  window.icEncrypt = async function () {
    const title = document.getElementById('f-title').value.trim();
    const pw1   = document.getElementById('enc-pw1').value;
    const pw2   = document.getElementById('enc-pw2').value;

    const alert = document.getElementById('ic-alert');
    alert.className = 'hidden';

    if (!title) { icShowAlert('ic-alert','err','Le titre est obligatoire.'); return; }
    if (!pw1)   { icShowAlert('ic-alert','err','Le mot de passe est obligatoire.'); return; }
    if (pw1 !== pw2) { icShowAlert('ic-alert','err','Les mots de passe ne correspondent pas.'); return; }

    const btn = document.getElementById('btn-enc');
    const spin = document.getElementById('spin-enc');
    btn.disabled = true; spin.classList.remove('hidden');

    try {
      const data = { title };
      const phone = document.getElementById('f-phone').value.trim();
      const role  = document.getElementById('f-role').value.trim();
      const loc   = document.getElementById('f-location').value.trim();
      const instr = document.getElementById('f-instructions').value.trim();
      const comm  = document.getElementById('f-comment').value.trim();
      if (phone) data.phone = phone;
      if (role)  data.role  = role;
      if (loc)   data.location = loc;
      if (instr) data.instructions = instr;
      if (comm)  data.comment = comm;

      const payload = await icEncryptPayload(JSON.stringify(data), pw1);
      currentPayload = payload;

      document.getElementById('enc-output').textContent = btoa(JSON.stringify(payload));
      document.getElementById('enc-meta').textContent =
        `Chiffre le ${new Date(payload.ts).toLocaleString('fr-FR')} · AES-GCM-256 · PBKDF2 ${payload.iter.toLocaleString()} iter`;
      document.getElementById('enc-result').classList.remove('hidden');
      icShowAlert('ic-alert','ok','Fiche chiffree. Copiez le texte ou telechargez le fichier.');
      document.getElementById('enc-result').scrollIntoView({behavior:'smooth',block:'nearest'});
    } catch(e) {
      icShowAlert('ic-alert','err','Erreur de chiffrement : '+e.message);
    } finally {
      btn.disabled=false; spin.classList.add('hidden');
    }
  };

  window.icDlJSON = function () {
    if (!currentPayload) return;
    const blob = new Blob([JSON.stringify(currentPayload,null,2)],{type:'application/json'});
    icTriggerDl(blob,'infocrypt_'+currentPayload.ts.replace(/[:.TZ]/g,'-')+'.json');
  };
  window.icDlTXT = function () {
    if (!currentPayload) return;
    const blob = new Blob(['INFOCRYPT V1\n'+'='.repeat(40)+'\n'+btoa(JSON.stringify(currentPayload))+'\n'],{type:'text/plain'});
    icTriggerDl(blob,'infocrypt_'+currentPayload.ts.replace(/[:.TZ]/g,'-')+'.txt');
  };
  function icTriggerDl(blob, name) {
    const url=URL.createObjectURL(blob), a=document.createElement('a');
    a.href=url; a.download=name; a.click(); URL.revokeObjectURL(url);
  }

  window.icClearEnc = function () {
    ['f-title','f-phone','f-role','f-location','f-instructions','f-comment','enc-pw1','enc-pw2']
      .forEach(id=>document.getElementById(id).value='');
    document.getElementById('enc-result').classList.add('hidden');
    document.getElementById('ic-alert').className='hidden';
    document.getElementById('ic-pw-bar').style.width='0%';
    document.getElementById('ic-pw-hint').textContent='- Entrez un mot de passe';
    currentPayload=null;
  };

  // ── IMPORT FILE ───────────────────────────────────────────────
  window.icImportFile = function (input) {
    const file = input.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      let text = e.target.result.trim();
      if (text.startsWith('INFOCRYPT')) {
        const lines = text.split('\n');
        text = lines.find(l => l.length>40 && !/^[=\s]|^INFO/.test(l)) || text;
      }
      document.getElementById('dec-input').value = text;
    };
    reader.readAsText(file);
  };

  // Drag-and-drop
  const dz = document.getElementById('ic-drop-zone');
  if (dz) {
    dz.addEventListener('dragover', e=>{ e.preventDefault(); dz.classList.add('border-neon-green/50'); });
    dz.addEventListener('dragleave', ()=>dz.classList.remove('border-neon-green/50'));
    dz.addEventListener('drop', e=>{
      e.preventDefault(); dz.classList.remove('border-neon-green/50');
      const file=e.dataTransfer.files[0]; if(!file) return;
      const fi=document.getElementById('ic-file-import'); fi.files=e.dataTransfer.files; icImportFile(fi);
    });
  }

  // ── DECRYPT FLOW ──────────────────────────────────────────────
  window.icDecrypt = async function () {
    ['dec-alert-err','dec-alert-ok'].forEach(id=>{
      const el=document.getElementById(id); el.className=(el.className||'')+' hidden';
    });
    document.getElementById('dec-card').classList.add('hidden');

    const raw = document.getElementById('dec-input').value.trim();
    const pw  = document.getElementById('dec-pw').value;

    if (!raw) { icShowAlert('dec-alert-err','err','Collez un texte chiffre ou importez un fichier.'); return; }
    if (!pw)  { icShowAlert('dec-alert-err','err','Le mot de passe est obligatoire.'); return; }

    const btn=document.getElementById('btn-dec'), spin=document.getElementById('spin-dec');
    btn.disabled=true; spin.classList.remove('hidden');

    try {
      let payload;
      try { payload = JSON.parse(raw); } catch(_) {
        try { payload = JSON.parse(atob(raw)); } catch(_2) {
          throw new Error('Format non reconnu (JSON ou base64 InfoCrypt attendu).');
        }
      }
      if (!payload.ct||!payload.salt||!payload.iv) throw new Error('Payload invalide : champs manquants.');

      const plaintext = await icDecryptPayload(payload, pw);
      const data = JSON.parse(plaintext);

      // Render card
      document.getElementById('dec-card-title').textContent = data.title || '(Sans titre)';
      const fields = [
        {key:'phone',        label:'Telephone'},
        {key:'role',         label:'Role'},
        {key:'location',     label:'Lieu / Zone'},
        {key:'instructions', label:'Instructions'},
        {key:'comment',      label:'Commentaire'},
      ];
      const container = document.getElementById('dec-card-fields');
      container.innerHTML = '';
      fields.forEach(f => {
        if (!data[f.key]) return;
        const row = document.createElement('div');
        row.className = 'ic-card-row';
        row.innerHTML = `
          <div class="ic-card-row-lbl">${f.label}</div>
          <div class="ic-card-row-val">${esc(data[f.key])}</div>
          <button class="ic-copy-btn" style="flex-shrink:0;" onclick="(function(btn){
            navigator.clipboard.writeText(${JSON.stringify(data[f.key])}).then(()=>{
              var o=btn.textContent; btn.textContent='✓'; btn.classList.add('copied');
              setTimeout(()=>{btn.textContent=o;btn.classList.remove('copied')},2000);
            });
          })(this)">⧉</button>`;
        container.appendChild(row);
      });
      document.getElementById('dec-meta').textContent =
        payload.ts ? `Chiffre le ${new Date(payload.ts).toLocaleString('fr-FR')} · ${payload.algo} · PBKDF2 ${(payload.iter||0).toLocaleString()} iter` : '';

      document.getElementById('dec-card').classList.remove('hidden');
      icShowAlert('dec-alert-ok','ok','Dechiffrement reussi.');

    } catch(e) {
      const msg = e.name==='OperationError' ? 'Mot de passe incorrect ou donnees corrompues.' : e.message;
      icShowAlert('dec-alert-err','err','x ' + msg);
    } finally {
      btn.disabled=false; spin.classList.add('hidden');
    }
  };

  window.icClearDec = function () {
    document.getElementById('dec-input').value='';
    document.getElementById('dec-pw').value='';
    document.getElementById('dec-card').classList.add('hidden');
    ['dec-alert-err','dec-alert-ok'].forEach(id=>{
      const el=document.getElementById(id); el.className=(el.className||'')+' hidden';
    });
    document.getElementById('ic-file-import').value='';
  };

  // ── GÉNÉRATEUR DICEWARE ───────────────────────────────────────
  // Liste embarquée dans la page : aucune requête réseau.
  let DW_WORDS = [];
  try { DW_WORDS = JSON.parse(document.getElementById('ic-dw-words').textContent); } catch(_) {}
  const DW_BITS_PER_WORD = DW_WORDS.length ? Math.log2(DW_WORDS.length) : 0;
  let dwSep = '-';
  let dwCurrent = '';

  // Tirage uniforme non biaisé via CSPRNG (rejection sampling).
  // Un simple `% n` introduirait un biais modulo ; on rejette la frange haute.
  function dwRandInt(n) {
    const max = Math.floor(0xFFFFFFFF / n) * n;
    const buf = new Uint32Array(1);
    let x;
    do { crypto.getRandomValues(buf); x = buf[0]; } while (x >= max);
    return x % n;
  }

  function dwClampCount() {
    const el = document.getElementById('ic-dw-count');
    let n = parseInt(el.value, 10);
    if (isNaN(n)) n = 6;
    n = Math.max(4, Math.min(12, n));
    el.value = n;
    return n;
  }

  function dwFormatTime(seconds) {
    if (!isFinite(seconds)) return 'pratiquement infini';
    const units = [
      ['milliard d\'années', 31557600e9],
      ['million d\'années',  31557600e6],
      ['millénaire',         31557600000],
      ['siècle',             3155760000],
      ['an',                 31557600],
      ['jour',               86400],
      ['heure',              3600],
      ['seconde',            1],
    ];
    for (const [name, secs] of units) {
      if (seconds >= secs) {
        const v = seconds / secs;
        const r = v >= 100 ? Math.round(v) : Math.round(v * 10) / 10;
        const plural = (r > 1 && !name.includes('\'')) ? (name.endsWith('s') ? name : name + 's') : name;
        return r.toLocaleString('fr-FR') + ' ' + plural;
      }
    }
    return 'moins d\'une seconde';
  }

  function icDwUpdateMeter() {
    const n = dwClampCount();
    const bits = n * DW_BITS_PER_WORD;
    const meter = document.getElementById('ic-dw-meter');
    const ent   = document.getElementById('ic-dw-entropy');
    const crack = document.getElementById('ic-dw-crack');

    // Échelle : 128 bits = barre pleine.
    const pct = Math.min(bits / 128 * 100, 100);
    let color, label;
    if (bits < 50)      { color = '#ff4444'; label = 'Faible'; }
    else if (bits < 70) { color = '#ffaa00'; label = 'Correct'; }
    else if (bits < 90) { color = '#7bed9f'; label = 'Fort'; }
    else                { color = '#00ff9f'; label = 'Excellent'; }
    meter.style.width = pct + '%';
    meter.style.background = color;
    ent.textContent = Math.round(bits) + ' bits';
    ent.style.color = color;

    // Hypothèse pessimiste : 100 milliards d'essais/seconde, sans tenir
    // compte du frein PBKDF2 (250k itérations) qui rallonge encore le calcul.
    const avgGuesses = Math.pow(2, bits - 1);
    const seconds = avgGuesses / 1e11;
    crack.innerHTML = '<b>' + label + '</b> · ' + Math.round(bits) +
      ' bits d\'entropie · cassage hors-ligne estimé à <b>' + dwFormatTime(seconds) + '</b>.';
  }

  window.icDwStep = function (d) {
    const el = document.getElementById('ic-dw-count');
    el.value = (parseInt(el.value, 10) || 6) + d;
    dwClampCount();
    if (dwCurrent) icDwGenerate(); else icDwUpdateMeter();
  };

  window.icDwSep = function (btn) {
    document.querySelectorAll('#ic-dw-seps .ic-dw-sep').forEach(b => b.classList.remove('ic-dw-sep-active'));
    btn.classList.add('ic-dw-sep-active');
    dwSep = btn.getAttribute('data-sep');
    if (dwCurrent) icDwGenerate();
  };

  window.icDwGenerate = function () {
    if (!DW_WORDS.length) return;
    const n = dwClampCount();
    const words = [];
    for (let i = 0; i < n; i++) words.push(DW_WORDS[dwRandInt(DW_WORDS.length)]);
    dwCurrent = words.join(dwSep);
    const out = document.getElementById('ic-dw-output');
    out.textContent = dwCurrent;
    out.classList.remove('ic-dw-empty');
    document.getElementById('ic-dw-use').disabled = false;
    icDwUpdateMeter();
  };

  window.icDwCopy = function (btn) {
    if (!dwCurrent) return;
    navigator.clipboard.writeText(dwCurrent).then(() => {
      btn.textContent = '✓'; btn.classList.add('copied');
      setTimeout(() => { btn.textContent = '⧉'; btn.classList.remove('copied'); }, 1800);
    });
  };

  window.icDwUse = function () {
    if (!dwCurrent) return;
    const p1 = document.getElementById('enc-pw1');
    const p2 = document.getElementById('enc-pw2');
    p1.value = dwCurrent; p2.value = dwCurrent;
    icPwStrength(dwCurrent);
    p1.scrollIntoView({ behavior: 'smooth', block: 'center' });
    const btn = document.querySelector('.ic-dw-use');
    const orig = btn.textContent;
    btn.textContent = '✓ Mot de passe rempli';
    setTimeout(() => { btn.textContent = orig; }, 2000);
  };

  // Init : une phrase prête dès l'ouverture.
  document.getElementById('ic-dw-use').disabled = true;
  icDwGenerate();
})();
</script>

</Layout>
