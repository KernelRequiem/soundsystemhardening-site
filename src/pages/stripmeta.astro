        var entryOff = gpsOffset + 2 + e * 12;
        if (entryOff + 12 > buf.byteLength) break;
        var tag   = r16(entryOff);
        var type  = r16(entryOff + 2);
        var count = r32(entryOff + 4);
        var valOff= entryOff + 8;
