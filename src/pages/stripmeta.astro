// ────────────────────────────────────────────────────────────
// 2. NETTOYAGE BINAIRE JPEG
// ────────────────────────────────────────────────────────────
function cleanJpegBinary(buffer) {
  var src = new Uint8Array(buffer);
  var out = [];
  var i   = 0;
  var stripped = 0;

  // SOI
  out.push(src[0], src[1]);
  i = 2;

  while (i < src.length - 1) {
    if (src[i] !== 0xFF) { out.push(src[i++]); continue; }
    var marker = (src[i] << 8) | src[i+1];

    // EOI ou marqueur sans longueur
    if (marker === 0xFFD9 || marker === 0xFFD8) {
      out.push(src[i], src[i+1]); i += 2; continue;
    }
    // SOS : copier jusqu'à la fin
    if (marker === JPEG_SOS) {
      for (var j = i; j < src.length; j++) out.push(src[j]);
      break;
    }
    // Longueur du segment
    if (i + 3 >= src.length) break;
    var segLen = (src[i+2] << 8) | src[i+3];
    if (segLen < 2) { i += 2; continue; }

    if (STRIP_MARKERS.indexOf(marker) !== -1) {
      // Supprimer ce segment
      stripped++;
      i += 2 + segLen;
    } else {
      // Conserver
      for (var j = 0; j < 2 + segLen; j++) out.push(src[i+j]);
      i += 2 + segLen;
    }
  }

  return { data: new Uint8Array(out), stripped: stripped };
