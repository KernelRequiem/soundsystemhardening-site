      canvas.toBlob(function(cleanBlob) {
        if (!cleanBlob) { reject(new Error('Canvas toBlob failed')); return; }
        resolve(cleanBlob);
      }, mimeOut, quality / 100);
    };
    img.onerror = function() { URL.revokeObjectURL(url); reject(new Error('Image load failed')); };
    img.src = url;
  });
}

// ────────────────────────────────────────────────────────────
// 5. PIPELINE COMPLET PAR FICHIER
// ────────────────────────────────────────────────────────────
function getOutputMime(file, fmtOverride) {
  if (fmtOverride === 'jpeg') return 'image/jpeg';
  if (fmtOverride === 'png')  return 'image/png';
  if (fmtOverride === 'webp') return 'image/webp';
  // original
  var t = file.type.toLowerCase();
  if (t === 'image/jpeg' || t === 'image/jpg') return 'image/jpeg';
  if (t === 'image/png')  return 'image/png';
  if (t === 'image/webp') return 'image/webp';
  return 'image/jpeg'; // fallback pour HEIC, TIFF, etc.
}

function getExtension(mime) {
  if (mime === 'image/jpeg') return '.jpg';
  if (mime === 'image/png')  return '.png';
  if (mime === 'image/webp') return '.webp';
  return '.jpg';
}

function formatBytes(n) {
  if (n < 1024) return n + ' o';
  if (n < 1048576) return (n/1024).toFixed(1) + ' Ko';
  return (n/1048576).toFixed(2) + ' Mo';
}

async function processFile(file, quality, fmtOverride, addSuffix) {
  var result = {
    name: file.name, originalSize: file.size,
    cleanedBlob: null, cleanedSize: 0,
    tags: {}, gps: null, strippedSegments: 0,
    outputMime: getOutputMime(file, fmtOverride),
    error: null, warning: null
  };

  try {
    var buffer = await file.arrayBuffer();
    var mime   = file.type.toLowerCase();
    var binaryStripped = 0;

    // ── Étape 1 : extraire le rapport de métadonnées
    if (mime === 'image/jpeg' || mime === 'image/jpg') {
      var parsed = parseExifJpeg(buffer);
      result.tags = parsed.tags;
      result.gps  = parsed.gps;
    }

    // ── Étape 2 : nettoyage binaire selon le format
    var binaryBlob = null;
    if (mime === 'image/jpeg' || mime === 'image/jpg') {
      var r = cleanJpegBinary(buffer);
      binaryStripped = r.stripped;
      result.strippedSegments = r.stripped;
      binaryBlob = new Blob([r.data], { type: 'image/jpeg' });
    } else if (mime === 'image/png') {
      var r = cleanPngBinary(buffer);
      binaryStripped = r.stripped;
      result.strippedSegments = r.stripped;
      binaryBlob = new Blob([r.data], { type: 'image/png' });
    } else {
      // WebP, HEIC, TIFF → direct canvas
      binaryBlob = file;
      if (mime === 'image/heic' || mime === 'image/heif' || mime === 'image/tiff') {
        result.warning = 'Format ' + file.type + ' : converti en ' + result.outputMime + ' via Canvas.';
      }
    }

    // ── Étape 3 : re-encodage Canvas (filet de sécurité)
    var cleanBlob = await canvasReencode(binaryBlob, result.outputMime, quality);

    // Renommer
    var baseName = file.name.replace(/\.[^.]+$/, '');
    if (addSuffix) baseName += '_clean';
    var ext = getExtension(result.outputMime);
    result.cleanedBlobName = baseName + ext;
    result.cleanedBlob = cleanBlob;
    result.cleanedSize = cleanBlob.size;

  } catch(e) {
    result.error = e.message || 'Erreur inconnue';
  }

  return result;
}

// ────────────────────────────────────────────────────────────
// 6. ÉTAT GLOBAL
// ────────────────────────────────────────────────────────────
var SM = {
  files:   [],   // { file, result, cardEl, thumbUrl }
  quality: 92,
  fmt:     'original',
  rename:  false,
};

// ────────────────────────────────────────────────────────────
// 7. UI - RENDU DES CARTES
// ────────────────────────────────────────────────────────────
function renderCard(entry, index) {
  var card = document.createElement('div');
  card.className = 'sm-file-card';
  card.dataset.idx = index;

  // Miniature
  var thumbUrl = URL.createObjectURL(entry.file);
  entry.thumbUrl = thumbUrl;

  card.innerHTML =
    '<div class="sm-card-head" data-idx="' + index + '">'
  + '  <img src="' + thumbUrl + '" class="sm-thumb" alt="" />'
  + '  <div class="sm-card-info">'
  + '    <div class="sm-card-name">' + escHtml(entry.file.name) + '</div>'
  + '    <div class="sm-card-meta">'
  +        entry.file.type + ' · ' + formatBytes(entry.file.size)
  + '    </div>'
  + '  </div>'
  + '  <span class="sm-card-status pending">EN ATTENTE</span>'
  + '  <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:rgba(0,255,159,0.4);transition:transform 0.2s;"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>'
  + '</div>'
  + '<div class="sm-card-body"></div>';

  // Toggle
  card.querySelector('.sm-card-head').addEventListener('click', function() {
    var body = card.querySelector('.sm-card-body');
    var chev = card.querySelector('.chev');
    var open = body.classList.toggle('open');
    chev.style.transform = open ? 'rotate(180deg)' : '';
  });

  entry.cardEl = card;
  return card;
}

function setCardStatus(entry, status, label) {
  var el = entry.cardEl.querySelector('.sm-card-status');
  el.className = 'sm-card-status ' + status;
  el.textContent = label;
  if (status === 'done') entry.cardEl.className = 'sm-file-card state-done';
  if (status === 'error') entry.cardEl.className = 'sm-file-card state-error';
  if (status === 'warn') entry.cardEl.className = 'sm-file-card state-warn';
}

// ────────────────────────────────────────────────────────────
// 7bis. PARSEUR MÉTADONNÉES PNG (tEXt / iTXt / zTXt / eXIf)
// ────────────────────────────────────────────────────────────
function parsePngMeta(buffer) {
  var src = new Uint8Array(buffer);
  var tags = {};
  var sig = [137,80,78,71,13,10,26,10];
  for (var k = 0; k < 8; k++) if (src[k] !== sig[k]) return tags;
  var i = 8;
  while (i + 12 <= src.length) {
    var len = (src[i]<<24)|(src[i+1]<<16)|(src[i+2]<<8)|src[i+3];
    if (len < 0 || i + 12 + len > src.length) break;
    var type = String.fromCharCode(src[i+4], src[i+5], src[i+6], src[i+7]);
    var dataStart = i + 8;
    try {
      if (type === 'tEXt') {
        var s = '';
        for (var j = 0; j < len; j++) s += String.fromCharCode(src[dataStart+j]);
        var nul = s.indexOf('\0');
        var key = nul >= 0 ? s.slice(0, nul) : 'tEXt';
        var val = nul >= 0 ? s.slice(nul+1) : s;
        tags['PNG:' + key] = val;
      } else if (type === 'iTXt') {
        var s2 = '';
        for (var j2 = 0; j2 < len; j2++) s2 += String.fromCharCode(src[dataStart+j2]);
        var parts = s2.split('\0');
        var key2 = parts[0] || 'iTXt';
        var val2 = parts.slice(5).join('\0') || parts[parts.length-1] || '';
        tags['PNG:' + key2] = val2;
      } else if (type === 'zTXt') {
        var s3 = '';
        for (var j3 = 0; j3 < Math.min(len, 80); j3++) s3 += String.fromCharCode(src[dataStart+j3]);
        var nul3 = s3.indexOf('\0');
        tags['PNG:' + (nul3 >= 0 ? s3.slice(0, nul3) : 'zTXt')] = '[texte compressé]';
      } else if (type === 'eXIf') {
        var ex = parseExifBlock(buffer.slice(dataStart, dataStart + len));
        tags = Object.assign(tags, ex.tags);
      } else if (type === 'tIME') {
        tags['PNG:LastModified'] = '[horodatage présent]';
      }
    } catch(e) {}
    if (type === 'IEND') break;
    i += 4 + 4 + len + 4;
  }
  return tags;
}

// ────────────────────────────────────────────────────────────
// 7ter. HELPERS DE RAPPORT (partagés inspection / post-nettoyage)
// ────────────────────────────────────────────────────────────
function classifyTags(tags, gps) {
  var c = { gps: !!gps, device:false, datetime:false, software:false, serial:false };
  Object.keys(tags).forEach(function(k) {
    if (k.indexOf('GPS') !== -1) c.gps = true;
    if (k === 'Make' || k === 'Model') c.device = true;
    if (k === 'DateTime' || k === 'DateTimeOriginal' || k === 'DateTimeDigitized') c.datetime = true;
    if (k === 'Software' || k === 'Artist' || k === 'Copyright' || k === 'UserComment' || k.indexOf('PNG:') === 0) c.software = true;
    if (k === 'BodySerialNumber' || k === 'LensSerialNumber' || k === 'ImageUniqueID' || k === 'CameraOwnerName') c.serial = true;
  });
  return c;
}

function buildChipsHtml(cats) {
  var defs = [];
  if (cats.gps)      defs.push(['GPS','crit']);
  if (cats.serial)   defs.push(['N° SÉRIE','crit']);
  if (cats.device)   defs.push(['APPAREIL','high']);
  if (cats.datetime) defs.push(['DATE','high']);
  if (cats.software) defs.push(['LOGICIEL','med']);
  if (!defs.length) return '<span class="sm-chip safe">RAS</span>';
  return defs.map(function(d) { return '<span class="sm-chip ' + d[1] + '">' + d[0] + '</span>'; }).join('');
}

function buildRiskBannerHtml(cats, removed) {
  var items = [];
  if (cats.gps)      items.push('la localisation GPS');
  if (cats.device)   items.push("le modèle d'appareil");
  if (cats.serial)   items.push('un numéro de série');
  if (cats.datetime) items.push('la date de prise de vue');
  if (cats.software) items.push('le logiciel utilisé');
  if (!items.length) {
    return '<div class="sm-risk-banner safe"><span class="sm-risk-banner-icon">✓</span><div>Aucune métadonnée sensible lisible détectée. Le re-encodage garantira tout de même une sortie propre.</div></div>';
  }
  var list = items.join(', ').replace(/,([^,]*)$/, ' et$1');
  var verb = removed ? 'exposait' : 'expose';
  var tail = removed ? ' Ces données ont été supprimées.' : ' Nettoie le fichier pour les retirer.';
  return '<div class="sm-risk-banner danger"><span class="sm-risk-banner-icon">⚠</span><div>Cette image ' + verb + ' : <b>' + list + '</b>.' + tail + '</div></div>';
}

function buildGpsAlertHtml(gps, removed) {
  var mapsUrl = 'https://www.openstreetmap.org/?mlat=' + gps.lat + '&mlon=' + gps.lon + '&zoom=15';
  return '<div class="sm-gps-alert"><span class="sm-gps-alert-icon">⚠</span><div>'
    + '<div class="sm-gps-alert-title">⚠ GPS DÉTECTÉ' + (removed ? ' - Supprimé' : ' - localisation exposée') + '</div>'
    + '<div class="sm-gps-alert-val">Lat ' + gps.lat + ' · Lon ' + gps.lon + '</div>'
    + '<a href="' + mapsUrl + '" target="_blank" rel="noopener" class="sm-gps-maps-link">↗ Voir sur OpenStreetMap</a>'
    + '</div></div>';
}

function buildMetaTableHtml(tags, removed) {
  var tagKeys = Object.keys(tags);
  if (!tagKeys.length) {
    return '<div class="sm-no-meta">Aucune métadonnée EXIF/texte lisible détectée (format non JPEG/PNG, ou fichier déjà propre).</div>';
  }
  var html = '<div class="sm-inspect-label">' + (removed ? 'Métadonnées trouvées et supprimées' : 'Métadonnées détectées dans le fichier') + '</div>';
  html += '<table class="sm-meta-table"><thead><tr><th>Champ</th><th>Valeur ' + (removed ? 'originale' : 'lue') + '</th></tr></thead><tbody>';
  tagKeys.sort().forEach(function(k) {
    var isGps    = k.indexOf('GPS') !== -1;
    var isDevice = ['Make','Model','BodySerialNumber','LensSerialNumber','ImageUniqueID','CameraOwnerName'].indexOf(k) !== -1;
    var isSoft   = ['Software','Artist','Copyright','UserComment'].indexOf(k) !== -1 || k.indexOf('PNG:') === 0;
    var tdClass  = isGps ? ' class="sm-meta-tag-gps"' : isDevice ? ' class="sm-meta-tag-device"' : isSoft ? ' class="sm-meta-tag-soft"' : '';
    var val = String(tags[k]);
    if (val.length > 80) val = val.substring(0, 80) + '…';
    html += '<tr><td' + tdClass + '>' + escHtml(k) + '</td><td>' + escHtml(val) + '</td></tr>';
  });
  html += '</tbody></table>';
  return html;
}

// ────────────────────────────────────────────────────────────
// 7quater. INSPECTION (lecture seule, dès l'ajout du fichier)
// ────────────────────────────────────────────────────────────
async function inspectFile(entry) {
  try {
    var buf  = await entry.file.arrayBuffer();
    var mime = entry.file.type.toLowerCase();
    var tags = {}, gps = null;
    if (mime === 'image/jpeg' || mime === 'image/jpg') {
      var p = parseExifJpeg(buf);
      tags = p.tags; gps = p.gps;
    } else if (mime === 'image/png') {
      tags = parsePngMeta(buf);
    }
    entry.inspection = { tags: tags, gps: gps };
  } catch(e) {
    entry.inspection = { tags: {}, gps: null, error: e.message };
  }
}

function renderInspection(entry) {
  if (entry.result) return; // déjà nettoyé : ne pas écraser le rapport post-nettoyage
  var insp = entry.inspection || { tags: {}, gps: null };
  var cats = classifyTags(insp.tags, insp.gps);
  var idx  = entry.cardEl.dataset.idx;

  // Chips de risque dans l'entête
  var info = entry.cardEl.querySelector('.sm-card-info');
  var chipBox = info.querySelector('.sm-card-chips');
  if (!chipBox) { chipBox = document.createElement('div'); chipBox.className = 'sm-card-chips'; info.appendChild(chipBox); }
  chipBox.innerHTML = buildChipsHtml(cats);

  // Statut pré-nettoyage
  var sensitive = cats.gps || cats.device || cats.datetime || cats.serial || cats.software;
  if (cats.gps)        setCardStatus(entry, 'inspect', '⚠ GPS');
  else if (sensitive)  setCardStatus(entry, 'inspect', 'MÉTA DÉTECTÉE');
  else                 setCardStatus(entry, 'pending', 'À RE-ENCODER');

  // Corps : bannière + alerte GPS + tableau + actions
  var body = entry.cardEl.querySelector('.sm-card-body');
  var html = buildRiskBannerHtml(cats, false);
  if (insp.gps) html += buildGpsAlertHtml(insp.gps, false);
  html += buildMetaTableHtml(insp.tags, false);
  html += '<div class="sm-card-actions">'
        + '<button class="sm-btn-small sm-clean-single" data-idx="' + idx + '">⊘ Nettoyer ce fichier</button>'
        + '<button class="sm-btn-small-sec sm-remove-card" data-idx="' + idx + '">× Retirer</button>'
        + '</div>';
  body.innerHTML = html;

  // Auto-ouvrir la carte si un risque est présent
  if (sensitive) {
    body.classList.add('open');
    entry.cardEl.querySelector('.chev').style.transform = 'rotate(180deg)';
  }

  body.querySelector('.sm-clean-single').addEventListener('click', function(e) {
    e.stopPropagation(); cleanSingle(entry);
  });
  body.querySelector('.sm-remove-card').addEventListener('click', function(e) {
    e.stopPropagation();
    var i = parseInt(entry.cardEl.dataset.idx);
    SM.files.splice(i, 1);
    entry.cardEl.remove();
    updateActionBar();
    renumberCards();
  });
}

async function cleanSingle(entry) {
  if (entry.result) return;
  setCardStatus(entry, 'working', 'TRAITEMENT…');
  entry.result = await processFile(entry.file, SM.quality, SM.fmt, SM.rename);
  if (entry.result.error)        setCardStatus(entry, 'error', 'ERREUR');
  else if (entry.result.warning) setCardStatus(entry, 'warn', 'CONVERTI');
  else                           setCardStatus(entry, 'done', entry.result.gps ? '⚠ GPS SUPPRIMÉ' : 'NETTOYÉ');
  renderCardBody(entry);
  updateActionBar();
}

function renderCardBody(entry) {
  var r = entry.result;
  var body = entry.cardEl.querySelector('.sm-card-body');

  var html = '';

  // Alerte GPS
  if (r.gps) {
    html += buildGpsAlertHtml(r.gps, true);
  }

  // Stats nettoyage
  if (r.cleanedBlob) {
    var saved = r.originalSize - r.cleanedSize;
    var pct   = r.originalSize > 0 ? Math.round((saved / r.originalSize) * 100) : 0;
    html +=
      '<div class="sm-clean-stats">'
    + '  <div class="sm-stat-block"><div class="sm-stat-val">' + r.strippedSegments + '</div><div class="sm-stat-label">Segments supprimés</div></div>'
    + '  <div class="sm-stat-block"><div class="sm-stat-val">' + Object.keys(r.tags).length + '</div><div class="sm-stat-label">Champs EXIF lus</div></div>'
    + '  <div class="sm-stat-block"><div class="sm-stat-val">' + formatBytes(r.cleanedSize) + '</div><div class="sm-stat-label">Taille finale</div></div>'
    + '  <div class="sm-stat-block"><div class="sm-stat-val' + (saved > 0 ? ' text-neon-green' : '') + '">' + (saved > 0 ? '-' : '') + formatBytes(Math.abs(saved)) + '</div><div class="sm-stat-label">Écart</div></div>'
    + '</div>';
  }

  // Erreur / warning
  if (r.error) {
    html += '<div style="font-family:JetBrains Mono,monospace;font-size:11px;color:rgba(255,68,68,0.8);padding:8px 0;">✕ ' + escHtml(r.error) + '</div>';
  }
  if (r.warning) {
    html += '<div style="font-family:JetBrains Mono,monospace;font-size:11px;color:rgba(255,180,0,0.8);padding:4px 0;">⚠ ' + escHtml(r.warning) + '</div>';
  }

  // Tableau EXIF (métadonnées supprimées)
  html += buildMetaTableHtml(r.tags, true);

  // Aperçu avant/après + bouton télécharger
  if (r.cleanedBlob) {
    var cleanUrl = URL.createObjectURL(r.cleanedBlob);
    entry.cleanUrl = cleanUrl;
    html +=
      '<div class="sm-preview-pair">'
    + '  <div><div class="sm-preview-label">Avant</div><img src="' + entry.thumbUrl + '" class="sm-preview-img" alt="avant" /></div>'
    + '  <div><div class="sm-preview-label">Après (nettoyé)</div><img src="' + cleanUrl + '" class="sm-preview-img" alt="après" /></div>'
    + '</div>';
  }

  // Boutons d'action
  html += '<div class="sm-card-actions">';
  if (r.cleanedBlob) {
    html += '<button class="sm-btn-small sm-dl-single" data-idx="' + entry.cardEl.dataset.idx + '">↓ Télécharger</button>';
  }
  html += '<button class="sm-btn-small-sec sm-remove-card" data-idx="' + entry.cardEl.dataset.idx + '">× Retirer</button>';
  html += '</div>';

  body.innerHTML = html;
  body.classList.add('open');
  entry.cardEl.querySelector('.chev').style.transform = 'rotate(180deg)';

  // Bind download
  var dlBtn = body.querySelector('.sm-dl-single');
  if (dlBtn) {
    dlBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      downloadBlob(r.cleanedBlob, entry.result.cleanedBlobName);
    });
  }
  // Bind remove
  body.querySelector('.sm-remove-card').addEventListener('click', function(e) {
    e.stopPropagation();
    var idx = parseInt(entry.cardEl.dataset.idx);
    SM.files.splice(idx, 1);
    entry.cardEl.remove();
    updateActionBar();
    renumberCards();
  });
}

function renumberCards() {
  SM.files.forEach(function(e, i) { e.cardEl.dataset.idx = i; });
}

function escHtml(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function downloadBlob(blob, name) {
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = name;
  document.body.appendChild(a);
  a.click();
  setTimeout(function() { document.body.removeChild(a); URL.revokeObjectURL(a.href); }, 500);
}

// ────────────────────────────────────────────────────────────
// 8. ZIP BATCH (JSZip depuis cdnjs)
// ────────────────────────────────────────────────────────────
function loadJSZip() {
  return new Promise(function(resolve, reject) {
    if (window.JSZip) { resolve(window.JSZip); return; }
    var s = document.createElement('script');
    s.src = '/vendor/jszip/jszip.min.js'; // auto-hébergé (zéro CDN externe)
    s.onload  = function() { resolve(window.JSZip); };
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

async function downloadAllZip() {
  var done = SM.files.filter(function(e) { return e.result && e.result.cleanedBlob; });
  if (!done.length) return;
  var dlBtn = document.getElementById('sm-download-all');
  dlBtn.textContent = '… Compression en cours';
  dlBtn.disabled = true;

  try {
    var JSZip = await loadJSZip();
    var zip = new JSZip();
    var folder = zip.folder('stripmeta_clean');
    for (var i = 0; i < done.length; i++) {
      var e = done[i];
      var ab = await e.result.cleanedBlob.arrayBuffer();
      folder.file(e.result.cleanedBlobName, ab);
    }
    var blob = await zip.generateAsync({ type: 'blob', compression: 'DEFLATE', compressionOptions: { level: 6 } });
    downloadBlob(blob, 'stripmeta_clean_' + Date.now() + '.zip');
  } catch(err) {
    alert('Erreur ZIP : ' + err.message);
  }
  dlBtn.innerHTML = '<span>↓</span> Télécharger tout (ZIP)';
  dlBtn.disabled = false;
}

// ────────────────────────────────────────────────────────────
// 9. ACTIONS GLOBALES
// ────────────────────────────────────────────────────────────
function updateActionBar() {
  var list    = document.getElementById('sm-file-list');
  var actions = document.getElementById('sm-actions');
  var opts    = document.getElementById('sm-options');
  var hasDl   = SM.files.some(function(e) { return e.result && e.result.cleanedBlob; });

  if (SM.files.length === 0) {
    list.classList.add('hidden');
    actions.classList.add('hidden');
    opts.classList.add('hidden');
    document.getElementById('sm-download-all').classList.add('hidden');
  } else {
    list.classList.remove('hidden');
    actions.classList.remove('hidden');
    opts.classList.remove('hidden');
    if (hasDl) document.getElementById('sm-download-all').classList.remove('hidden');
  }
}

async function processAll() {
  var btn = document.getElementById('sm-process-all');
  btn.disabled = true;
  var status = document.getElementById('sm-global-status');

  for (var i = 0; i < SM.files.length; i++) {
    var entry = SM.files[i];
    if (entry.result) continue; // déjà traité
    setCardStatus(entry, 'working', 'TRAITEMENT…');
    status.textContent = (i+1) + ' / ' + SM.files.length + ' en cours…';

    entry.result = await processFile(entry.file, SM.quality, SM.fmt, SM.rename);

    if (entry.result.error) {
      setCardStatus(entry, 'error', 'ERREUR');
    } else if (entry.result.warning) {
      setCardStatus(entry, 'warn', 'CONVERTI');
    } else {
      var gpsLabel = entry.result.gps ? '⚠ GPS TROUVÉ' : 'NETTOYÉ';
      setCardStatus(entry, 'done', gpsLabel);
    }
    renderCardBody(entry);
    updateActionBar();
  }

  status.textContent = SM.files.length + ' fichier(s) traité(s)';
  btn.disabled = false;
}

// ────────────────────────────────────────────────────────────
// 10. INIT - BINDING DES ÉVÉNEMENTS
// ────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
  var dropzone  = document.getElementById('sm-dropzone');
  var fileInput = document.getElementById('sm-file-input');
  var fileList  = document.getElementById('sm-file-list');

  // ── Dropzone ──
  dropzone.addEventListener('click', function() { fileInput.click(); });
  dropzone.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });

  dropzone.addEventListener('dragover', function(e) {
    e.preventDefault(); dropzone.classList.add('drag-over');
  });
  dropzone.addEventListener('dragleave', function() {
    dropzone.classList.remove('drag-over');
  });
  dropzone.addEventListener('drop', function(e) {
    e.preventDefault(); dropzone.classList.remove('drag-over');
    addFiles(e.dataTransfer.files);
  });

  fileInput.addEventListener('change', function() {
    addFiles(fileInput.files);
    fileInput.value = '';
  });

  // ── Ajouter fichiers ──
  function addFiles(fileList_) {
    var added = 0;
    Array.prototype.forEach.call(fileList_, function(f) {
      if (!f.type.startsWith('image/') && !f.name.match(/\.(jpg|jpeg|png|webp|heic|heif|tiff|tif)$/i)) return;
      SM.files.push({ file: f, result: null, cardEl: null, thumbUrl: null, cleanUrl: null, inspection: null });
      var idx = SM.files.length - 1;
      var card = renderCard(SM.files[idx], idx);
      fileList.appendChild(card);
      // Inspection immédiate : on révèle les métadonnées avant tout nettoyage
      (function(en) { inspectFile(en).then(function() { renderInspection(en); }); })(SM.files[idx]);
      added++;
    });
    if (added) updateActionBar();
  }

  // ── Options qualité ──
  var qualSlider = document.getElementById('sm-quality');
  var qualVal    = document.getElementById('sm-quality-val');
  qualSlider.addEventListener('input', function() {
    SM.quality = parseInt(qualSlider.value);
    qualVal.textContent = qualSlider.value;
  });

  // ── Format de sortie ──
  document.querySelectorAll('.sm-fmt-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.sm-fmt-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      SM.fmt = btn.dataset.fmt;
    });
  });

  // ── Toggle renommer ──
  var renameToggle = document.getElementById('sm-rename-toggle');
  renameToggle.addEventListener('click', function() {
    SM.rename = !SM.rename;
    renameToggle.setAttribute('aria-checked', SM.rename ? 'true' : 'false');
  });
  renameToggle.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') renameToggle.click();
  });

  // ── Nettoyer tout ──
  document.getElementById('sm-process-all').addEventListener('click', processAll);

  // ── Télécharger ZIP ──
  document.getElementById('sm-download-all').addEventListener('click', downloadAllZip);

  // ── Vider ──
  document.getElementById('sm-clear-all').addEventListener('click', function() {
    SM.files.forEach(function(e) {
      if (e.thumbUrl) URL.revokeObjectURL(e.thumbUrl);
      if (e.cleanUrl) URL.revokeObjectURL(e.cleanUrl);
    });
    SM.files = [];
    fileList.innerHTML = '';
    updateActionBar();
    document.getElementById('sm-global-status').textContent = '';
  });

  // ── Guide modal ──
  document.getElementById('smGuideBtn').addEventListener('click', function() {
    document.getElementById('sm-guide-overlay').classList.remove('hidden');
  });
  document.getElementById('smGuideClose').addEventListener('click', function() {
    document.getElementById('sm-guide-overlay').classList.add('hidden');
  });
  document.getElementById('sm-guide-overlay').addEventListener('click', function(e) {
    if (e.target === this) this.classList.add('hidden');
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') document.getElementById('sm-guide-overlay').classList.add('hidden');
  });

  updateActionBar();
});
</script>
