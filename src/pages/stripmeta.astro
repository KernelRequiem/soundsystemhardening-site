    var chunkType = readPngChunkType(src, i+4);

    if (PNG_STRIP_CHUNKS.indexOf(chunkType) !== -1) {
      stripped++;
    } else {
      var chunkTotal = 4 + 4 + dataLen + 4; // len + type + data + crc
      for (var j = i; j < i + chunkTotal; j++) out.push(src[j]);
    }
    i += 4 + 4 + dataLen + 4;
  }

  return { data: new Uint8Array(out), stripped: stripped };
