// ────────────────────────────────────────────────────────────
// 1. PARSEUR EXIF JPEG (pour rapport uniquement)
// ────────────────────────────────────────────────────────────
function parseExifJpeg(buffer) {
  var view = new DataView(buffer);
  var tags = {};
  var gps  = null;

  // Chercher APP1 EXIF
  var i = 2;
  while (i < view.byteLength - 4) {
    var marker = view.getUint16(i);
    if (marker === JPEG_SOS) break;
    if ((marker & 0xFF00) !== 0xFF00) { i++; continue; }
