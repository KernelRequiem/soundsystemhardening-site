function parseExifBlock(buf) {
  var view = new DataView(buf);
  if (buf.byteLength < 8) return { tags: {}, gps: null };

  // Byte order
  var bo = view.getUint16(0);
  var le = (bo === 0x4949); // little-endian = Intel

