var PNG_STRIP_CHUNKS = ['tEXt','iTXt','zTXt','eXIf','gAMA','cHRM',
                        'sRGB','iCCP','bKGD','hIST','pHYs','sPLT',
                        'tIME','oFFs','pCAL','sBIT'];

function readPngChunkType(arr, off) {
  return String.fromCharCode(arr[off], arr[off+1], arr[off+2], arr[off+3]);
}

function cleanPngBinary(buffer) {
  var src = new Uint8Array(buffer);
  if (src.length < 8) return { data: src, stripped: 0 };

  // Vérifier signature PNG
  var sig = [137,80,78,71,13,10,26,10];
  for (var k = 0; k < 8; k++) if (src[k] !== sig[k]) return { data: src, stripped: 0 };

  var out = [];
  // Copier signature
  for (var k = 0; k < 8; k++) out.push(src[k]);

  var i = 8;
  var stripped = 0;

  while (i + 12 <= src.length) {
    var dataLen = (src[i]<<24)|(src[i+1]<<16)|(src[i+2]<<8)|src[i+3];
