          tags['GPS_' + name] = val.trim();
        } else if (type === 3) {
          val = r16(dataOff);
          tags['GPS_' + name] = val;
        } else if (type === 4) {
          val = r32(dataOff);
          tags['GPS_' + name] = val;
        }
