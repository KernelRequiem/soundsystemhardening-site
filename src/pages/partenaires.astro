---
// src/pages/partenaires.astro
// Page legitimite : organisations alliees + orgas referencant le wiki.
// Data-driven : pour ajouter une entree, editer les tableaux ci-dessous.
import Layout from '../layouts/Layout.astro';

// Organisations & ressources alliees referencees par le wiki.
const allies = [
  {
    nom: 'Techno+',
    cat: 'Reduction des risques',
    desc: "Association de prevention et reduction des risques en milieu festif. Reference historique du mouvement.",
    url: 'https://technoplus.org',
  },
  {
    nom: 'La Quadrature du Net',
    cat: 'Libertes numeriques',
    desc: "Defense des droits et libertes a l'ere numerique : surveillance, vie privee, contestation des lois securitaires.",
    url: 'https://www.laquadrature.net',
  },
  {
    nom: 'Disclose',
    cat: 'Journalisme d\'investigation',
    desc: "Media d'investigation a but non lucratif. Enquetes sur la surveillance et l'action de l'Etat.",
    url: 'https://disclose.ngo',
  },
  {
    nom: 'EFF - Surveillance Self-Defense',
    cat: 'OpSec / formation',
    desc: "Guides pratiques d'auto-defense numerique de l'Electronic Frontier Foundation, en francais.",
    url: 'https://ssd.eff.org/fr',
  },
  {
    nom: 'Tails OS',
    cat: 'OpSec / outil',
    desc: "Systeme d'exploitation amnesique sur cle USB, route tout le trafic via Tor. Aucune trace.",
    url: 'https://tails.net/doc/index.fr.html',
  },
  {
    nom: 'Ligue des Droits de l\'Homme',
    cat: 'Droits / juridique',
    desc: "Observation et action contre les violences en rassemblement. Peut se constituer partie civile.",
    url: 'https://www.ldh-france.org',
  },
];

// Organisations qui referencent / relaient officiellement le wiki.
// Vide au depart : remplir au fur et a mesure des partenariats confirmes.
const referrers: { nom: string; url: string; note?: string }[] = [];
---

<Layout
  title="Partenaires & Alliés"
  category="PROJET"
  description="Organisations alliées du wiki SoundSystemHardening : réduction des risques, libertés numériques, défense juridique. Référencer le wiki, devenir partenaire."
>

  <h1>Partenaires & alliés</h1>
  <p class="text-dedsec-muted text-sm font-mono tracking-widest uppercase mb-8">
    ▸ Réseau · Légitimité · Solidarité
  </p>

  <div class="info-box mb-10">
    Cette plateforme ne remplace aucune structure existante. Elle s'appuie sur le travail d'organisations
    qui défendent, chacune sur son terrain, les libertés du mouvement free party : réduction des
    risques, défense juridique, libertés numériques, investigation. Cette page recense ces alliés
    et ouvre la porte à de nouveaux partenariats.
  </div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- 1. ORGANISATIONS & RESSOURCES ALLIÉES                  -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <h2>Organisations & ressources alliées</h2>
  <p>
    Structures dont le travail nourrit ce projet et vers lesquelles nous orientons régulièrement.
    Aucun lien commercial, aucune contrepartie : ce sont des références que nous jugeons fiables.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-8">
    {allies.map(a => (
      <a href={a.url} target="_blank" rel="noopener noreferrer"
         class="card-neon no-underline group block p-5">
        <div class="flex items-start justify-between gap-3 mb-2">
          <span class="text-neon-green font-display font-bold text-lg leading-tight">{a.nom}</span>
          <span class="text-dedsec-muted/50 font-mono text-[13px] shrink-0 group-hover:text-neon-green transition-colors">↗</span>
        </div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-neon-green/70 mb-3">{a.cat}</div>
        <p class="text-dedsec-muted text-sm font-mono leading-relaxed m-0">{a.desc}</p>
      </a>
    ))}
  </div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- 2. ORGAS QUI RÉFÉRENCENT LE WIKI                        -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <h2>Ils nous référencent</h2>
  <p>
    Collectifs, sound systems et organisations qui relaient ou intègrent ce projet dans leurs
    ressources. La liste se construit dans le temps.
  </p>

  {referrers.length > 0 ? (
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 my-8">
      {referrers.map(r => (
        <a href={r.url} target="_blank" rel="noopener noreferrer"
           class="card-neon no-underline text-center p-4 block">
          <div class="text-neon-green font-mono font-bold text-sm">{r.nom}</div>
          {r.note && <div class="text-dedsec-muted/60 text-[10px] font-mono mt-1.5">{r.note}</div>}
        </a>
      ))}
    </div>
  ) : (
    <div class="my-8 border border-dashed border-dedsec-border bg-dedsec-darker/40 p-8 text-center">
      <div class="text-dedsec-muted/50 font-mono text-3xl mb-3">[ &nbsp; ]</div>
      <p class="text-dedsec-muted font-mono text-sm leading-relaxed max-w-md mx-auto mb-1">
        Aucune organisation listée publiquement pour l'instant.
      </p>
      <p class="text-dedsec-muted/60 font-mono text-xs leading-relaxed max-w-md mx-auto">
        Cette section est volontairement ouverte. Tu représentes un collectif, un sound system
        ou une orga qui veut référencer le wiki ? On t'ajoute ici.
      </p>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- 3. CTA PARTENARIAT                                       -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <div class="border border-neon-green/30 bg-neon-green/[0.03] p-6 md:p-8 my-12">
    <div class="text-[10px] font-mono uppercase tracking-widest text-neon-green/70 mb-2">▸ Devenir partenaire</div>
    <h3 class="text-dedsec-text font-display font-bold text-xl mb-3 mt-0">Tu représentes une organisation ?</h3>
    <p class="text-dedsec-muted font-mono text-sm leading-relaxed mb-6 max-w-2xl">
      Association de réduction des risques, collectif, sound system, structure juridique ou média :
      si tu veux référencer le wiki, proposer une ressource, ou monter une collaboration, écris-nous.
      Aucun compte requis, aucune donnée conservée côté site.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="btn-neon">✉ Nous contacter</a>
      <a href="/a-propos" class="btn-neon" style="border-color:rgba(122,122,138,0.4);color:#7a7a8a;">◎ Qui sommes-nous</a>
    </div>
  </div>

  <p class="text-dedsec-muted/50 font-mono text-[11px] leading-relaxed border-t border-dedsec-border pt-4">
    Mention d'une organisation sur cette page = reconnaissance de la qualité de son travail.
    Cela n'implique aucun lien organique, aucune responsabilité mutuelle, aucun financement.
  </p>

</Layout>
