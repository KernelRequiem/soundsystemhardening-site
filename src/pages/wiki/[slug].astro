---
import Layout from '../../layouts/Layout.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { isPublishedSlug } from '../../lib/wikiPages';

const { slug } = Astro.params;

const wikiDir = join(process.cwd(), 'src/content/wiki');
let rawContent = '';

// Allowlist stricte : lettres (accents inclus), chiffres, tiret, underscore,
// apostrophe et esperluette. Tout separateur de chemin (/ \ .) ou sequence
// ".." est exclu de fait, ce qui ferme la traversee de repertoire :
// le slug ne peut plus pointer hors de src/content/wiki.
const isSafeSlug = typeof slug === 'string' && /^[\p{L}\p{N}_'&-]+$/u.test(slug);

// Pages masquées (HIDDEN / fragments / structurelles) ou slug invalide : on
// renvoie vers la page 404 personnalisée (au lieu d'un message maigre en article),
// pour que "dépublier" soit réel et que l'utilisateur ait les bons chemins de secours.
if (!isSafeSlug || !isPublishedSlug(slug as string)) {
  return Astro.redirect('/404', 302);
}
try {
  rawContent = readFileSync(join(wikiDir, `${slug}.md`), 'utf-8');
} catch (e) {
  return Astro.redirect('/404', 302);
}

// Extract title from first H1
const titleMatch = rawContent.match(/^#\s+(.+)$/m);
const title = titleMatch ? titleMatch[1].replace(/[🏠⚠️🎯⚖️📜🔐🎵✊◆◇▸]/g, '').trim() : slug.replace(/-/g, ' ');

// Simple Markdown to HTML renderer
function renderMarkdown(md: string): string {
  let html = md;
  
  // Escape HTML in code blocks first (preserve them)
  const codeBlocks: string[] = [];
  html = html.replace(/```([\s\S]*?)```/g, (match, code) => {
    codeBlocks.push(code);
    return `__CODEBLOCK_${codeBlocks.length - 1}__`;
  });
  
  const inlineCodes: string[] = [];
  html = html.replace(/`([^`]+)`/g, (match, code) => {
    inlineCodes.push(code);
    return `__INLINECODE_${inlineCodes.length - 1}__`;
  });

  // ── Echappement HTML global (anti-XSS stocke) ──────────────────────────────
  // Le contenu wiki provient de contributions Markdown ouvertes (PR GitHub).
  // Sans cet echappement, tout HTML brut (balise script, img onerror=...) injecte
  // dans un .md traversait le renderer et s'executait via set:html cote client,
  // d'autant que le CSP autorise encore 'unsafe-inline'. On neutralise donc tout
  // < > & du source AVANT d'appliquer les transformations Markdown, qui se
  // contentent ensuite d'ajouter leurs propres balises (deja sures).
  html = html
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');

  // Filtre de schema d'URL : seuls http(s), mailto et les liens relatifs sont
  // autorises. Bloque javascript:, data:, vbscript: et echappe les guillemets
  // pour empecher toute evasion d'attribut href/src.
  const safeUrl = (raw: string): string => {
    const url = raw.trim();
    const hasScheme = /^[a-z][a-z0-9+.-]*:/i.test(url);
    const allowed =
      !hasScheme || /^(https?:|mailto:)/i.test(url);
    if (!allowed) return '#';
    return url.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  };

  // Headers (avec ancres GitHub-style pour que le sommaire et les liens
  // profonds fonctionnent : #titre-slugifie)
  const slugifyHeading = (text: string): string =>
    text
      .replace(/[*`]/g, '')                       // marqueurs markdown résiduels
      .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')     // [texte](url) -> texte
      .replace(/<[^>]+>/g, '')                      // balises éventuelles
      .trim()
      .toLowerCase()
      .replace(/[^\p{L}\p{N} \-_]/gu, '')          // ponctuation retirée, accents gardés
      .replace(/ /g, '-');
  const hx = (level: number) => (_m: string, content: string) =>
    `<h${level} id="${slugifyHeading(content)}">${content}</h${level}>`;
  html = html.replace(/^######\s+(.+)$/gm, hx(6));
  html = html.replace(/^#####\s+(.+)$/gm, hx(5));
  html = html.replace(/^####\s+(.+)$/gm, hx(4));
  html = html.replace(/^###\s+(.+)$/gm, hx(3));
  html = html.replace(/^##\s+(.+)$/gm, hx(2));
  html = html.replace(/^#\s+(.+)$/gm, hx(1));
  
  // Bold, italic
  html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
  
  // Images (traitees avant les liens : la syntaxe ![]() contient []())
  html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, (_m, alt, src) => {
    const cleanAlt = String(alt).replace(/"/g, '&quot;');
    return `<img src="${safeUrl(src)}" alt="${cleanAlt}" />`;
  });

  // Links
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_m, text, href) => {
    return `<a href="${safeUrl(href)}">${text}</a>`;
  });
  
  // Horizontal rules
  html = html.replace(/^---+$/gm, '<hr />');
  
  // Blockquotes
  html = html.replace(/^>\s+(.+)$/gm, '<blockquote>$1</blockquote>');
  // Fusionne les lignes de citation consecutives en un seul bloc (en-tete meta,
  // encarts multi-lignes) au lieu d'empiler des boites separees.
  html = html.replace(/(?:<blockquote>.*?<\/blockquote>\n?){2,}/g, (match) => {
    const lines = (match.match(/<blockquote>(.*?)<\/blockquote>/g) || [])
      .map((s) => s.replace(/<\/?blockquote>/g, ''));
    // Le 1er bloc qui commence par un label (Resume, Statut, Mise a jour, Dossier,
    // Page rattachee, Prerequis) recoit la classe meta pour un rendu en fiche.
    const isMeta = /^(Résumé|Resume|Statut|Mise à jour|Derni|Dossier|Page rattach|Prérequis|Prerequis)/i.test(lines[0]);
    const cls = isMeta ? ' class="page-meta"' : '';
    return `<blockquote${cls}>${lines.join('<br />')}</blockquote>`;
  });
  
  // Lists
  html = html.replace(/^(\s*)[-*+]\s+(.+)$/gm, (match, indent, content) => {
    const level = indent.length / 2;
    return `<li data-level="${level}">${content}</li>`;
  });
  html = html.replace(/^(\s*)\d+\.\s+(.+)$/gm, '<oli>$2</oli>');
  
  // Wrap lists
  html = html.replace(/(<li[^>]*>.*?<\/li>(\n|$))+/gs, (match) => {
    return '<ul>' + match.replace(/\n/g, '') + '</ul>';
  });
  html = html.replace(/(<oli>.*?<\/oli>(\n|$))+/gs, (match) => {
    return '<ol>' + match.replace(/<oli>/g, '<li>').replace(/<\/oli>/g, '</li>').replace(/\n/g, '') + '</ol>';
  });
  
  // Tables (basic)
  const tableRegex = /^\|(.+)\|\s*\n\|[\s\-:|]+\|\s*\n((?:\|.+\|\s*\n?)+)/gm;
  html = html.replace(tableRegex, (match, header, rows) => {
    const headers = header.split('|').map((h: string) => h.trim()).filter(Boolean);
    const headerRow = '<tr>' + headers.map((h: string) => `<th>${h}</th>`).join('') + '</tr>';
    const bodyRows = rows.trim().split('\n').map((row: string) => {
      const cells = row.split('|').map(c => c.trim()).filter((_, i, arr) => i > 0 && i < arr.length - 1);
      return '<tr>' + cells.map(c => `<td>${c}</td>`).join('') + '</tr>';
    }).join('');
    return `<table><thead>${headerRow}</thead><tbody>${bodyRows}</tbody></table>`;
  });
  
  // Paragraphs (lines that aren't already wrapped)
  html = html.split('\n\n').map(block => {
    block = block.trim();
    if (!block) return '';
    if (block.match(/^<(h[1-6]|ul|ol|li|blockquote|hr|table|pre|div|img)/)) return block;
    return `<p>${block}</p>`;
  }).join('\n\n');
  
  // Restore code blocks
  html = html.replace(/__CODEBLOCK_(\d+)__/g, (match, i) => {
    const code = codeBlocks[parseInt(i)];
    const lines = code.split('\n');
    const lang = lines[0].trim();
    const codeContent = lang.match(/^[a-z]+$/) ? lines.slice(1).join('\n') : code;
    return `<pre><code>${codeContent.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</code></pre>`;
  });
  
  html = html.replace(/__INLINECODE_(\d+)__/g, (match, i) => {
    return `<code>${inlineCodes[parseInt(i)].replace(/</g, '&lt;').replace(/>/g, '&gt;')}</code>`;
  });
  
  // Convert internal wiki links [[Page]] or wiki-style links
  html = html.replace(/\[\[([^\]]+)\]\]/g, (match, page) => {
    const slug = encodeURIComponent(String(page).trim().replace(/\s+/g, '-'));
    const label = String(page).replace(/"/g, '&quot;');
    return `<a href="/wiki/${slug}">${label}</a>`;
  });
  
  return html;
}

const htmlContent = renderMarkdown(rawContent);

// Get category from slug
// Correspondance exacte slug -> categorie, alignee sur les sections de /wiki.
// Chaque page du wiki est ainsi rattachee a une categorie, sans page orpheline.
const CATEGORY_MAP: Record<string, string> = {
  // Démarrer
  'Guide-du-site': 'DÉMARRER',
  // Terrain critique
  'Urgence-immédiate': 'URGENCE',
  'Repression': 'RÉPRESSION',
  'Contestation': 'JURIDIQUE',
  // Arsenal juridique
  'arsenal-legislatif': 'JURIDIQUE',
  'jurisprudence': 'JURIDIQUE',
  'recours-juridiques': 'JURIDIQUE',
  'ripost': 'CONTRE RIPOST',
  'Strategie-contre-ripost': 'CONTRE RIPOST',
  // Modus operandi
  'Modus-Operandi': 'SUR LE TERRAIN',
  'Zones-Grises-Failles': 'SUR LE TERRAIN',
  'ZAD-Pourquoi-État-Evite': 'SUR LE TERRAIN',
  'Propriete-Privee-Fermee': 'SUR LE TERRAIN',
  'Terrains-Abandonnes': 'SUR LE TERRAIN',
  'Espaces-Semi-Publics': 'SUR LE TERRAIN',
  'Zones-Limitrophes': 'SUR LE TERRAIN',
  'Definition-Ambigue-Organisateur': 'SUR LE TERRAIN',
  'Seuil-250-500-Personnes': 'SUR LE TERRAIN',
  'Rassemblement-vs-Manifestation': 'SUR LE TERRAIN',
  'Declaration-Preuve-Legitimite': 'SUR LE TERRAIN',
  'Prescription-et-Delais': 'SUR LE TERRAIN',
  'Manque-de-Ressources': 'SUR LE TERRAIN',
  'Coordination-Defaillante': 'SUR LE TERRAIN',
  'Autorisation-Locale-Tacite': 'SUR LE TERRAIN',
  'Couverture-Mediatique-Dissuasive': 'SUR LE TERRAIN',
  'Presence-Temoins-Neutralisante': 'SUR LE TERRAIN',
  'Techniques-Contournement': 'SUR LE TERRAIN',
  'Camouflage-Evenement': 'SUR LE TERRAIN',
  'Fragmentation-Geographique': 'SUR LE TERRAIN',
  'Coordination-Decentralisee': 'SUR LE TERRAIN',
  'Documentation-Preemptive': 'SUR LE TERRAIN',
  'Declaration-Strategique': 'SUR LE TERRAIN',
  // Etudes de cas
  'Carhaix-Pourquoi-Intervention': 'ÉTUDES DE CAS',
  'Redon-Messe-Techno': 'ÉTUDES DE CAS',
  'Phalsbourg-Succes-Absence-Intervention': 'ÉTUDES DE CAS',
  'Teknival-Marigny-Avant-Apres': 'ÉTUDES DE CAS',
  // Securite numerique
  'Sécurite-Numerique': 'OPSEC',
  'wiki-opsec': 'OPSEC',
  'threat-model': 'OPSEC',
  'Sécurité-des-communications': 'OPSEC',
  'messagerie-chiffree': 'OPSEC',
  'reseau-anonymisation': 'OPSEC',
  'darknet-pgp-anonymat': 'OPSEC',
  'surveillance-mobile': 'OPSEC',
  'metadonnees-exif': 'OPSEC',
  'identites-numeriques': 'OPSEC',
  'compartimentation': 'OPSEC',
  'wiki-ports-reseau': 'OPSEC',
  // Strategie de resistance
  'Stratégie-résistance': 'STRATÉGIE',
  'Juridique': 'STRATÉGIE',
  'Politique': 'STRATÉGIE',
  'Sanitaire': 'STRATÉGIE',
  'Axe-sanitaire': 'STRATÉGIE',
  'Organisationnel': 'STRATÉGIE',
  'Culturel': 'STRATÉGIE',
  'Coalitions': 'STRATÉGIE',
  // Mobilisation
  'Mobilisation': 'MOBILISATION',
  'Templates-Recours': 'MOBILISATION',
  'Contacts-Allies': 'MOBILISATION',
  'Argumentaires': 'MOBILISATION',
  'Manifesto': 'MOBILISATION',
  // Histoire & culture
  'Histoire-&-Culture': 'HISTOIRE & CULTURE',
  "L'esprit-des-teufeurs": 'HISTOIRE & CULTURE',
  'Chronologie': 'HISTOIRE & CULTURE',
  'Sound-System': 'HISTOIRE & CULTURE',
  'Incidents-répressifs': 'HISTOIRE & CULTURE',
  'Patrimoine-culturel': 'HISTOIRE & CULTURE',
  'Medias-Propriete': 'MÉDIAS',
  // Veille
  "Vue-d'ensemble-veille": 'VEILLE',
  'Lois-En-Cours': 'VEILLE',
  'Actualites-Repressions': 'VEILLE',
  'Sources-Fiables': 'VEILLE',
  'Changelog': 'VEILLE',
};

function getCategory(slug: string): string {
  return CATEGORY_MAP[slug] ?? 'WIKI';
}

const category = getCategory(slug);
---

<Layout title={title} description={`${title} - SoundSystemHardening Wiki`} category={category}>
  <div class="wiki-kicker">
    <span class="wiki-kicker-badge">{category}</span>
    <span class="wiki-kicker-line"></span>
    <a href="/wiki" class="wiki-kicker-index">Index du wiki</a>
  </div>
  <article class="prose-dedsec" set:html={htmlContent} />

  <!-- Article footer -->
  <div class="mt-16 pt-8 border-t border-dedsec-border">
    <div class="flex flex-wrap items-center justify-between gap-4 text-xs font-mono text-dedsec-muted">
      <div>
        ▸ <span class="text-neon-green">LICENSE</span> : CC BY-SA 4.0
      </div>
      <div>
        ▸ <a href="/" class="text-neon-green">← Retour accueil</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Wiki content specific styles */
  article :global(h1) {
    @apply text-3xl mb-6 mt-0;
  }

  article :global(table) {
    @apply text-sm;
  }

  article :global(img) {
    @apply max-w-full h-auto rounded-lg my-4 border border-dedsec-border;
  }

  /* ── Bandeau categorie au-dessus du titre ── */
  .wiki-kicker {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 22px;
  }
  .wiki-kicker-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #00ff9f;
    border: 1px solid rgba(0, 255, 159, 0.3);
    background: rgba(0, 255, 159, 0.05);
    padding: 4px 10px;
    white-space: nowrap;
  }
  .wiki-kicker-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(0, 255, 159, 0.25), transparent);
  }
  .wiki-kicker-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(122, 122, 138, 0.7);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .wiki-kicker-index:hover { color: #00ff9f; }

  /* ── Fiche meta en tete de page (Resume / Statut / Mise a jour) ── */
  article :global(blockquote.page-meta) {
    border-left: none;
    border: 1px solid rgba(42, 42, 58, 0.8);
    border-top: 2px solid rgba(0, 255, 159, 0.45);
    background:
      linear-gradient(180deg, rgba(0, 255, 159, 0.04) 0%, rgba(8, 8, 12, 0.4) 100%);
    padding: 16px 20px;
    margin: 0 0 28px;
    font-family: 'JetBrains Mono', monospace;
    font-style: normal;
    font-size: 12px;
    line-height: 2;
    color: rgba(190, 190, 205, 0.92);
    letter-spacing: 0.01em;
  }
  /* Met en relief les libelles avant le premier deux-points de chaque ligne */
  article :global(blockquote.page-meta br) { content: ""; }

  /* ── Ancres de titres : pastille au survol ── */
  article :global(h2),
  article :global(h3) { scroll-margin-top: 90px; position: relative; }
  article :global(h2)::before {
    content: "";
    position: absolute;
    left: -14px;
    top: 0.15em;
    height: 0.85em;
    width: 3px;
    background: rgba(0, 255, 159, 0.55);
  }

  /* ── Liste premium : puces neon ── */
  article :global(.prose-dedsec ul > li::marker) { color: rgba(0, 255, 159, 0.6); }

  /* ── Dernier paragraphe Voir aussi / Sources : respiration ── */
  article :global(hr) { opacity: 0.5; }
</style>
