---
import Layout from '../../layouts/Layout.astro';
import { ripostStatus } from '../../data/ripost-status';
---

<Layout
  title="RIPOST"
  description="Guide opérationnel contre la loi RIPOST : AFD, droits terrain, stratégies de résistance, ressources et contacts."
  category="CONTRE RIPOST"
>

<style is:global>

  /* ══════════════════════════════════════════════════════
     RIPOST - DESIGN SYSTEM
     Typo : Bebas Neue (titres) · Space Grotesk (corps) · JetBrains Mono (codes)
  ══════════════════════════════════════════════════════ */

  .rp-header {
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(42,42,58,0.60);
    position: relative;
  }
  .rp-header::before {
    content: '';
    position: absolute;
    left: -28px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, #ff4444 0%, rgba(255,68,68,0.03) 100%);
  }

  .rp-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,68,68,0.90);
    border: 1px solid rgba(255,68,68,0.28);
    background: rgba(255,68,68,0.04);
    padding: 4px 12px;
    margin-bottom: 16px;
  }

  .rp-title {
    font-family: 'Bebas Neue', sans-serif !important;
    font-size: 64px !important;
    color: #e8e8f0 !important;
    letter-spacing: 0.08em !important;
    line-height: 1 !important;
    margin: 0 0 12px !important;
    padding: 0 !important;
    border: none !important;
  }

  .rp-subtitle {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    color: rgba(210,210,224,0.92);
    line-height: 1.65;
    margin-bottom: 22px;
    max-width: 680px;
  }

  /* Status banner */
  .rp-status {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: rgba(255,230,0,0.03);
    border: 1px solid rgba(255,230,0,0.15);
    border-left: 3px solid rgba(255,200,0,0.60);
    padding: 16px 20px;
    margin-bottom: 0;
  }
  .rp-status-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    background: #ffd600;
    box-shadow: 0 0 8px #ffd600;
    flex-shrink: 0;
    margin-top: 5px;
    animation: rp-pulse 2s ease-in-out infinite;
  }
  @keyframes rp-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.45; }
  }
  .rp-status-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(255,214,0,0.65);
    margin-bottom: 4px;
  }
  .rp-status-main {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #e8e8f0;
    margin-bottom: 5px;
  }
  .rp-status-main em {
    font-style: normal;
    color: #ffd600;
  }
  .rp-status-sub {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(205,205,220,0.92);
    line-height: 1.60;
  }
  .rp-status-sub strong { color: #00ff9f; }
  .rp-petition-btn {
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,214,0,0.72);
    border: 1px solid rgba(255,214,0,0.28);
    padding: 9px 14px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
    display: none;
  }
  .rp-petition-btn:hover {
    color: #ffd600;
    border-color: rgba(255,214,0,0.60);
    background: rgba(255,214,0,0.04);
  }
  @media (min-width: 600px) { .rp-petition-btn { display: inline-block; } }

  /* Bloc partage : faire circuler l'alerte */
  .rp-share {
    display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
    margin-bottom: clamp(48px, 6vw, 68px);
    padding: 16px 18px;
    border: 1px solid rgba(0,255,159,0.3);
    border-left: 3px solid #00ff9f;
    background: linear-gradient(180deg, rgba(0,255,159,0.05), rgba(8,8,12,0.4));
  }
  .rp-share-text { flex: 1; min-width: 220px; }
  .rp-share-title { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #00ff9f; margin-bottom: 5px; }
  .rp-share-sub { font-family: 'Space Grotesk', sans-serif; font-size: 13px; line-height: 1.55; color: rgba(210,210,224,0.85); margin: 0; }
  #rp-share-btn {
    flex-shrink: 0; display: inline-flex; align-items: center; gap: 9px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;
    color: #06120d; background: #00ff9f; border: none; border-radius: 3px; padding: 12px 20px;
    transition: box-shadow 0.2s, transform 0.15s;
  }
  #rp-share-btn:hover { transform: translateY(-1px); box-shadow: 0 0 0 1px rgba(0,255,159,0.5), 0 10px 28px -12px rgba(0,255,159,0.7); }
  .rp-share-glyph { font-size: 14px; }

  /* Section wrapper */
  .rp-section {
    margin-bottom: clamp(48px, 6vw, 68px);
  }
  .rp-section-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(0,255,159,0.7);
    margin-bottom: 10px;
  }
  .rp-section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 30px;
    color: #e8e8f0;
    letter-spacing: 0.06em;
    line-height: 1.05;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(42,42,58,0.5);
  }

  /* Comparatif avant/après */
  .rp-compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid rgba(42,42,58,0.70);
    overflow: hidden;
  }
  @media (max-width: 560px) { .rp-compare-grid { grid-template-columns: 1fr; } }

  .rp-col {
    padding: 24px;
    background: rgba(8,8,12,0.70);
  }
  .rp-col-left { border-right: 1px solid rgba(42,42,58,0.60); }
  .rp-col-right { border-left: 3px solid rgba(255,68,68,0.50); }

  .rp-col-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .rp-col-label.ok { color: rgba(0,255,159,0.65); }
  .rp-col-label.ko { color: rgba(255,68,68,0.65); }

  .rp-compare-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(42,42,58,0.40);
  }
  .rp-compare-row:last-child { border-bottom: none; }
  .rp-compare-lbl {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(205,205,220,0.90);
  }
  .rp-compare-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    text-align: right;
  }
  .rp-compare-sub {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px;
    color: rgba(122,122,138,0.65);
    text-align: right;
    margin-top: 2px;
  }
  .val-green { color: #00ff9f; }
  .val-red   { color: #ff4444; }

  .rp-note {
    border-left: 3px solid rgba(122,122,138,0.25);
    background: rgba(8,8,12,0.50);
    padding: 12px 16px;
    margin-top: 0;
    border-top: none;
    border-right: 1px solid rgba(42,42,58,0.50);
    border-bottom: 1px solid rgba(42,42,58,0.50);
  }
  .rp-note-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    color: rgba(180,180,200,0.88);
    line-height: 1.60;
  }
  .rp-note-text strong { color: rgba(255,68,68,0.88); }
  .rp-note-text em { font-style: normal; color: rgba(200,200,220,0.75); }

  /* AFD décision flowchart */
  .rp-flow {
    border: 1px solid rgba(42,42,58,0.70);
    background: rgba(8,8,12,0.70);
    padding: 28px;
  }
  .rp-flow-start {
    text-align: center;
    margin-bottom: 20px;
  }
  .rp-flow-start-box {
    display: inline-block;
    border: 1px solid rgba(122,122,138,0.35);
    background: rgba(20,20,30,0.80);
    padding: 14px 24px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #e8e8f0;
  }
  .rp-flow-arrow {
    display: flex;
    justify-content: center;
    margin: 12px 0;
  }
  .rp-flow-arrow::after {
    content: '↓';
    font-family: 'JetBrains Mono', monospace;
    font-size: 18px;
    color: rgba(122,122,138,0.50);
  }
  .rp-flow-choice {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }
  @media (max-width: 560px) { .rp-flow-choice { grid-template-columns: 1fr; } }

  .rp-flow-bad {
    border: 1px solid rgba(255,68,68,0.22);
    border-top: 3px solid rgba(255,68,68,0.55);
    background: rgba(255,68,68,0.03);
    padding: 20px;
  }
  .rp-flow-good {
    border: 1px solid rgba(0,255,159,0.22);
    border-top: 3px solid rgba(0,255,159,0.55);
    background: rgba(0,255,159,0.03);
    padding: 20px;
  }

  .rp-flow-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .rp-flow-tag.bad { color: rgba(255,68,68,0.60); }
  .rp-flow-tag.good { color: rgba(0,255,159,0.60); }

  .rp-flow-choice-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .rp-flow-choice-title.bad { color: #ff4444; }
  .rp-flow-choice-title.good { color: #00ff9f; }

  .rp-flow-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(210,210,224,0.94);
    margin-bottom: 6px;
    line-height: 1.50;
  }
  .rp-flow-item .icon-bad  { color: #ff4444; flex-shrink: 0; }
  .rp-flow-item .icon-good { color: #00ff9f; flex-shrink: 0; }

  .rp-flow-sub {
    background: rgba(12,12,18,0.80);
    border: 1px solid rgba(42,42,58,0.55);
    border-left: 3px solid rgba(0,255,159,0.25);
    padding: 20px;
  }
  .rp-flow-sub-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(122,122,138,0.55);
    margin-bottom: 14px;
  }
  .rp-flow-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  @media (max-width: 560px) { .rp-flow-options { grid-template-columns: 1fr; } }

  .rp-flow-opt {
    background: rgba(8,8,12,0.80);
    border: 1px solid rgba(42,42,58,0.55);
    padding: 16px;
  }
  .rp-flow-opt-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(122,122,138,0.55);
    margin-bottom: 6px;
  }
  .rp-flow-opt-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #e8e8f0;
    margin-bottom: 8px;
  }
  .rp-flow-opt-body {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    color: rgba(140,140,165,0.80);
    line-height: 1.60;
  }
  .rp-flow-opt-body em { font-style: normal; color: rgba(255,200,0,0.85); }

  /* Faille technique */
  .rp-faille {
    margin-top: 16px;
    border: 1px solid rgba(0,255,159,0.18);
    border-left: 3px solid rgba(0,255,159,0.50);
    background: rgba(0,255,159,0.03);
    padding: 14px 18px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .rp-faille-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(0,255,159,0.65);
    flex-shrink: 0;
    padding-top: 3px;
  }
  .rp-faille-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(210,210,224,0.93);
    line-height: 1.60;
  }
  .rp-faille-text strong { color: #00ff9f; }

  /* 4 réflexes */
  .rp-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  @media (max-width: 560px) { .rp-cards { grid-template-columns: 1fr; } }

  .rp-card {
    background: rgba(8,8,12,0.80);
    border: 1px solid rgba(42,42,58,0.60);
    border-top: 3px solid rgba(0,255,159,0.45);
    padding: 22px;
    transition: border-top-color 0.20s, transform 0.20s;
  }
  .rp-card:hover {
    border-top-color: rgba(0,255,159,0.85);
    transform: translateY(-2px);
  }
  .rp-card-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(0,255,159,0.45);
    margin-bottom: 8px;
  }
  .rp-card-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: #e8e8f0;
    letter-spacing: 0.05em;
    margin-bottom: 14px;
    line-height: 1.1;
  }
  .rp-card-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(210,210,224,0.94);
    margin-bottom: 7px;
    line-height: 1.50;
  }
  .rp-card-item-arrow {
    color: rgba(0,255,159,0.65);
    flex-shrink: 0;
    font-size: 11px;
    padding-top: 1px;
  }
  .rp-card-note {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid rgba(42,42,58,0.50);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: rgba(0,255,159,0.55);
  }

  /* Mobilisation collective */
  .rp-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid rgba(42,42,58,0.60);
    overflow: hidden;
  }
  .rp-action {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 22px 24px;
    background: rgba(8,8,12,0.70);
    border-bottom: 1px solid rgba(42,42,58,0.45);
    transition: background 0.15s;
  }
  .rp-action:last-child { border-bottom: none; }
  .rp-action:hover { background: rgba(0,255,159,0.02); }
  .rp-action-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    color: rgba(0,255,159,0.40);
    flex-shrink: 0;
    min-width: 32px;
  }
  .rp-action-body {}
  .rp-action-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #e8e8f0;
    margin-bottom: 6px;
  }
  .rp-action-desc {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(155,155,180,0.85);
    line-height: 1.60;
  }
  .rp-action-desc strong { color: #00ff9f; }

  /* Ressources */
  .rp-resources {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid rgba(42,42,58,0.60);
  }
  @media (max-width: 680px) { .rp-resources { grid-template-columns: 1fr; } }

  .rp-res-col {
    padding: 22px;
    background: rgba(8,8,12,0.70);
    border-right: 1px solid rgba(42,42,58,0.45);
  }
  .rp-res-col:last-child { border-right: none; }

  .rp-res-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(0,255,159,0.55);
    margin-bottom: 18px;
  }
  .rp-res-item { margin-bottom: 18px; }
  .rp-res-item:last-child { margin-bottom: 0; }
  .rp-res-link {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #00ff9f;
    text-decoration: none;
    margin-bottom: 4px;
    transition: color 0.12s;
  }
  .rp-res-link:hover { color: rgba(0,255,159,0.70); }
  .rp-res-desc {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    color: rgba(122,122,138,0.80);
    line-height: 1.55;
  }
  .rp-res-contact {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: rgba(100,100,120,0.65);
    margin-top: 3px;
  }

  /* Matrice */
  .rp-matrix {
    border: 1px solid rgba(42,42,58,0.60);
    overflow-x: auto;
  }
  .rp-matrix table {
    width: 100%;
    border-collapse: collapse;
  }
  .rp-matrix th {
    padding: 12px 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(122,122,138,0.55);
    background: rgba(12,12,20,0.90);
    border-bottom: 1px solid rgba(42,42,58,0.65);
    text-align: left;
    white-space: nowrap;
  }
  .rp-matrix td {
    padding: 13px 18px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(205,205,220,0.92);
    border-bottom: 1px solid rgba(42,42,58,0.35);
    vertical-align: top;
    line-height: 1.50;
  }
  .rp-matrix tr:last-child td { border-bottom: none; }
  .rp-matrix tr:nth-child(odd) td { background: rgba(8,8,12,0.55); }
  .rp-matrix tr:nth-child(even) td { background: rgba(10,10,16,0.55); }
  .rp-matrix .col-action {
    color: #e8e8f0;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rp-matrix .m-ok  { color: #00ff9f; font-size: 15px; }
  .rp-matrix .m-bad { color: #ff4444; font-size: 15px; }
  .rp-matrix .m-mid { color: rgba(255,200,0,0.80); font-size: 15px; }

  /* Footer */
  .rp-footer {
    border-top: 1px solid rgba(42,42,58,0.55);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  @media (min-width: 600px) {
    .rp-footer { flex-direction: row; justify-content: space-between; align-items: center; }
  }
  .rp-footer-credits {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.10em;
    color: rgba(100,100,120,0.55);
  }
  .rp-footer-links {
    display: flex;
    gap: 20px;
  }
  .rp-footer-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(122,122,138,0.55);
    text-decoration: none;
    transition: color 0.12s;
  }
  .rp-footer-link:hover { color: #00ff9f; }

</style>

<!-- ══════════════════════════════════════════════════
     EN-TÊTE
═══════════════════════════════════════════════════ -->
<div class="not-prose rp-header">
  <div class="rp-badge">⚖ LOI EN COURS D'ADOPTION</div>
  <h1 class="rp-title">RIPOST</h1>
  <p class="rp-subtitle">
    Le projet de loi RIPOST veut criminaliser les free parties. Voici ce que ça change, comment résister, et comment contester une amende forfaitaire.
  </p>

  <div class="rp-status">
    <span class="rp-status-dot"></span>
    <div style="flex:1">
      <div class="rp-status-date">Statut vérifié le {ripostStatus.lastChecked}</div>
      <div class="rp-status-main">RIPOST <em>{ripostStatus.inForce ? 'est en vigueur' : "n'est pas encore en vigueur"}</em></div>
      <div class="rp-status-sub">
        {ripostStatus.currentStage}
        <br />{ripostStatus.currentLaw}
      </div>
    </div>
    <a href="https://petitions.assemblee-nationale.fr/initiatives/i-5428" target="_blank" rel="noopener" class="rp-petition-btn">
      ✎ Signer la pétition
    </a>
  </div>
</div>

<!-- ══════════════════════════════════════════════════
     PARTAGE · faire circuler l'alerte (diffusion)
═══════════════════════════════════════════════════ -->
<div class="not-prose rp-share">
  <div class="rp-share-text">
    <div class="rp-share-title">▸ Fais circuler l'info</div>
    <p class="rp-share-sub">Une personne avertie sait quoi faire face à un contrôle. Partage cette page sur tes canaux (Signal, Telegram, bouche-à-oreille).</p>
  </div>
  <button type="button" id="rp-share-btn"
    data-share-url="https://soundsystemhardening.fr/wiki/ripost"
    data-share-text="Loi RIPOST contre les free parties : tes droits et quoi faire si tu es contrôlé. Ne paie pas sur place, ne signe rien.">
    <span class="rp-share-glyph" aria-hidden="true">⇄</span>
    <span id="rp-share-label">Partager l'alerte</span>
  </button>
</div>

<script>
  (function () {
    const btn = document.getElementById('rp-share-btn');
    const label = document.getElementById('rp-share-label');
    if (!btn || !label) return;
    const url = btn.getAttribute('data-share-url') || '';
    const text = btn.getAttribute('data-share-text') || '';
    btn.addEventListener('click', async () => {
      // Web Share API (mobile) : ouvre le partage natif (Signal, Telegram…)
      if (navigator.share) {
        try { await navigator.share({ title: 'RIPOST · SoundSystemHardening', text, url }); return; } catch { /* annulé */ }
      }
      // Repli desktop : copie le message + lien dans le presse-papier
      try {
        await navigator.clipboard.writeText(text + ' ' + url);
        const o = label.textContent; label.textContent = '✓ Lien copié';
        setTimeout(() => { label.textContent = o; }, 2200);
      } catch {
        label.textContent = 'Copie : ' + url;
      }
    });
  })();
</script>


