---
import Layout from '../../layouts/Layout.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { listWikiSlugs } from '../../lib/wikiPages';

// Lit le titre H1 depuis un fichier markdown
function getTitle(slug: string): string {
  try {
    const content = readFileSync(
      join(process.cwd(), 'src/content/wiki', `${slug}.md`),
      'utf-8'
    );
    const m = content.match(/^#\s+(.+)$/m);
    return m ? m[1].trim() : slug.replace(/-/g, ' ');
  } catch {
    return slug.replace(/-/g, ' ');
  }
}

// Lit la première ligne **bold** comme sous-titre
function getSub(slug: string): string {
  try {
    const content = readFileSync(
      join(process.cwd(), 'src/content/wiki', `${slug}.md`),
      'utf-8'
    );
    const m = content.match(/^\*\*([^*]{15,90})\*\*/m);
    return m ? m[1].trim() : '';
  } catch {
    return '';
  }
}

// Liste dynamique partagée : même source que le compteur de la home et la
// recherche, pour un nombre de pages identique et calculé sur les vraies data.
const allFiles: Set<string> = new Set(listWikiSlugs());

type Page = { slug: string; title: string; sub: string };

function pages(slugs: string[]): Page[] {
  return slugs
    .filter(s => allFiles.has(s))
    .map(s => ({ slug: s, title: getTitle(s), sub: getSub(s) }));
}

const sections = [
  {
    key: 'demarrer',
    label: 'DÉMARRER ICI',
    desc: 'Nouveau sur le site ? Comment tout fonctionne, le wiki et chaque outil, expliqué simplement.',
    accent: '#00ff9f',
    slugs: [
      'Guide-du-site',
    ],
  },
  {
    key: 'critique',
    label: 'TERRAIN CRITIQUE',
    desc: 'Ressources opérationnelles pour les situations de pression ou d\'urgence directe.',
    accent: '#ff4444',
    slugs: [
      'Urgence-immédiate',
      'Repression',
      'Contestation',
    ],
  },
  {
    key: 'juridique',
    label: 'ARSENAL JURIDIQUE',
    desc: 'Cadre légal, décisions de justice, voies de recours et stratégie contre RIPOST.',
    accent: '#00ff9f',
    slugs: [
      'arsenal-legislatif',
      'jurisprudence',
      'recours-juridiques',
      'ripost',
      'Strategie-contre-ripost',
    ],
  },
  {
    key: 'operandi',
    label: 'SUR LE TERRAIN',
    desc: 'Zones grises, failles légales et pratiques, tactiques de contournement.',
    accent: '#00ff9f',
    slugs: [
      'Modus-Operandi',
      'Zones-Grises-Failles',
      'ZAD-Pourquoi-État-Evite',
      'Propriete-Privee-Fermee',
      'Terrains-Abandonnes',
      'Espaces-Semi-Publics',
      'Zones-Limitrophes',
      'Definition-Ambigue-Organisateur',
      'Seuil-250-500-Personnes',
      'Rassemblement-vs-Manifestation',
      'Declaration-Preuve-Legitimite',
      'Prescription-et-Delais',
      'Manque-de-Ressources',
      'Coordination-Defaillante',
      'Autorisation-Locale-Tacite',
      'Couverture-Mediatique-Dissuasive',
      'Presence-Temoins-Neutralisante',
      'Techniques-Contournement',
      'Camouflage-Evenement',
      'Fragmentation-Geographique',
      'Coordination-Decentralisee',
      'Documentation-Preemptive',
      'Declaration-Strategique',
    ],
  },
  {
    key: 'casdetude',
    label: 'ÉTUDES DE CAS',
    desc: 'Analyses d\'interventions documentées : pourquoi l\'État agit ou s\'abstient.',
    accent: '#ff4444',
    slugs: [
      'Carhaix-Pourquoi-Intervention',
      'Redon-Messe-Techno',
      'Teknival-Marigny-Avant-Apres',
    ],
  },
  {
    key: 'opsec',
    label: 'SÉCURITÉ NUMÉRIQUE',
    desc: 'OPSEC, chiffrement, anonymisation réseau, messagerie sécurisée et surveillance mobile.',
    accent: '#00ff9f',
    slugs: [
      'Sécurite-Numerique',
      'wiki-opsec',
      'threat-model',
      'Sécurité-des-communications',
      'messagerie-chiffree',
      'reseau-anonymisation',
      'darknet-pgp-anonymat',
      'surveillance-mobile',
      'metadonnees-exif',
      'identites-numeriques',
      'compartimentation',
      'wiki-ports-reseau',
    ],
  },
  {
    key: 'strategie',
    label: 'STRATÉGIE DE RÉSISTANCE',
    desc: 'Vue d\'ensemble et axes de résistance : juridique, politique, sanitaire, culturel.',
    accent: '#00ff9f',
    slugs: [
      'Stratégie-résistance',
      'Juridique',
      'Politique',
      'Sanitaire',
      'Organisationnel',
      'Culturel',
      'Coalitions',
    ],
  },
  {
    key: 'mobilisation',
    label: 'MOBILISATION',
    desc: 'Contacts alliés, templates de recours, argumentaires et manifeste.',
    accent: '#e8e8f0',
    slugs: [
      'Mobilisation',
      'Templates-Recours',
      'Contacts-Allies',
      'Argumentaires',
      'Manifesto',
    ],
  },
  {
    key: 'culture',
    label: 'HISTOIRE & CULTURE',
    desc: 'Mémoire du mouvement, chronologie, patrimoine sonore et incidents répressifs.',
    accent: '#e8e8f0',
    slugs: [
      'Histoire-&-Culture',
      "L'esprit-des-teufeurs",
      'Chronologie',
      'Sound-System',
      'Incidents-répressifs',
      'Patrimoine-culturel',
      'Medias-Propriete',
    ],
  },
  {
    key: 'veille',
    label: 'VEILLE',
    desc: 'Anticipation législative, actualités de la répression, sources et changelog.',
    accent: '#e8e8f0',
    slugs: [
      "Vue-d'ensemble-veille",
      'Lois-En-Cours',
      'Actualites-Repressions',
      'Sources-Fiables',
      'Changelog',
    ],
  },
];

// Pages non catégorisées
const categorizedSlugs = new Set(sections.flatMap(s => s.slugs));
const uncategorized = [...allFiles].filter(f => !categorizedSlugs.has(f)).sort();

const totalPages = allFiles.size;
---

<Layout
  title="Wiki"
  description={`Index complet du wiki SoundSystemHardening - ${totalPages} pages sur les droits, l'opsec et la résistance free party.`}
  category="WIKI"
>

  <!-- En-tête -->
  <div class="mb-10 not-prose">
    <div class="font-mono text-[11px] tracking-[0.25em] text-neon-green/70 uppercase mb-2">soundsystemhardening.fr / wiki</div>
    <h1 class="font-display font-bold text-2xl text-dedsec-text m-0 leading-tight">Base de connaissances</h1>
    <p class="font-mono text-[11px] text-dedsec-muted mt-2 mb-0">
      {totalPages} pages &middot; {sections.length} sections &middot; CC BY-SA 4.0 &middot; MAJ juin 2026
    </p>
  </div>

  <!-- Accès rapide -->
  <div class="not-prose grid grid-cols-1 sm:grid-cols-3 gap-px bg-dedsec-border mb-12">
    {[
      {
        href: '/urgence',
        label: 'URGENCE',
        desc: 'Réflexes par situation critique',
        accent: '#ff4444',
        icon: '▲',
      },
      {
        href: '/wiki/ripost',
        label: 'CONTRE RIPOST',
        desc: 'Résistance juridique et collective',
        accent: '#00ff9f',
        icon: '↺',
      },
      {
        href: '/wiki/Contestation',
        label: 'CONTESTATION',
        desc: 'Contester une amende étape par étape',
        accent: '#e8e8f0',
        icon: '◈',
      },
    ].map(item => (
      <a
        href={item.href}
        class="group bg-dedsec-darker px-5 py-4 no-underline flex items-start gap-3 hover:bg-dedsec-gray/30 transition-colors"
        style={`border-left: 2px solid ${item.accent};`}
      >
        <span class="font-mono text-base mt-px flex-shrink-0" style={`color:${item.accent}`}>{item.icon}</span>
        <div>
          <div class="font-mono text-[12px] font-bold tracking-widest mb-0.5" style={`color:${item.accent}`}>
            {item.label}
          </div>
          <div class="font-mono text-[11px] text-dedsec-muted group-hover:text-dedsec-text/80 transition-colors leading-relaxed">
            {item.desc}
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Sections -->
  {sections.map(section => {
    const sectionPages = pages(section.slugs);
    if (sectionPages.length === 0) return null;
    return (
      <div class="not-prose mb-12">

        <!-- Header section -->
        <div class="flex items-start gap-3 mb-4">
          <div
            class="w-[2px] flex-shrink-0 mt-1"
            style={`height:2.5rem; background:${section.accent}; box-shadow:0 0 8px ${section.accent}60;`}
          />
          <div>
            <div class="font-mono text-[10px] tracking-[0.28em] mb-1" style={`color:${section.accent}`}>
              {section.key.toUpperCase()} &middot; {sectionPages.length} pages
            </div>
            <div class="font-display font-bold text-base text-dedsec-text leading-tight tracking-wide">
              {section.label}
            </div>
            <div class="font-mono text-[11px] text-dedsec-muted mt-0.5 leading-relaxed">
              {section.desc}
            </div>
          </div>
        </div>

        <!-- Grille de pages -->
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px ml-5"
          style="background-color: #2a2a3a;"
        >
          {sectionPages.map(page => (
            <a
              href={`/wiki/${page.slug}`}
              class="group bg-dedsec-darker px-4 py-3 no-underline flex items-center gap-2.5 hover:bg-dedsec-gray/30 transition-colors min-w-0"
            >
              <span
                class="flex-shrink-0 font-mono text-[10px] transition-colors"
                style={`color:${section.accent}60`}
              >▸</span>
              <span class="font-mono text-[12px] text-dedsec-text/85 group-hover:text-dedsec-text transition-colors truncate leading-snug">
                {page.title}
              </span>
            </a>
          ))}
        </div>

      </div>
    );
  })}

  <!-- Pages non catégorisées (filet de sécurité) -->
  {uncategorized.length > 0 && (
    <div class="not-prose mb-12">
      <div class="flex items-start gap-3 mb-4">
        <div class="w-[2px] flex-shrink-0 mt-1" style="height:2.5rem; background:#7a7a8a;"/>
        <div>
          <div class="font-mono text-[9px] tracking-[0.35em] text-dedsec-muted/50 mb-1">
            AUTRES &middot; {uncategorized.length} pages
          </div>
          <div class="font-display font-bold text-base text-dedsec-text/60 leading-tight">
            Non classées
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px ml-5" style="background-color:#2a2a3a;">
        {uncategorized.map(slug => (
          <a
            href={`/wiki/${slug}`}
            class="group bg-dedsec-darker px-4 py-3 no-underline flex items-center gap-2.5 hover:bg-dedsec-gray/30 transition-colors"
          >
            <span class="flex-shrink-0 font-mono text-[10px] text-dedsec-muted/30">▸</span>
            <span class="font-mono text-[11px] text-dedsec-muted/60 group-hover:text-dedsec-text transition-colors truncate">
              {getTitle(slug)}
            </span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Footer wiki -->
  <div class="not-prose border-t border-dedsec-border pt-6 mt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
    <div class="font-mono text-[10px] text-dedsec-muted/40 tracking-widest uppercase">
      Contenu sous licence CC BY-SA 4.0 &middot; Contributions bienvenues
    </div>
    <div class="flex gap-4">
      <a href="/contribuer" class="font-mono text-[10px] text-dedsec-muted/50 hover:text-neon-green transition-colors no-underline tracking-widest">
        ✎ CONTRIBUER
      </a>
      <a href="/search" class="font-mono text-[10px] text-dedsec-muted/50 hover:text-neon-green transition-colors no-underline tracking-widest">
        ⌕ RECHERCHER
      </a>
    </div>
  </div>

</Layout>
