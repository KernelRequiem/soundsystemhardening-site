---
// Page 404 personnalisée. En output:server + adaptateur Node, Astro la sert
// automatiquement pour toute route inexistante. On garde le Layout (topbar, footer,
// navigation) pour qu'un visiteur égaré puisse repartir, contrairement à la page
// maintenance qui est volontairement nue.
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

// On force le statut HTTP 404 (sinon Astro renverrait 200 sur cette page).
Astro.response.status = 404;

const shortcuts = [
  { href: '/commencer', icon: 'start',    label: 'Commencer ici', desc: 'Le guide d\'entrée du site' },
  { href: '/wiki',      icon: 'wiki',     label: 'Wiki',          desc: 'Droits, OPSEC, stratégie' },
  { href: '/urgence',   icon: 'urgence',  label: 'Urgence',       desc: 'Réflexes face aux forces de l\'ordre', crit: true },
  { href: '/tools',     icon: 'tools',    label: 'Outils',        desc: 'Carte, décision, chiffrement…' },
];
---

<Layout
  title="Page introuvable"
  category="ERREUR 404"
  description="Cette page n'existe pas ou a été déplacée."
>
  <section class="nf not-prose">
    <div class="nf-code"><span class="nf-glitch" data-glitch="404">404</span></div>

    <h1 class="nf-joke" id="nf-joke">Le son est bon, mais l'URL est fausse.</h1>
    <p class="nf-text">
      Lien erroné, page déplacée ou contenu retiré. Rien d'inquiétant : voici par où repartir.
    </p>

    <div class="nf-grid">
      {shortcuts.map((s) => (
        <a href={s.href} class={`nf-card ${s.crit ? 'nf-card--crit' : ''}`}>
          <span class={`nf-card-ic ${s.crit ? 'nf-card-ic--crit' : ''}`}><Icon name={s.icon} size={22} /></span>
          <span class="nf-card-body">
            <span class="nf-card-label">{s.label}</span>
            <span class="nf-card-desc">{s.desc}</span>
          </span>
          <span class="nf-card-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>

    <div class="nf-foot">
      <a href="/" class="nf-home">◆ Retour à l'accueil</a>
      <a href="/search" class="nf-search">⌕ Rechercher dans le site</a>
    </div>

    <p class="nf-report">
      Tu es arrivé ici en suivant un lien du site ? <a href="/contact">Signale-le nous</a>,
      on corrige les liens morts.
    </p>
  </section>

  <script>
    // Punchline 404 tirée au sort (esprit free party / anti-rép, jamais mechant).
    (function () {
      const jokes = [
        "Le son est bon, mais l'URL est fausse.",
        'Cette page est en zone blanche.',
        'Page introuvable : elle a fui le contrôle.',
        'Spot non déclaré. Et cette page non plus.',
        '404 : le kick est là, la page non.',
        'Rien ici. Même pas un mur de son.',
      ];
      const el = document.getElementById('nf-joke');
      if (el) el.textContent = jokes[Math.floor(Math.random() * jokes.length)];
    })();
  </script>
</Layout>

<style>
  .nf { max-width: 640px; margin: 0 auto; padding: 8px 0 24px; text-align: center; }

  .nf-code { line-height: 1; margin-bottom: 14px; }
  /* Glitch identique a HARDENING (home), mais plus frequent : 3s au lieu de 7s. */
  .nf-glitch {
    font-family: 'Bebas Neue', 'Space Grotesk', sans-serif;
    font-size: clamp(80px, 22vw, 160px);
    font-weight: 800; letter-spacing: 0.05em;
    color: #e8e8f0; position: relative; display: inline-block;
    text-shadow: 0 0 28px rgba(0,255,159,0.12);
    animation: nf-glitch-main 3s linear infinite;
  }
  .nf-glitch::before, .nf-glitch::after {
    content: attr(data-glitch); position: absolute; top: 0; left: 0;
    width: 100%; opacity: 0; pointer-events: none;
  }
  .nf-glitch::before { color: #00ff9f; animation: nf-glitch-green 3s linear infinite; }
  .nf-glitch::after  { color: rgba(255, 0, 110, 0.75); animation: nf-glitch-pink 3s linear infinite; }

  @keyframes nf-glitch-main {
    0%, 83%, 100% { transform: translate(0); color: #e8e8f0; }
    84% { transform: translate(-3px, 1px) skewX(-2deg); color: rgba(232, 232, 240, 0.7); }
    85% { transform: translate(4px, -2px); color: #e8e8f0; }
    86% { transform: translate(-2px, 0) skewX(3deg); color: rgba(0, 255, 159, 0.9); }
    87% { transform: translate(3px, 1px); color: #e8e8f0; }
    88% { transform: translate(-1px, -1px); color: rgba(232, 232, 240, 0.85); }
    89% { transform: translate(0); color: #e8e8f0; }
  }
  @keyframes nf-glitch-green {
    0%, 83%, 100% { opacity: 0; transform: translate(0); }
    84% { opacity: 0.85; transform: translate(-4px, 0); clip-path: polygon(0 5%, 100% 5%, 100% 38%, 0 38%); }
    85% { opacity: 0; }
    86% { opacity: 0.9; transform: translate(3px, 0); clip-path: polygon(0 55%, 100% 55%, 100% 78%, 0 78%); }
    87% { opacity: 0; }
    88% { opacity: 0.75; transform: translate(-2px, 0); clip-path: polygon(0 20%, 100% 20%, 100% 55%, 0 55%); }
    89% { opacity: 0; }
  }
  @keyframes nf-glitch-pink {
    0%, 83%, 100% { opacity: 0; transform: translate(0); }
    84% { opacity: 0; }
    85% { opacity: 0.55; transform: translate(5px, 0); clip-path: polygon(0 45%, 100% 45%, 100% 70%, 0 70%); }
    86% { opacity: 0; }
    87% { opacity: 0.6; transform: translate(-4px, 0); clip-path: polygon(0 10%, 100% 10%, 100% 40%, 0 40%); }
    88% { opacity: 0; }
    89% { opacity: 0.45; transform: translate(2px, 0); clip-path: polygon(0 65%, 100% 65%, 100% 90%, 0 90%); }
    90% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .nf-glitch, .nf-glitch::before, .nf-glitch::after { animation: none; }
    .nf-glitch::before, .nf-glitch::after { opacity: 0; }
  }

  .nf-joke { font-family: 'Space Grotesk', sans-serif; font-size: clamp(17px, 3.2vw, 22px); font-weight: 700; color: #e8e8f0; margin: 6px 0 12px; letter-spacing: 0.01em; }
  .nf-text { font-family: 'Space Grotesk', sans-serif; font-size: 14.5px; line-height: 1.65; color: rgba(210,210,224,0.85); margin: 0 auto 28px; max-width: 520px; }

  .nf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 24px; text-align: left; }
  .nf-card {
    display: flex; align-items: center; gap: 12px; padding: 14px 16px;
    border: 1px solid rgba(42,42,58,0.7); border-radius: 4px;
    background: rgba(8,8,12,0.4); text-decoration: none;
    transition: transform 0.15s, border-color 0.2s, background 0.2s;
  }
  .nf-card:hover { transform: translateY(-2px); border-color: rgba(0,255,159,0.4); background: rgba(0,255,159,0.03); }
  .nf-card--crit:hover { border-color: rgba(255,68,68,0.4); background: rgba(255,68,68,0.03); }
  .nf-card-ic { color: rgba(0,255,159,0.7); flex-shrink: 0; display: inline-flex; }
  .nf-card-ic--crit { color: rgba(255,92,92,0.85); }
  .nf-card-body { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
  .nf-card-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.04em; color: #e8e8f0; }
  .nf-card-desc { font-family: 'Space Grotesk', sans-serif; font-size: 11.5px; color: rgba(122,122,138,0.9); line-height: 1.35; }
  .nf-card-arrow { color: rgba(0,255,159,0.4); flex-shrink: 0; transition: transform 0.15s, color 0.15s; font-family: 'JetBrains Mono', monospace; }
  .nf-card:hover .nf-card-arrow { transform: translateX(3px); color: #00ff9f; }

  .nf-foot { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px 24px; margin-bottom: 18px; }
  .nf-home, .nf-search { font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; color: rgba(0,255,159,0.85); text-decoration: none; }
  .nf-home:hover, .nf-search:hover { color: #00ff9f; }
  .nf-report { font-family: 'JetBrains Mono', monospace; font-size: 11px; line-height: 1.6; color: rgba(122,122,138,0.8); margin: 0; }
  .nf-report a { color: rgba(0,255,159,0.8); }
  .nf-report a:hover { color: #00ff9f; }

  @media (max-width: 480px) { .nf-grid { grid-template-columns: 1fr; } }
</style>
