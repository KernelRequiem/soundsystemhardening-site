---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Décision"
  description="Arbre de décision interactif : droits et procédures face aux forces de l'ordre : Avant, Pendant, Après."
  category="OUTILS"
>
  <h1 class="mb-2">◩ DÉCISION</h1>
  <p class="text-dedsec-muted text-sm mb-2 font-mono leading-relaxed">
    Arbre de décision interactif · Contrôle d'identité · Fouille · Interpellation · Garde à vue
  </p>
  <p class="text-dedsec-muted/75 text-xs mb-10 font-mono">
    Réponds aux questions pour obtenir des conseils adaptés à ta situation, avant, pendant et après.
  </p>

  <!-- Indicateur de phase -->
  <div id="phase-bar" class="hidden mb-10">
    <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-dedsec-muted/65 mb-2">Phase active</div>
    <div class="flex items-stretch gap-0 border border-dedsec-border overflow-hidden">
      <button id="pb-avant"   data-phase="avant"   class="phase-bar-btn">◷ Avant</button>
      <div class="w-px bg-dedsec-border shrink-0"></div>
      <button id="pb-pendant" data-phase="pendant" class="phase-bar-btn">◈ Pendant</button>
      <div class="w-px bg-dedsec-border shrink-0"></div>
      <button id="pb-apres"   data-phase="apres"   class="phase-bar-btn">↩ Après</button>
    </div>
  </div>

  <!-- Moteur de rendu -->
  <div id="decision-root"></div>
</Layout>

<style is:global>
  /* ── Phase bar ── */
  .phase-bar-btn {
    flex: 1;
    padding: 10px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-align: center;
    color: rgba(122, 122, 138, 0.72);
    background: transparent;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .phase-bar-btn:hover {
    color: rgba(232, 232, 240, 0.65);
    background: rgba(0, 255, 159, 0.04);
  }
  .phase-bar-btn.active {
    color: #00ff9f;
    background: rgba(0, 255, 159, 0.07);
  }

  /* ── Phase grid ── */
  .phase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }
  @media (min-width: 600px) {
    .phase-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
  }

  /* ── Phase selector cards - layout vertical dans la grille ── */
  .phase-card {
    --ph-color: #00ff9f;
    --ph-rgb: 0, 255, 159;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 24px 22px 20px;
    background: rgba(8, 8, 12, 0.68);
    border: 1px solid rgba(42, 42, 58, 0.80);
    border-top: 3px solid var(--ph-color);
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    transition: border-color 0.18s ease, background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    text-align: left;
    width: 100%;
    min-height: 180px;
  }
  .phase-card:hover {
    background: rgba(var(--ph-rgb), 0.05);
    border-color: rgba(var(--ph-rgb), 0.45);
    border-top-color: var(--ph-color);
    transform: translateY(-4px);
    box-shadow: 0 -3px 0 rgba(var(--ph-rgb), 0.5), 0 12px 40px rgba(var(--ph-rgb), 0.09);
  }
  .phase-card:active {
    transform: translateY(-1px);
    background: rgba(var(--ph-rgb), 0.08);
  }
  .phase-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
    margin-bottom: 18px;
  }
  .phase-card-icon {
    font-size: 30px;
    line-height: 1;
    opacity: 0.68;
    transition: opacity 0.18s, transform 0.18s;
  }
  .phase-card:hover .phase-card-icon {
    opacity: 1;
    transform: scale(1.12);
  }
  .phase-card-step {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(var(--ph-rgb), 0.40);
    transition: color 0.18s;
  }
  .phase-card:hover .phase-card-step {
    color: rgba(var(--ph-rgb), 0.85);
  }
  .phase-card-label {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(232, 232, 240, 0.92);
    margin-bottom: 8px;
    transition: color 0.18s;
  }
  .phase-card:hover .phase-card-label {
    color: #e8e8f0;
  }
  .phase-card-sub {
    font-size: 10px;
    letter-spacing: 0.02em;
    color: rgba(122, 122, 138, 0.68);
    line-height: 1.65;
    flex: 1;
    transition: color 0.18s;
  }
  .phase-card:hover .phase-card-sub {
    color: rgba(122, 122, 138, 0.90);
  }
  .phase-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-top: 20px;
  }
  .phase-card-tag {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(var(--ph-rgb), 0.52);
    border: 1px solid rgba(var(--ph-rgb), 0.15);
    padding: 3px 9px;
    white-space: nowrap;
    transition: border-color 0.18s, color 0.18s;
  }
  .phase-card:hover .phase-card-tag {
    color: rgba(var(--ph-rgb), 1);
    border-color: rgba(var(--ph-rgb), 0.55);
  }
  .phase-card-arrow {
    font-size: 16px;
    color: rgba(var(--ph-rgb), 0);
    transition: color 0.22s ease, transform 0.22s ease;
    transform: translateY(6px);
    line-height: 1;
  }
  .phase-card:hover .phase-card-arrow {
    color: rgba(var(--ph-rgb), 0.72);
    transform: translateY(0);
  }

  /* ── Situation grid ── */
  .situation-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  @media (min-width: 700px) {
    .situation-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }
  }

  /* ── Situation selector cards - vertical dans la grille ── */
  .situation-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 0;
    background: rgba(8, 8, 12, 0.65);
    border: 1px solid rgba(42, 42, 58, 0.80);
    border-top: 2px solid rgba(0, 255, 159, 0.20);
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, transform 0.15s, box-shadow 0.15s;
    text-align: center;
    width: 100%;
    overflow: hidden;
    min-height: 120px;
  }
  .situation-card:hover {
    border-color: rgba(0, 255, 159, 0.48);
    border-top-color: rgba(0, 255, 159, 0.85);
    background: rgba(0, 255, 159, 0.04);
    transform: translateY(-3px);
    box-shadow: 0 -3px 0 rgba(0, 255, 159, 0.45), 0 10px 30px rgba(0, 255, 159, 0.07);
  }
  .situation-card:active {
    transform: translateY(-1px);
    background: rgba(0, 255, 159, 0.08);
  }
  .situation-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    width: 100%;
    padding: 22px 0 14px;
    opacity: 0.68;
    transition: opacity 0.15s, transform 0.15s;
    line-height: 1;
  }
  .situation-card:hover .situation-card-icon {
    opacity: 1;
    transform: scale(1.12);
  }
  .situation-card-label {
    flex: 1;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(232, 232, 240, 0.78);
    line-height: 1.5;
    padding: 0 12px 16px;
    transition: color 0.15s;
  }
  .situation-card:hover .situation-card-label {
    color: rgba(232, 232, 240, 0.97);
  }
  .situation-card-arrow {
    width: 100%;
    text-align: center;
    font-size: 10px;
    color: rgba(0, 255, 159, 0);
    padding: 0 0 14px;
    transition: color 0.2s ease, transform 0.2s ease;
    transform: translateY(4px);
    line-height: 1;
  }
  .situation-card:hover .situation-card-arrow {
    color: rgba(0, 255, 159, 0.60);
    transform: translateY(0);
  }

  /* ── Question box ── */
  .question-box {
    position: relative;
    border: 1px solid rgba(0, 255, 159, 0.2);
    background: rgba(0, 255, 159, 0.03);
    padding: 22px 24px 22px 28px;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .question-box::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, rgba(0,255,159,0.65) 0%, rgba(0,255,159,0.12) 100%);
  }
  .question-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0, 255, 159, 0.55);
    margin-bottom: 10px;
  }
  .question-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: rgba(232, 232, 240, 0.96);
    line-height: 1.5;
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* ── Choice buttons ── */
  .choices-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .choice-btn {
    position: relative;
    width: 100%;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: rgba(8, 8, 12, 0.55);
    border: 1px solid rgba(42, 42, 58, 0.75);
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    overflow: hidden;
  }
  .choice-btn:hover {
    border-color: rgba(0, 255, 159, 0.52);
    background: rgba(0, 255, 159, 0.05);
    transform: translateX(3px);
    box-shadow: -3px 0 0 rgba(0, 255, 159, 0.52), 0 0 24px rgba(0, 255, 159, 0.08);
  }
  .choice-btn:active {
    transform: translateX(1px);
    background: rgba(0, 255, 159, 0.09);
    box-shadow: -3px 0 0 rgba(0, 255, 159, 0.7);
  }
  .choice-num {
    font-size: 11px;
    font-weight: 700;
    color: rgba(0, 255, 159, 0.35);
    flex-shrink: 0;
    width: 26px;
    transition: color 0.15s;
    line-height: 1;
  }
  .choice-btn:hover .choice-num {
    color: rgba(0, 255, 159, 0.88);
  }
  .choice-text {
    font-size: 13px;
    color: rgba(232, 232, 240, 0.8);
    line-height: 1.55;
    flex: 1;
    transition: color 0.15s;
  }
  .choice-btn:hover .choice-text {
    color: rgba(232, 232, 240, 0.97);
  }
  .choice-arrow {
    flex-shrink: 0;
    font-size: 12px;
    color: rgba(0, 255, 159, 0);
    transition: color 0.2s ease, transform 0.2s ease;
    transform: translateX(-8px);
    line-height: 1;
  }
  .choice-btn:hover .choice-arrow {
    color: rgba(0, 255, 159, 0.65);
    transform: translateX(0);
  }
  .choice-tag {
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid rgba(255, 68, 68, 0.4);
    color: rgba(255, 68, 68, 0.85);
    padding: 3px 8px;
    transition: border-color 0.15s, color 0.15s;
  }
  .choice-btn:hover .choice-tag {
    border-color: rgba(255, 68, 68, 0.7);
    color: rgba(255, 68, 68, 1);
  }

  /* ── Resource badges ── */
  .resource-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 7px 14px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .resource-badge::after { display: none; }
  .resource-badge-wiki {
    color: rgba(0, 255, 159, 0.7);
    border: 1px solid rgba(0, 255, 159, 0.18);
    background: rgba(0, 255, 159, 0.03);
  }
  .resource-badge-wiki:hover {
    color: #00ff9f;
    border-color: rgba(0, 255, 159, 0.45);
    background: rgba(0, 255, 159, 0.07);
  }
  .resource-badge-template {
    color: rgba(232, 232, 240, 0.6);
    border: 1px solid rgba(42, 42, 58, 0.9);
  }
  .resource-badge-template:hover {
    color: #e8e8f0;
    border-color: rgba(232, 232, 240, 0.25);
  }
  .resource-badge-contact {
    color: rgba(232, 232, 240, 0.75);
    border: 1px solid rgba(42, 42, 58, 0.9);
    background: transparent;
  }
  .resource-badge-contact:hover {
    color: rgba(232, 232, 240, 0.95);
    border-color: rgba(232, 232, 240, 0.25);
    background: rgba(232, 232, 240, 0.03);
  }
  .resource-badge-external {
    color: rgba(138, 158, 232, 0.78);
    border: 1px solid rgba(138, 158, 232, 0.22);
    background: rgba(138, 158, 232, 0.03);
  }
  .resource-badge-external:hover {
    color: #8a9ee8;
    border-color: rgba(138, 158, 232, 0.5);
    background: rgba(138, 158, 232, 0.08);
  }

  /* ── Document légal : conteneur ── */
  .legal-wrap {
    border: 1px solid rgba(138, 158, 232, 0.22);
    background: rgba(138, 158, 232, 0.03);
    padding: 22px 22px 24px;
    margin-top: 8px;
  }
  .legal-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(138, 158, 232, 0.78);
    margin-bottom: 6px;
  }
  .legal-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: rgba(232, 232, 240, 0.96);
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .legal-intro {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12.5px;
    line-height: 1.7;
    color: rgba(122, 122, 138, 0.92);
    margin: 0 0 14px;
  }
  .legal-recipient {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(232, 232, 240, 0.62);
    border-left: 2px solid rgba(138, 158, 232, 0.4);
    padding: 6px 12px;
    margin-bottom: 16px;
    background: rgba(8, 8, 12, 0.4);
  }

  /* ── Formulaire ── */
  .legal-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 14px;
    margin-bottom: 18px;
  }
  @media (max-width: 640px) {
    .legal-form { grid-template-columns: 1fr; }
  }
  .legal-field { display: flex; flex-direction: column; gap: 5px; }
  .legal-field.full { grid-column: 1 / -1; }
  .legal-field label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(122, 122, 138, 0.85);
  }
  .legal-field input,
  .legal-field textarea {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: rgba(232, 232, 240, 0.95);
    background: rgba(8, 8, 12, 0.7);
    border: 1px solid rgba(42, 42, 58, 0.85);
    padding: 9px 11px;
    width: 100%;
    transition: border-color 0.15s, box-shadow 0.15s;
    resize: vertical;
  }
  .legal-field textarea { min-height: 64px; line-height: 1.6; }
  .legal-field input:focus,
  .legal-field textarea:focus {
    outline: none;
    border-color: rgba(138, 158, 232, 0.6);
    box-shadow: 0 0 0 1px rgba(138, 158, 232, 0.25);
  }

  /* ── Aperçu ── */
  .legal-preview-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .legal-preview-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(122, 122, 138, 0.7);
  }
  .legal-preview {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.75;
    color: rgba(232, 232, 240, 0.86);
    background: rgba(4, 4, 7, 0.75);
    border: 1px solid rgba(42, 42, 58, 0.7);
    padding: 18px 18px;
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 340px;
    overflow: auto;
    margin: 0 0 16px;
  }
  .legal-blank {
    color: rgba(138, 158, 232, 0.85);
    border-bottom: 1px dotted rgba(138, 158, 232, 0.6);
  }

  /* ── Barre d'export ── */
  .legal-actions { display: flex; flex-wrap: wrap; gap: 8px; }
  .legal-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 9px 16px;
    cursor: pointer;
    background: rgba(8, 8, 12, 0.6);
    border: 1px solid rgba(42, 42, 58, 0.85);
    color: rgba(232, 232, 240, 0.8);
    transition: all 0.15s;
  }
  .legal-btn:hover {
    border-color: rgba(138, 158, 232, 0.55);
    color: #e8e8f0;
    background: rgba(138, 158, 232, 0.07);
    transform: translateY(-1px);
  }
  .legal-btn-primary {
    border-color: rgba(138, 158, 232, 0.4);
    color: rgba(138, 158, 232, 0.92);
    background: rgba(138, 158, 232, 0.06);
  }
  .legal-btn-primary:hover {
    border-color: rgba(138, 158, 232, 0.85);
    color: #aab8f2;
    background: rgba(138, 158, 232, 0.12);
  }
  .legal-btn.copied { border-color: rgba(0, 255, 159, 0.6); color: #00ff9f; }
</style>

<script>
import {
  tree,
  PHASE_LABELS,
  PHASE_ICONS,
  PHASE_SUBTITLES,
  SITUATION_ICONS,
  type Phase,
  type DecisionNode,
} from '../data/decision';
import { LEGAL_DOCS, type LegalDoc, type LegalField } from '../data/legal-docs';

// ─── ÉTAT ─────────────────────────────────────────────────────────────────────

let history: string[] = ['root'];

function currentNode(): DecisionNode {
  return tree[history[history.length - 1]];
}

function currentPhase(): Phase | null {
  for (let i = history.length - 1; i >= 0; i--) {
    const n = tree[history[i]];
    if (n?.phase) return n.phase;
  }
  return null;
}

// ─── HELPERS ──────────────────────────────────────────────────────────────────

type SeverityTokens = { border: string; text: string; bg: string; accent: string };

function severityTokens(severity?: string): SeverityTokens {
  if (severity === 'green')  return { border: 'border-neon-green/40',  text: 'text-neon-green',  bg: 'bg-neon-green/5',   accent: '#00ff9f' };
  if (severity === 'orange') return { border: 'border-yellow-400/40', text: 'text-yellow-400', bg: 'bg-yellow-400/5', accent: '#facc15' };
  if (severity === 'red')    return { border: 'border-red-400/40',    text: 'text-red-400',    bg: 'bg-red-400/5',    accent: '#f87171' };
  return { border: 'border-dedsec-border', text: 'text-dedsec-text', bg: 'bg-dedsec-gray/20', accent: '#2a2a3a' };
}

function resourceTypePrefix(type: string): string {
  if (type === 'wiki')     return '◇';
  if (type === 'template') return '▸';
  if (type === 'contact')  return '✆';
  if (type === 'external') return '⤤';
  return '→';
}

function sectionHead(icon: string, label: string, color = 'text-dedsec-muted/65'): string {
  return `
    <div class="flex items-center gap-3 mb-4">
      <span class="font-mono text-[11px] uppercase tracking-[0.16em] ${color}">${icon} ${label}</span>
      <div class="flex-1 h-px bg-dedsec-border/40"></div>
    </div>
  `;
}

// ─── RENDER : BREADCRUMB ──────────────────────────────────────────────────────

function renderBreadcrumb(): string {
  if (history.length <= 1) return '';
  const crumbs = history.map((id, i) => {
    const node  = tree[id];
    const raw   = i === 0 ? 'DÉBUT' : node.text;
    const label = raw.length > 32 ? raw.slice(0, 32) + '…' : raw;
    const isLast = i === history.length - 1;
    return `
      ${i > 0 ? '<span class="text-dedsec-border/70 mx-1">›</span>' : ''}
      ${isLast
        ? `<span class="text-neon-green/80">${label}</span>`
        : `<button class="hover:text-neon-green/80 text-dedsec-muted/65 transition-colors underline underline-offset-2" data-goto="${i}">${label}</button>`
      }
    `;
  }).join('');

  return `
    <nav class="flex items-center flex-wrap gap-0.5 mb-8 font-mono text-[11px] leading-relaxed">
      ${crumbs}
    </nav>
  `;
}

// ─── RENDER : SÉLECTEUR DE PHASE ──────────────────────────────────────────────

function renderPhaseSelector(node: DecisionNode): string {
  const PHASE_RGB: Record<string, string> = {
    avant:   '0, 255, 159',
    pendant: '255, 136, 66',
    apres:   '138, 158, 232',
  };
  const PHASE_TAGS: Record<string, string> = {
    avant:   'Préparation',
    pendant: 'En cours',
    apres:   'Recours',
  };

  const PHASE_COLORS: Record<string, string> = {
    avant:   '#00ff9f',
    pendant: '#ff8842',
    apres:   '#8a9ee8',
  };

  const cards = (node.choices ?? []).map((ch, idx) => {
    const phase = ch.next.replace('sit_', '') as Phase;
    const rgb   = PHASE_RGB[phase] ?? '0, 255, 159';
    const color = PHASE_COLORS[phase] ?? '#00ff9f';
    const tag   = PHASE_TAGS[phase] ?? ch.tag ?? '';
    const step  = String(idx + 1).padStart(2, '0');
    return `
      <button data-next="${ch.next}" class="phase-card animate-fade-in" style="--ph-rgb:${rgb};--ph-color:${color}">
        <div class="phase-card-header">
          <span class="phase-card-icon">${PHASE_ICONS[phase] ?? '◈'}</span>
          <span class="phase-card-step">${step}</span>
        </div>
        <div class="phase-card-label">${ch.label}</div>
        <div class="phase-card-sub">${PHASE_SUBTITLES[phase] ?? ''}</div>
        <div class="phase-card-footer">
          ${tag ? `<span class="phase-card-tag">${tag}</span>` : '<span></span>'}
          <span class="phase-card-arrow">↓</span>
        </div>
      </button>
    `;
  }).join('');

  return `
    <div style="margin-bottom:28px;" class="animate-fade-in">
      <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:rgba(122,122,138,0.65);line-height:1.7;">${node.subtitle ?? ''}</p>
    </div>
    <div class="phase-grid">
      ${cards}
    </div>
  `;
}

// ─── RENDER : SÉLECTEUR DE SITUATION ──────────────────────────────────────────

function renderSituationSelector(node: DecisionNode): string {
  const phase      = node.phase!;
  const phaseLabel = PHASE_LABELS[phase];

  const cards = (node.choices ?? []).map(ch => {
    const sitKey = ch.next.split('_').slice(1).join('_') as keyof typeof SITUATION_ICONS;
    const icon   = SITUATION_ICONS[sitKey] ?? '◈';
    return `
      <button data-next="${ch.next}" class="situation-card animate-fade-in">
        <span class="situation-card-icon">${icon}</span>
        <span class="situation-card-label">${ch.label}</span>
        <span class="situation-card-arrow">▸</span>
      </button>
    `;
  }).join('');

  return `
    <div style="margin-bottom:28px;" class="animate-fade-in">
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(0,255,159,0.62);text-transform:uppercase;letter-spacing:0.22em;margin-bottom:10px;">
        Phase · ${phaseLabel}
      </div>
      <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:rgba(122,122,138,0.78);line-height:1.70;">${node.subtitle ?? ''}</p>
    </div>
    <div class="situation-grid">
      ${cards}
    </div>
  `;
}

// ─── RENDER : NŒUD QUESTION ───────────────────────────────────────────────────

function renderQuestion(node: DecisionNode): string {
  const choices = (node.choices ?? []).map((ch, i) => `
    <button
      data-next="${ch.next}"
      class="choice-btn animate-fade-in"
    >
      <span class="choice-num">${String(i + 1).padStart(2, '0')}.</span>
      <span class="choice-text">${ch.label}</span>
      ${ch.tag ? `<span class="choice-tag">${ch.tag}</span>` : ''}
      <span class="choice-arrow">▸</span>
    </button>
  `).join('');

  return `
    <div class="question-box animate-fade-in">
      <div class="question-label">▸ Question</div>
      <p class="question-text">${node.text}</p>
    </div>
    <div class="choices-list">
      ${choices}
    </div>
  `;
}

// ─── RENDER : NŒUD RÉSULTAT ───────────────────────────────────────────────────

function renderResult(node: DecisionNode): string {
  const c = severityTokens(node.severity);

  // ── En-tête ──
  const header = `
    <div class="relative border ${c.border} ${c.bg} px-6 py-5 mb-8 animate-fade-in overflow-hidden">
      <div class="absolute left-0 top-0 bottom-0 w-[3px]" style="background:${c.accent};opacity:0.7;"></div>
      <div class="flex items-center gap-4">
        <span class="text-3xl leading-none shrink-0">${node.icon ?? '▸'}</span>
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.18em] mb-1.5" style="color:${c.accent};opacity:0.82;">
            ${node.situation ? node.situation.toUpperCase() : ''} · ${node.phase ? node.phase.toUpperCase() : ''}
          </div>
          <h2 class="${c.text} font-mono text-lg font-bold m-0 leading-tight">${node.text}</h2>
        </div>
      </div>
    </div>
  `;

  // ── Contexte juridique ──
  const contextBlock = node.context && node.context !== 'TODO' ? `
    <div class="mb-7 animate-fade-in">
      ${sectionHead('◈', 'Contexte juridique', 'text-dedsec-muted/68')}
      <p class="text-dedsec-text/75 text-sm leading-[1.85] m-0 pl-1" style="font-family:'Space Grotesk',sans-serif">${node.context}</p>
    </div>
  ` : '';

  // ── Actions ──
  const actionsBlock = node.actions?.length && node.actions[0] !== 'TODO' ? `
    <div class="card-neon mb-6 animate-fade-in">
      ${sectionHead('▸', 'Que faire maintenant', 'text-neon-green/70')}
      <ol class="space-y-3 m-0 p-0 list-none">
        ${node.actions.map((a, i) => `
          <li class="flex gap-4 py-1" style="font-family:'Space Grotesk',sans-serif">
            <span class="text-neon-green/50 font-mono text-[11px] shrink-0 mt-[3px] w-6 leading-none">${String(i + 1).padStart(2, '0')}.</span>
            <span class="text-dedsec-text/85 text-sm leading-relaxed">${a}</span>
          </li>
        `).join('')}
      </ol>
    </div>
  ` : '';

  // ── Droits ──
  const rightsBlock = node.rights?.length && node.rights[0] !== 'TODO' ? `
    <div class="card-neon border-neon-green/10 mb-6 animate-fade-in">
      ${sectionHead('◇', 'Tes droits', 'text-neon-green/50')}
      <ul class="space-y-3 m-0 p-0 list-none">
        ${node.rights.map(r => `
          <li class="flex gap-4 py-0.5" style="font-family:'Space Grotesk',sans-serif">
            <span class="text-neon-green/55 shrink-0 mt-[3px] leading-none">◇</span>
            <span class="text-dedsec-muted/80 text-sm leading-relaxed">${r}</span>
          </li>
        `).join('')}
      </ul>
    </div>
  ` : '';

  // ── Pièges ──
  const pitfallsBlock = node.pitfalls?.length && node.pitfalls[0] !== 'TODO' ? `
    <div class="card-neon border-yellow-400/10 mb-6 animate-fade-in">
      ${sectionHead('⚠', 'Pièges courants', 'text-yellow-400/60')}
      <ul class="space-y-3 m-0 p-0 list-none">
        ${node.pitfalls.map(p => `
          <li class="flex gap-4 py-0.5" style="font-family:'Space Grotesk',sans-serif">
            <span class="text-yellow-400/30 shrink-0 mt-[3px] leading-none">⚠</span>
            <span class="text-dedsec-muted/80 text-sm leading-relaxed">${p}</span>
          </li>
        `).join('')}
      </ul>
    </div>
  ` : '';

  // ── Ressources ──
  const resourcesBlock = node.resources?.length ? `
    <div class="mb-6 animate-fade-in">
      ${sectionHead('▸', 'Ressources', 'text-dedsec-muted/65')}
      <div class="flex flex-wrap gap-2">
        ${node.resources.map(r => {
          const isExternal = r.type === 'external' || /^https?:\/\//.test(r.href);
          const attrs = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '';
          const tail  = isExternal ? '↗' : '→';
          return `
          <a href="${r.href}"${attrs} class="resource-badge resource-badge-${r.type}">
            <span class="opacity-60">${resourceTypePrefix(r.type)}</span>
            <span>${r.label}</span>
            <span class="opacity-40">${tail}</span>
          </a>
        `;
        }).join('')}
      </div>
    </div>
  ` : '';

  // ── Phase suivante ──
  const nextPhaseBlock = node.next_phase ? `
    <div class="mt-8 pt-6 border-t border-dedsec-border/25 animate-fade-in">
      <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-dedsec-muted/60 mb-3">
        Continuer vers la phase suivante
      </div>
      <button
        data-next="${node.next_phase.next}"
        class="w-full flex items-center justify-between gap-4
               border border-neon-green/20 hover:border-neon-green/50
               hover:bg-neon-green/4 px-6 py-4
               font-mono text-sm text-neon-green/60 hover:text-neon-green/90
               transition-all duration-200"
      >
        <span>${node.next_phase.label}</span>
        <span class="text-xl opacity-60">→</span>
      </button>
    </div>
  ` : '';

  const legalBlock = buildLegalSection(node.id);

  return header + contextBlock + actionsBlock + rightsBlock + pitfallsBlock + resourcesBlock + legalBlock + nextPhaseBlock;
}

// ─── RENDER : DOCUMENT LÉGAL + FORMULAIRE ─────────────────────────────────────

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function renderField(f: LegalField): string {
  const cls   = 'legal-field' + (f.full ? ' full' : '');
  const ph    = f.placeholder ? ` placeholder="${escapeHtml(f.placeholder)}"` : '';
  const input = f.type === 'textarea'
    ? `<textarea data-field="${f.id}" rows="3"${ph}></textarea>`
    : `<input type="${f.type ?? 'text'}" data-field="${f.id}"${ph} />`;
  return `
    <div class="${cls}">
      <label for="lf-${f.id}">${escapeHtml(f.label)}</label>
      ${input}
    </div>
  `;
}

function buildLegalSection(nodeId: string): string {
  const doc = LEGAL_DOCS[nodeId];
  if (!doc) return '';

  const recipient = doc.recipient
    ? `<div class="legal-recipient">À adresser à : ${escapeHtml(doc.recipient)}</div>`
    : '';

  const refs = doc.legalRefs?.length
    ? `<div class="legal-meta" style="margin-top:14px;opacity:0.7">Fondements : ${doc.legalRefs.map(escapeHtml).join(' · ')}</div>`
    : '';

  const wikiLink = doc.wiki
    ? `<a href="${doc.wiki.href}" class="resource-badge resource-badge-template" style="margin-top:14px">
         <span class="opacity-60">▸</span>
         <span>${escapeHtml(doc.wiki.label)}</span>
         <span class="opacity-40">→</span>
       </a>`
    : '';

  return `
    <div class="mt-7 animate-fade-in">
      ${sectionHead('▤', 'Document légal', 'text-[#8a9ee8]/70')}
      <div class="legal-wrap" data-legal="${nodeId}">
        <div class="legal-meta">${escapeHtml(doc.docType)}</div>
        <h3 class="legal-title">${escapeHtml(doc.title)}</h3>
        <p class="legal-intro">${escapeHtml(doc.intro)}</p>
        ${recipient}
        <form class="legal-form" onsubmit="return false">
          ${doc.fields.map(renderField).join('')}
        </form>
        <div class="legal-preview-head">
          <span class="legal-preview-label">▸ Aperçu du document</span>
        </div>
        <div class="legal-preview" data-legal-preview></div>
        ${refs}
        ${wikiLink}
        <div class="legal-actions">
          <button type="button" class="legal-btn legal-btn-primary" data-legal-act="print">⎙ Imprimer / PDF</button>
          <button type="button" class="legal-btn" data-legal-act="email">✉ Email</button>
          <button type="button" class="legal-btn" data-legal-act="copy">⧉ Copier</button>
          <button type="button" class="legal-btn" data-legal-act="txt">↓ .txt</button>
        </div>
      </div>
    </div>
  `;
}

// ─── DOCUMENT LÉGAL : LOGIQUE D'EXPORT ────────────────────────────────────────

function legalValues(wrap: HTMLElement): Record<string, string> {
  const values: Record<string, string> = {};
  wrap.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[data-field]').forEach(el => {
    values[el.dataset.field!] = el.value;
  });
  return values;
}

function fillTemplate(body: string, values: Record<string, string>, mode: 'preview' | 'export'): string {
  if (mode === 'export') {
    return body.replace(/\{\{(\w+)\}\}/g, (_, k) => {
      const v = (values[k] ?? '').trim();
      return v ? v : '............................';
    });
  }
  // preview : HTML échappé + champs vides surlignés
  return escapeHtml(body).replace(/\{\{(\w+)\}\}/g, (_, k) => {
    const v = (values[k] ?? '').trim();
    return v
      ? `<span style="color:rgba(138,158,232,0.95)">${escapeHtml(v)}</span>`
      : `<span class="legal-blank">·············</span>`;
  });
}

function updateLegalPreview(wrap: HTMLElement): void {
  const id  = wrap.dataset.legal!;
  const doc = LEGAL_DOCS[id];
  if (!doc) return;
  const preview = wrap.querySelector<HTMLElement>('[data-legal-preview]');
  if (preview) preview.innerHTML = fillTemplate(doc.body, legalValues(wrap), 'preview');
}

function legalPlainText(wrap: HTMLElement): { doc: LegalDoc; text: string } {
  const id  = wrap.dataset.legal!;
  const doc = LEGAL_DOCS[id];
  const head = doc.recipient ? `À adresser à : ${doc.recipient}\n\n` : '';
  const text = head + fillTemplate(doc.body, legalValues(wrap), 'export');
  return { doc, text };
}

function printLegalDoc(wrap: HTMLElement): void {
  const { doc, text } = legalPlainText(wrap);
  const iframe = document.createElement('iframe');
  iframe.style.position = 'fixed';
  iframe.style.right = '0';
  iframe.style.bottom = '0';
  iframe.style.width = '0';
  iframe.style.height = '0';
  iframe.style.border = '0';
  document.body.appendChild(iframe);

  const docHtml = `<!doctype html><html lang="fr"><head><meta charset="utf-8">
    <title>${escapeHtml(doc.title)}</title>
    <style>
      @page { margin: 22mm 20mm; }
      * { box-sizing: border-box; }
      body { font-family: Georgia, 'Times New Roman', serif; color: #111; margin: 0; }
      .doc-type { font-family: Arial, sans-serif; font-size: 10px; letter-spacing: 0.14em;
        text-transform: uppercase; color: #555; margin-bottom: 4px; }
      h1 { font-size: 17px; margin: 0 0 18px; border-bottom: 1.5px solid #111; padding-bottom: 8px; }
      pre { font-family: 'Courier New', monospace; font-size: 12px; line-height: 1.7;
        white-space: pre-wrap; word-break: break-word; margin: 0; }
      .refs { margin-top: 22px; padding-top: 10px; border-top: 1px solid #999;
        font-family: Arial, sans-serif; font-size: 9.5px; color: #666; }
      .foot { margin-top: 26px; font-family: Arial, sans-serif; font-size: 8.5px; color: #999; }
    </style></head><body>
    <div class="doc-type">${escapeHtml(doc.docType)}</div>
    <h1>${escapeHtml(doc.title)}</h1>
    <pre>${escapeHtml(text)}</pre>
    ${doc.legalRefs?.length ? `<div class="refs">Fondements : ${escapeHtml(doc.legalRefs.join(' · '))}</div>` : ''}
    <div class="foot">Modèle indicatif à adapter. Pour les actes contentieux, faire valider par un avocat.</div>
    </body></html>`;

  const idoc = iframe.contentWindow?.document;
  if (!idoc) { iframe.remove(); return; }
  idoc.open();
  idoc.write(docHtml);
  idoc.close();

  const doPrint = () => {
    iframe.contentWindow?.focus();
    iframe.contentWindow?.print();
    setTimeout(() => iframe.remove(), 1500);
  };
  if (iframe.contentWindow?.document.readyState === 'complete') {
    setTimeout(doPrint, 60);
  } else {
    iframe.onload = () => setTimeout(doPrint, 60);
  }
}

function emailLegalDoc(wrap: HTMLElement): void {
  const { doc, text } = legalPlainText(wrap);
  const subject = encodeURIComponent(`${doc.docType} - ${doc.title}`);
  const body    = encodeURIComponent(text);
  window.location.href = `mailto:?subject=${subject}&body=${body}`;
}

function copyLegalDoc(wrap: HTMLElement, btn: HTMLElement): void {
  const { text } = legalPlainText(wrap);
  const done = () => {
    const original = btn.textContent;
    btn.textContent = '✓ Copié';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = original; btn.classList.remove('copied'); }, 1600);
  };
  if (navigator.clipboard?.writeText) {
    navigator.clipboard.writeText(text).then(done).catch(() => fallbackCopy(text, done));
  } else {
    fallbackCopy(text, done);
  }
}

function fallbackCopy(text: string, done: () => void): void {
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.style.position = 'fixed';
  ta.style.opacity = '0';
  document.body.appendChild(ta);
  ta.select();
  try { document.execCommand('copy'); done(); } catch {}
  ta.remove();
}

function downloadLegalTxt(wrap: HTMLElement): void {
  const { doc, text } = legalPlainText(wrap);
  const slug = doc.title.toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url;
  a.download = `${slug || 'document'}.txt`;
  document.body.appendChild(a);
  a.click();
  a.remove();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

function bindLegalSection(): void {
  const wrap = document.querySelector<HTMLElement>('[data-legal]');
  if (!wrap) return;

  updateLegalPreview(wrap);

  wrap.querySelectorAll<HTMLElement>('[data-field]').forEach(el => {
    el.addEventListener('input', () => updateLegalPreview(wrap));
  });

  wrap.querySelectorAll<HTMLButtonElement>('[data-legal-act]').forEach(btn => {
    btn.addEventListener('click', () => {
      switch (btn.dataset.legalAct) {
        case 'print': printLegalDoc(wrap);          break;
        case 'email': emailLegalDoc(wrap);          break;
        case 'copy':  copyLegalDoc(wrap, btn);      break;
        case 'txt':   downloadLegalTxt(wrap);       break;
      }
    });
  });
}

// ─── RENDER : BOUTONS DE NAVIGATION ───────────────────────────────────────────

function renderNavButtons(node: DecisionNode): string {
  if (history.length <= 1) return '';

  return `
    <div class="flex gap-3 mt-10 pt-6 border-t border-dedsec-border/20 animate-fade-in">
      <button id="btn-back"
        class="flex items-center gap-2 border border-dedsec-border/70
               hover:border-dedsec-text/40 text-dedsec-muted/75 hover:text-dedsec-text/85
               font-mono text-xs px-5 py-2.5 transition-all">
        ← Retour
      </button>
      <button id="btn-restart"
        class="flex items-center gap-2 border border-dedsec-border/55
               hover:border-neon-green/40 text-dedsec-muted/58 hover:text-neon-green/75
               font-mono text-xs px-5 py-2.5 transition-all">
        ↺ Recommencer
      </button>
    </div>
  `;
}

// ─── PHASE BAR ────────────────────────────────────────────────────────────────

function updatePhaseBar(): void {
  const bar = document.getElementById('phase-bar');
  if (!bar) return;

  const phase = currentPhase();
  bar.classList.toggle('hidden', !phase);
  if (!phase) return;

  (['avant', 'pendant', 'apres'] as Phase[]).forEach(p => {
    document.getElementById(`pb-${p}`)?.classList.toggle('active', p === phase);
  });
}

// ─── RENDER PRINCIPAL ─────────────────────────────────────────────────────────

function render(): void {
  const node      = currentNode();
  const container = document.getElementById('decision-root');
  if (!container) return;

  let html = renderBreadcrumb();

  switch (node.type) {
    case 'phase-select':     html += renderPhaseSelector(node);     break;
    case 'situation-select': html += renderSituationSelector(node); break;
    case 'question':         html += renderQuestion(node);          break;
    case 'result':           html += renderResult(node);            break;
  }

  html += renderNavButtons(node);
  container.innerHTML = html;

  updatePhaseBar();
  bindEvents();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ─── EVENTS ───────────────────────────────────────────────────────────────────

function bindEvents(): void {
  const container = document.getElementById('decision-root');
  if (!container) return;

  container.querySelectorAll<HTMLButtonElement>('[data-next]').forEach(btn => {
    btn.addEventListener('click', () => {
      history.push(btn.dataset.next!);
      render();
    });
  });

  container.querySelectorAll<HTMLButtonElement>('[data-goto]').forEach(btn => {
    btn.addEventListener('click', () => {
      history = history.slice(0, parseInt(btn.dataset.goto!) + 1);
      render();
    });
  });

  document.getElementById('btn-back')?.addEventListener('click', () => {
    if (history.length > 1) history.pop();
    render();
  });

  document.getElementById('btn-restart')?.addEventListener('click', () => {
    history = ['root'];
    render();
  });

  bindLegalSection();
}

// ─── PHASE BAR CLICKS ─────────────────────────────────────────────────────────

document.addEventListener('DOMContentLoaded', () => {
  const phaseToNode: Record<string, string> = {
    avant: 'sit_avant', pendant: 'sit_pendant', apres: 'sit_apres',
  };

  (['avant', 'pendant', 'apres'] as Phase[]).forEach(p => {
    document.getElementById(`pb-${p}`)?.addEventListener('click', () => {
      history = ['root', phaseToNode[p]];
      render();
    });
  });

  render();
});
</script>
