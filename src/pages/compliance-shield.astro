        <label class="rl-check"><input type="checkbox" id="f-chill-out" /><span>Espace chill-out aménagé</span></label>
        <label class="rl-check"><input type="checkbox" id="f-affichage-urgence" /><span>Numéros urgences affichés (15 / 18 / 112)</span></label>
