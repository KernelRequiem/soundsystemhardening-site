  <script>
    import '../scripts/compliance-shield.ts';

    // Guide toggle
    const guideToggle = document.getElementById('guideToggle');
    const guidePanel  = document.getElementById('guidePanel');
    const guideArrow  = document.getElementById('guideArrow');
    if (guideToggle && guidePanel && guideArrow) {
      guideToggle.addEventListener('click', () => {
        const open = guidePanel.classList.toggle('open');
        guidePanel.setAttribute('aria-hidden', String(!open));
        guideToggle.setAttribute('aria-expanded', String(open));
        guideArrow.textContent = open ? '▾' : '▸';
      });
    }

    // Reset
    document.getElementById('btnReset')?.addEventListener('click', () => {
      if (!confirm('Réinitialiser le formulaire ? (le brouillon localStorage n\'est pas purgé)')) return;
      (document.getElementById('csForm') as HTMLFormElement)?.reset();
    });
  </script>

