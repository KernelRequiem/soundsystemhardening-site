    </fieldset>

    <!-- ── S11 : Bilan de sortie (phase post) ────────────────── -->
    <fieldset class="rl-section" id="sectionBilan" style="display:none">
      <legend class="rl-legend"><span class="rl-num">11</span> Bilan et restitution du site</legend>
