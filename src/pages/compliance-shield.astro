        <label class="rl-check"><input type="checkbox" id="f-remise-etat" /><span>Engagement de remise en état + évacuation totale des déchets</span></label>
      </div>
    </fieldset>

    <!-- ── S09 : Photos état des lieux (avant) ───────────────── -->
    <fieldset class="rl-section">
      <legend class="rl-legend"><span class="rl-num">09</span> État des lieux d'entrée (photos avant installation)</legend>
      <p class="cs-field-hint">Documente l'état initial du terrain avant l'arrivée du matériel. Ces photos sont les preuves les plus fortes contre toute accusation de dégradation. EXIF / GPS supprimés automatiquement.</p>

      <div class="rl-upload-zone" id="zoneAvant">
        <input type="file" id="f-photos-avant" accept="image/*" multiple class="rl-file-input" />
