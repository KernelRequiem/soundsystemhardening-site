        </div>
      </div>
      <div id="previewAvant" class="photo-preview-grid" style="display:none"></div>
    </fieldset>

    <!-- ── S10 : Organisation interne ────────────────────────── -->
    <fieldset class="rl-section">
      <legend class="rl-legend"><span class="rl-num">10</span> Organisation interne et gestion du site</legend>

      <div class="rl-field">
        <label for="f-referents" class="rl-label">Référents et rôles (sécurité, son, entrée, secours...)</label>
        <textarea id="f-referents" name="referents" rows="4" class="rl-textarea" placeholder="ex: SÉCURITÉ - Prénom NOM, joignable talkie canal 6. RÉGIE SON - Prénom NOM, consignes SPL. ENTRÉE - Prénom NOM, infoline..."></textarea>
      </div>

      <div class="rl-type-grid" style="margin-top:12px">
        <label class="rl-check"><input type="checkbox" id="f-brief-secu" /><span>Briefing sécurité réalisé avant ouverture du site</span></label>
      </div>

      <div class="rl-field" style="margin-top:12px">
        <label for="f-procedure-incident" class="rl-label">Procédure en cas d'incident</label>
        <textarea id="f-procedure-incident" name="procedure-incident" rows="3" class="rl-textarea" placeholder="ex: Tout incident = contacter le référent sécurité, appel 15 / 18 / 112 sans attendre, arrêt sono si évacuation demandée..."></textarea>
      </div>

      <div class="rl-field" style="margin-top:12px">
        <label for="f-parking" class="rl-label">Gestion du stationnement et des flux véhicules</label>
